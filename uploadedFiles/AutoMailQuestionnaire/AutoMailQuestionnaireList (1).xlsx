<?xml version="1.0"?>
<ArrayOfQuestionnaireAutoMailViewModel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <QuestionnaireAutoMailViewModel>
    <id>1049</id>
    <subject>Not Defined Yet: Buy American Act – Invitation</subject>
    <text>&lt;p style="font-family: Verdana; font-size: 12px;"&gt;&lt;i&gt;Dear Valued Supplier,&lt;/i&gt;&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;Doing business with the U.S. Federal Government requires Honeywell and our supply base to comply with several critical statutory and regulatory requirements: &lt;b&gt; Not Defined Yet (BAA)&lt;/b&gt; being one.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;To begin the BAA Certification questionnaire, please click on this&lt;a href="https://www.intelleges.com/MVCMT/Generic/Registration?Accesscode=[partner Access Code]"&gt;hyperlink&lt;/a&gt;and enter Access Code &lt;b&gt;[partner Access Code]&lt;/b&gt; which is unique to your company. We have identified those part numbers and/or components contained in our end products that have a corresponding National Stock Number (NSN) requiring a BAA Certification. Please respond to the applicable question(s) for each part number listed in your queue.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;In the event you are not the correct person to receive this BAA Certification invitation, please click &lt;a href="https://www.intelleges.com/MVCMT/Generic/WrongContact?Accesscode=[partner Access Code]"&gt;here&lt;/a&gt;to re-direct the invitation to the correct individual.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;&lt;b&gt;&lt;u&gt;Please complete the online BAA Certification questionnaire no later than [Due Date]&lt;/u&gt;&lt;/b&gt;. Failure to complete and submit this certification may jeopardize future business opportunities with Honeywell-Aerospace.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;The online certification tool is provided by Intelleges®, Intelleges is Honeywell’s third party host of this questionnaire and has been contracted to securely manage the data as it is submitted. All information you provide will be kept completely confidential.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;We have provided a short &lt;a href="https://www.youtube.com/watch?v=d-27qS0k9rU&amp;feature=youtu.be"&gt;Not Defined Yet Certification Training Video&lt;/a&gt; to familiarize yourself with the overall process. In addition, after you've logged into the online certification there are several icons, in the upper left-hand corner of the page, that will link you to key documents pertaining to the certification requirement.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;If you have any questions regarding this BAA Certification requirement, please feel free to contact your Honeywell Commodity Manager or Buyer.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;Honeywell-Aerospace extends its sincere thanks in advance for your support and assistance with this key compliance initiative.&lt;/p&gt;</text>
    <footer1>&lt;br&gt;[Provider HRO Full Name] [Provider HRO Title] [Provider HRO Email]&lt;/p&gt;</footer1>
    <mailType>1</mailType>
    <partnerTypeTouchpointQuestionnaire>2076</partnerTypeTouchpointQuestionnaire>
    <sendDateCalcFactor>0</sendDateCalcFactor>
    <sendDateSet xsi:nil="true" />
  </QuestionnaireAutoMailViewModel>
  <QuestionnaireAutoMailViewModel>
    <id>1050</id>
    <subject>Not Defined Yet: Buy American Act – Incomplete Reminder</subject>
    <text>&lt;p style="font-family: Verdana; font-size: 12px;"&gt;
&lt;i&gt;Dear Valued Supplier,&lt;/i&gt;&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;This is a reminder your &lt;i&gt;Not Defined Yet (BAA) Certification questionnaire&lt;/i&gt; is &lt;b&gt;INCOMPLETE.&lt;/b&gt;&lt;/p
&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;Please take the time now to finish the online BAA Certification questionnaire by clicking on this &lt;a href='https://www.intelleges.com/MVCMT/Generic/Registration?Accesscode=[partner Access Code]'&gt;hyperlink&lt;/a&gt;and enter Access Code &lt;b&gt;[partner Access Code]&lt;/b&gt; which is unique to your company.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;In the event you are not the correct person to receive this BAA Certification invitation, please click &lt;a href='https://www.intelleges.com/honeywellBAA/wrongContact.aspx?ProviderIdSession=[Provider Encrypted Id]&amp;ProviderEmailSession=[Provider Contact Email]&amp;ProviderCodeSession=[Provider Access Code]'&gt;here&lt;/a&gt; to re-direct this invitation to the correct individual.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;&lt;b&gt;&lt;i&gt;&lt;u&gt;Please complete the online BAA Certification questionnaire AS SOON AS POSSIBLE.&lt;/u&gt;&lt;/i&gt;&lt;/b&gt;Failure to complete and submit this certification may jeopardize future business opportunities with Honeywell-Aerospace.&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;If you have any questions regarding this BAA Certification requirement, please feel free to contact your Honeywell Commodity Manager or Buyer.&lt;/p&gt; &lt;br&gt;[Provider HRO Full Name] [Provider HRO Title] [Provider HRO Email]&lt;/p&gt;&lt;p style="font-family: Verdana; font-size: 12px;"&gt;Thank you.&lt;/p&gt;</text>
    <footer1>&lt;br&gt;[Provider HRO Full Name] [Provider HRO Title] [Provider HRO Email]&lt;/p&gt;</footer1>
    <footer2 />
    <mailType>2</mailType>
    <partnerTypeTouchpointQuestionnaire>2076</partnerTypeTouchpointQuestionnaire>
    <sendDateCalcFactor>7</sendDateCalcFactor>
    <sendDateSet xsi:nil="true" />
  </QuestionnaireAutoMailViewModel>
  <QuestionnaireAutoMailViewModel>
    <id>1051</id>
    <subject>Not Defined Yet: Buy American Act – Completed Confirmation</subject>
    <text>&lt;p style="font-family: Verdana; font-size: 12px;"&gt;Your online certification is &lt;b&gt;COMPLETE&lt;/b&gt;.&lt;/p&gt;&lt;br&gt; &lt;p style="font-family: Verdana; font-size: 12px;"&gt;Please keep this &lt;a href='https://www.intelleges.com/MVCMT/Generic/Registration?Accesscode=[partner Access Code]'&gt;hyperlink&lt;/a&gt; and Access Code &lt;b&gt;[partner Access Code]&lt;/b&gt; in case you need to make any changes in the future.&lt;/p&gt; &lt;p style="font-family: Verdana; font-size: 12px;"&gt;Thank you again for completing your Not Defined Yet (BAA) Certification.</text>
    <footer1>&lt;br&gt;[Provider HRO Full Name] [Provider HRO Title] [Provider HRO Email]&lt;/p&gt;</footer1>
    <footer2 />
    <mailType>3</mailType>
    <partnerTypeTouchpointQuestionnaire>2076</partnerTypeTouchpointQuestionnaire>
    <sendDateCalcFactor>7</sendDateCalcFactor>
    <sendDateSet xsi:nil="true" />
  </QuestionnaireAutoMailViewModel>
