<script type="text/javascript">
    $(document).ready(function () {
        if ('@ViewBag.isEmailChanged' == "1") {
            alertify.set({
                labels: {
                    ok: "No",
                    cancel: "Yes"
                },
                buttonFocus: "cancel"
            });
            // button labels will be "Accept" and "Deny"
            alertify.confirm("you have changed email address this requires redirect, would you like to redirect this questionnaire to someone else?", function (e) {
                if (e) {
                    $('#email').val('@Session["currentEmail"].ToString()');

                } else {
                    // user clicked "cancel"
                    window.location.replace("@Url.Content("~/wrongContact?AccessCode="+ViewBag.accessCode)");
                }
            });
        }
    });
</script>