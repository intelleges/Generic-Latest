                                    <span id="ctl00_contentQuestionnaireBody_requiredtxtCity" style="color:Red;display:none;"><br />Required</span>*@
                                                        @Html.EditorFor(model => model.city)
                                                        @Html.ValidationMessageFor(model => model.city)
                                                    </td>
