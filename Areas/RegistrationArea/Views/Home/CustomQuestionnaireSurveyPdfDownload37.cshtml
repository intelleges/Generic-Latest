                <br />
                <li>
                    <b>
                        <input type="checkbox" @ViewBag.Checkbox57258_124280 />
                        N/A - Work will be performed outside the US by employees not recruited within the US, District of Columbia, Puerto Rico, Northern Mariana Islands, American Samoa, Guam, US Virgin Islands and Wake Island(AC)
                    </b>
                </li>
                <br />
                <li><b>If <i>No</i>, please provide your FEDERAL REGISTRATION NUMBER:(AA)</b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; @(ViewBag.Checkbox57258_Comment ?? String.Empty)</li>
            </ul>
        </div>


        <div>
