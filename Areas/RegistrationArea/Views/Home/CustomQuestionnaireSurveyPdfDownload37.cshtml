@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc.Html
@using System.Web.Mvc
@using Generic.Helpers

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title></title>
    <style>
        body {
            font-family: "Calibri, serif";
        }

        h1 {
            font-size: 25px;
        }

        h2 {
            font-size: 18px;
        }

        h3 {
            font-size: 17px;
        }

        h4 {
            font-size: 16px;
        }

        p {
            font-size: 16px;
        }

        .ml25 {
            margin-left: 25px;
        }

        .ml50 {
            margin-left: 50px;
        }

        .ml75 {
            margin-left: 75px;
        }

        .text-center {
            text-align: center;
        }

        ul.hr li {
            display: inline;
            margin-right: 5px;
            padding: 3px;
        }

        li {
            list-style-type: none;
        }

        .mt20 {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <FONT FACE="Calibri, serif">
        <table width="100%">
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(ViewBag.logoSrc))
                    {
                        <img src="@ViewBag.logoSrc" runat="server" style="height:50px; width:300px; border:none" />
                    }
                </td>
            </tr>
        </table>
        <div>
            <ul class="ml25">
                <li><i><input type="checkbox" /> Commercial Unique</i></li>
                <li><i><input type="checkbox" checked="checked" /> Commercial FAR Part 12</i></li>
                <li><i><input type="checkbox" /> Non-Commercial FAR Part 15</i></li>
            </ul>
        </div>
        <table width="100%" style="margin-top:20px;">
            <tr>
                <td style="color: #081835" class="text-center">
                    <h1>SUPPLIER CERTIFICATION and ASSESSMENT<br />CALENDAR YEAR 2022</h1>
                </td>
            </tr>
            <tr>
                <td class="text-center">
                    <p>All current and prospective Celestica suppliers are required to complete the Annual Certification and Assessment each calendar year.  Suppliers are required to certify their compliance with the following FAR/DFARS requirements.</p>
                </td>
            </tr>
        </table>
        @foreach (var item in ViewBag.partnerHeader)
        {
            <table width="100%" cellpadding="0" cellspacing="0" border="1">
                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        ONESOURCE SUPPLIER ID# (DUNS#)  @ViewBag.partner.dunsNumber
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        Celestica SAP/LOCAL SUPPLIER #  @ViewBag.partner.federalID
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        PRIMARY NAICS CODE  @ViewBag.PrimaryNaicsCode
                    </td>
                </tr>
                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="3">
                        SUPPLIER NAME: @ViewBag.partner.name
                    </td>
                </tr>
                <tr>
                    <td colspan="2">
                        <table width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                    SUPPLIER ADDRESS (Manufacturing address - no PO Box): @ViewBag.partner.address1
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                    @ViewBag.partner.address2
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    CITY/TOWN: @ViewBag.partner.city
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    STATE/PROVINCE/REGION: @ViewBag.state
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    ZIP CODE:
                                    @if (ViewBag.partner.zipcode != null)
                                    {
                                        @MvcHtmlString.Create(ViewBag.partner.zipcode.ToString().Length > 5 ? ViewBag.partner.zipcode.ToString().Substring(0, 5) + "-" + ViewBag.partner.zipcode.ToString().Substring(5, ViewBag.partner.zipcode.ToString().Length - 5) : ViewBag.partner.zipcode);
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    COUNTRY: @ViewBag.country
                                </td>
                            </tr>
                        </table>
                    </td>
                    <td>
                        <table width="100%" cellpadding="0" cellspacing="0" style="height:150px; border-collapse:collapse" border="1">
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                    CONTACT NAME: @ViewBag.partner.firstName @ViewBag.partner.lastName
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                    CONTACT TELEPHONE#: @ViewBag.partner.phone
                                </td>
                                <td width="30%" style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                    CONTACT FAX#: @ViewBag.partner.fax
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                    CONTACT EMAIL ADDRESS: @ViewBag.partner.email
                                    <br />
                                    <br />
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        }

        <br />
        <div>
            <h2><b>1.&nbsp;<i><u>Envronmental Policy:</u></i></b></h2>
            <p class="ml25">
                Does your company have an environmental policy?
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57143_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57143_No /> No </b></li>
                <li><b>If <i>No</i>, futher comment or explaination required:</b>&nbsp;&nbsp; @(ViewBag.Checkbox57143_Comment ?? String.Empty) </li>
            </ul>
        </div>

        <div>
            <h2><b>2.&nbsp;<i><u>Do you know what your annual scope 1 emissions (globally) in mt CO2e was in 2020?</u></i></b></h2>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57144_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57144_No /> No </b></li>
                <li><b>If Yes, CO2e emission in mt</b>&nbsp;&nbsp; @(ViewBag.Checkbox57144_Comment ?? String.Empty) </li>
            </ul>
        </div>

        <div>
            <h2><b>3.&nbsp;<i><u>Do you know what your annual scope 2 emissions (globally) in mt CO2e was in 2021?</u></i></b></h2>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57145_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57145_No /> No </b></li>
                <li><b>If Yes, CO2e emission in mt</b>&nbsp;&nbsp; @(ViewBag.Checkbox57145_Comment ?? String.Empty) </li>
            </ul>
        </div>
        <div>
            <h2><b>4.&nbsp;<i><u>Do you have a policy for diversity, discrimination, and harassment?</u></i></b></h2>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57146_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57146_No /> No </b></li>
            </ul>
        </div>
        <div>
            <h2><b>5.&nbsp;<i><u>Cybersecurity Maturity Model Certification(CMMC):</u></i></b></h2>
            <p class="ml25">
                Requirements pertaining to CMMC are either anticipated or are now in place via a contract clause or RFP requirement. Suppliers must achieve CMMC certification at or above the required CMMC level before issuance of a Purchase Order (LSC). Suppliers who are required to receive, generate, or store Controlled Unclassified Information (CUI) must achieve a CMMC Level 3 or higher certification before issuance of a PO or LSC. Answer the question below based on your organization's current state regarding CMMC.<br>  Offeror represents that it (Select only ONE of the following):
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox57147_124136 /> Has been certified by an accredited 3rd party assessor(AA) </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57147_124137 /> Has not been certified but has begun the certification process, or intends to seek certification, by an accredited 3rd party CMMC assessor(AB) </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57147_124138 /> Does not intend to seek CMMC certification(AC) </b></li>
            </ul>
        </div>
        <div>
            <h2><b>6.&nbsp;<i><u>Celestica Code of Business Conduct</u></i></b></h2>
            <p class="ml25">It is the policy of Celestica to take reasonable steps to ensure that its suppliers and potential suppliers have the highest level of business ethics consistent with, or similar to Celestica's requirements for integrity and compliance and requires its suppliers to certify to the same. </p>
            <h4 class="ml50"><b><i>Supplier acknowledges</i></b></h4>
            <p class="ml50">
                It has implemented the systems, procedures and processes consistent with, or similar to, the Celestica Inc and Celestica Supplier Code of Business Conduct located at http://Celestica.com/About/Pages/code-of-business-conduct.aspx.
                <b><i><u>or will adhere to their own Code of Business Conduct, which supports the spirit of Celestica's requirements for integrity and compliance.</u></i></b>
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57151_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57151_No /> No </b></li>
                <li><b>If <i>No</i>, further comment/explanation required:</b>&nbsp;&nbsp; @(ViewBag.Checkbox57151_Comment ?? String.Empty)</li>
            </ul>
        </div>
        <div>
            <h2><b>7.&nbsp;<i><u>Overall Supplier Capabilities</u></i></b></h2>
            <p class="ml25">Supplier has adequate financial resources, technical equipment, facilities and the organizational experience, skills and controls available or has the ability to obtain them to perform awarded contracts.</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57152_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57152_No /> No </b></li>
                <li><b>If <i>No</i>, further comment/explanation required:</b>&nbsp;&nbsp; @(ViewBag.Checkbox57152_Comment ?? String.Empty)</li>
            </ul>
        </div>
        <div>
            <h2><b>8.&nbsp;<i><u>Certificate of Insurance</u></i></b></h2>
            <p class="ml25">
                Does your company have a
                <hint text="The Certificate of Insurance (COI), is typically a copy of your company?s Certificate of Liability Insurance which you?ll have to obtain from your insurer.  Please reference Celestica's General Purchase Order Provisions available on Celestica's Supply Chain Collaboration Portal at https://scc.Celestica.com for further information on the Insurance requirement">Certificate of Insurance</hint>? <br>
                <span style="color:Red;"><b><i>If a Certificate Holder is required for insurer to issue a Certificate of Insurance, please use:</i></b></span>
                <br>    Celestica LLC<br>    11 Continental Blvd.<br>    Merrimack, NH  03054<br> <b><i>Notice:</i></b>  Hard copies of your Certificate of Insurance should be mailed to:<br>    Celestica LLC<br>    4163 Pea Ridge Rd<br>    Maryville, TN 37804<br>    Attn:  Edwin Bond<br> Or email to:  EBond@Celestica.com
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57153_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57153_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">Please select the principal Commodity Manager that you work with</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57154_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57154_No /> No </b></li>
                @if (!string.IsNullOrEmpty(ViewBag.Checkbox57154_Yes))
                {
                    <br />
                    <li><b>Provide full name of commodity Manager you are currenty working with : </b>&nbsp;&nbsp; @(ViewBag.Checkbox57154_Comment ?? String.Empty)</li>
                }
            </ul>
        </div>

        <div>
            <p class="ml25">Please select the main location that [partner name] supplies</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124144 /> Brockton(AH) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124145 /> Mable Grove, MN(AG) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124146 /> Mexicali, Baja California, Mexico(AA) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124147 /> Mississauga, Ontario, Canada(AB) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124148 /> New Hope(AH) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124149 /> Newmarket, Ontario, Canada(AC) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124150 /> Rochester(AI) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124151 /> Tuscon, Arizona, USA(AD) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57155_124152 /> Other/None of the above(AF) </b></li>
                <br />
                <li><b>Please provide details about which location you work with that are not listed(AF) : </b>&nbsp;&nbsp; @(ViewBag.Checkbox57155_Comment ?? String.Empty)</li>
            </ul>
        </div>

        <div>
            <p class="ml25">Do you know the name of the current Buyer/Supply Chain Manager (SCM) that you work with</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57156_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57156_No /> No </b></li>
                <br />
                <li><b>Please provide full name of buyers/suppply chain manager you work with : </b>&nbsp;&nbsp; @(ViewBag.Checkbox57156_Comment ?? String.Empty)</li>
            </ul>
        </div>

        <div>
            <h2><b>9.&nbsp;<i><u>Disaster Recovery Emergency Contact</u></i></b></h2>
            <p class="ml25">
                Due to the unprecedented number of worldwide natural and man-made disaster events such as extreme hurricanes, typhoons, wildfires, mega-earthquakes and geo-political unrest.  Celestica takes supply chain crisis management and the welfare of our suppliers very seriously.  In an effort to quickly understand the impact to our suppliers, their shipments and recovery, we are implementing an advanced automated 2-way emergency notification system allowing a more effective management of these types of events.  In order to do this, we need your company's Emergency Contact details.  Communication is key and it is expected we hear from you within 24 hours after the disaster.  International cell phones can be unreliable, therefore we suggest you use LAN-lines or email.
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57157_124153 /> Our Disaster Recovery Emergency Contact is the same person who's listed on the <b><i>Contact Info page</i></b>(AA) </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57157_124154 /> Our Disaster Recovery Emergency Contact is someone other than the person listed on the Contact Info page.(AB) </b></li>
            </ul>
        </div>

        <div>
            <h2><b>10.&nbsp;<i><u>North American Industrial Classification System (NAICS) Code</u></i></b></h2>
            <p class="ml25">
                Is your facility located in North America (United States, Canada, or Mexico)?
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57164_124155 /> Yes(AA) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57164_124156 /> N/A - Non-US supplier located outside of North America(AB) </b></li>
                @if (!string.IsNullOrEmpty(ViewBag.Checkbox57164_124155))
                {
                    <br />
                    <li>
                        Please provide your <b><i>PRIMARY</i></b> 6-digit <a href="http://www.census.gov/eos/www/naics/" rel="nofollow me noopener noreferrer" target="_blank">
                            NAICS Code
                        </a> that best represents the material or service your firm supplies to Celestica-Aerospace:&nbsp; @(ViewBag.Checkbox57164_Comment ?? String.Empty)
                    </li>
                }
            </ul>
        </div>

        <div>
            <h2><b>10.&nbsp;<i><u>NAICS Code <u>(Secondary)</u></u></i></b></h2>
            <p class="ml25">
                Do you have additional NAICS Codes you would like to list?
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57165_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57165_No /> No </b></li>
                @if (!string.IsNullOrEmpty(ViewBag.Checkbox57165_Yes))
                {
                    <br />
                    <li>
                        Please provide any additional <a href="http://www.census.gov/eos/www/naics/" rel="nofollow me noopener noreferrer" target="_blank">NAICS Codes</a> that may apply &nbsp;&nbsp; @(ViewBag.Checkbox57165_Comment ?? String.Empty)
                    </li>
                }
            </ul>
        </div>

        <div>
            <h2><b>10.&nbsp;<i><u>Supplier Demographics</u></i></b></h2>
            <p class="ml25">Is your company a</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124157 /> US Small Business(AB) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124158 /> US Large Business(AC) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124159 /> US Alaska Native Corps & Indian Tribes(AD) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124160 /> US Historically Black College or University or Minority Institution (HBCU/MI)(AE) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124161 /> US University or College(AF) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124162 /> US Non-Profit(AG) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124163 /> US Government Agency/Entity(AA) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124164 /> Non-US Canadian Business(AH) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124165 /> Non-US Small Business (Less Than 500 Employees)(AI) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124166 /> Non-US Large Business (500 or More Employees)(AJ) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57166_124167 /> Non-US University or College(AK) </b></li>
                <br />
                <li> Please provide name of Government Agency/Entity:(AA) &nbsp;&nbsp; @(ViewBag.Checkbox57166_Comment ?? String.Empty) </li>
            </ul>
        </div>

        <div>
            <h2><b>10.&nbsp;<i><u>Notice of Penalty</u></i></b></h2>
            <p class="ml25">
                Supplier understands, under <a href="http://www.gpo.gov/fdsys/granule/USCODE-2011-title15/USCODE-2011-title15-chap14A-sec645" rel="nofollow me noopener noreferrer" target="_blank">15 U.S.C. 645(d)</a>, any person who misrepresents a firm's status as a small business concern, a qualified HUBZone small business concern, a small business concern owned and controlled by socially and economically disadvantaged individuals, or a small business concern owned and controlled by women in order to obtain for oneself or another any:<br> &nbsp;&nbsp;&nbsp;&nbsp; (a) prime contract to be awarded pursuant to Section 638, 644 or 657(a) of this title;<br> &nbsp;&nbsp;&nbsp;&nbsp; (b) subcontract to be awarded pursuant to Section 637(a) of this title;<br> &nbsp;&nbsp;&nbsp;&nbsp; (c) subcontract to be included as part or all of a goal contained in a subcontracting plan required pursuant to section 637(d) of this title; or<br> &nbsp;&nbsp;&nbsp;&nbsp; (d) prime or subcontract to be awarded as a result, or in furtherance, of any other provision of Federal law that speciifically references Section 637(d) of this title for a definition of program eligibility, shall be:<br> &nbsp;&nbsp;&nbsp;&nbsp; (a) punished by a fine of not more than $500,000 or by imprisonment for not more than 10 years, or both;<br> &nbsp;&nbsp;&nbsp;&nbsp; (b) subject to the administrative remedies prescribed by the Program Fraud Civil Remedies Action of 1986 (31 U.S.C. 3801-3812);<br> &nbsp;&nbsp;&nbsp;&nbsp; (c) subject to suspension and debarment as specified in subpart 9.4 of title 48, Code of Federal Regulations (or any successor regulation; and<br> &nbsp;&nbsp;&nbsp;&nbsp; (d) ineligible for participation in any program or activity conducted under the authority of this chapter or the Small Business Investment Act of 1958 (15 U.S.C. 661 et seq) for a period not to exceed 3 years.
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57167_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57167_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">Is your company a veteran-owned business?</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57168_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57168_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">Is your company a service disabled veteran-owned business?</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57169_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57169_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">
                Is your company a "qualified" HUBZone business?
                <br> <span style="color:Red;">
                    <b><i>May ONLY certify as a HUBZone supplier if your company is listed on the "Qualified HUBZone Small Business Concerns List" maintained by the Small Business Administration.</i></b>
                </span>
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57170_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57170_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">
                Is your company a disadvantaged/minority-owned business?
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57171_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox57171_No /> No </b></li>
            </ul>
        </div>

        <div>
            <p class="ml25">
                <b><i>Minority Ownership:</i></b>
                <br>
                Only if supplier has represented itself above as a Small Disadvantaged Business (SDB) or Women-Owned Small Disadvantaged Business (WOSDB), please check the appropriate category of ownership
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox57172_124168 /> Black American(AB) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57172_124169 /> Hispanic American(AC) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57172_124170 /> Native American (American Indians, Eskimos, Aleuts, or Native Hawaiians)(AD) </b></li>
                <br />
                <li><b><input type="checkbox" @ViewBag.Checkbox57172_124171 /> Asian-Pacific American (persons with origins from Burma, Thailand, Malaysia, Indonesia, Singapore, Brunei, Japan, China, Taiwan, Laos, Cambodia (Kampuchea), Vietnam, Korea, The Philippines, Republic of Palau, Republic of the Marshall Islands, Federated States of Micronesia, the Commonwealth of the Northern Mariana Islands, Guam, Samoa, Macao, Hong Kong, Fiji, Tonga, Kiribati, Tuvalu, or Nauru)(AE) </b></li>
                <br />
                <li>
