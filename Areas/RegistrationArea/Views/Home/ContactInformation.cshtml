@inherits System.Web.Mvc.WebViewPage<Generic.partner>
@using System.Web.Mvc.Html
@using Generic.Helpers
@{
    Layout = Generic.Helpers.LayoutHelper.GetRegistrationLayout();
    ViewBag.Title = "Contact Information";
}
@section Bottom{
    <div class="banner1">
        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="float: left; margin-top: -44px">
            <tr>
                <td width="20%" align="right">
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td width="22%" valign="top">
                                <ul id="qm0" class="qmmc" style="width: 775px;">
                                    <li><a class="qmparent" href=""></a></li>
                                    <li><a class="qmparent" id="contactUS">@ViewBag.CONTACT_US_EMAIL</a></li>                                    
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_PDF" target="_blank">@ViewBag.QUESTIONNAIRE_PDF</a></li>
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_FAQ" target="_blank">@ViewBag.QUESTIONNAIRE_FAQ</a> </li>
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_DOC_OTHER" target="_blank">@ViewBag.QUESTIONNAIRE_DOC_OTHER</a> </li>
                                    <li><a class="qmparent" href="@ViewBag.QUESTIONNAIRE_VIDEO_LINK" target="_blank">@ViewBag.QUESTIONNAIRE_VIDEO</a> </li>
                                    <li class="qmclear">&nbsp;</li>
                                </ul>  
                            </td>
                            <td width="20%" align="right" valign="top"></td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>
}
@section Top{
    <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
            <td height="77" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td width="76%" align="center" valign="top" class="supplytitleblueone">
                            <span id="ctl00_lblSurvey">


                                @{
                                   
                                    @Html.Raw(ViewBag.CMS_PAGE_TITLE)
                                    
                                    <span style="font-size: 12px">
                                        @Html.Raw(ViewBag.CMS_PAGE_SUBTITLE)
                                    </span>
                                    
                                
                                }

                            </span>
                        </td>
                        <td width="13%" height="106" valign="bottom">
                            <img src="~/Contents/images/tickmark.gif" alt="" width="95" height="89" class="surveyban" />
                        </td>
                    </tr>
                </table>
            </td>

        </tr>
        <tr>
            <td height="119" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td valign="top">
                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyleft">&nbsp;
                                    </td>
                                </tr>
                                <tr>

                                    <td class="supplyleft">

                                        <div id="ctl00_RegistrationPageText">


                                           
                                                @Html.Raw(ViewBag.CMS_PAGE_PANEL_ONE)
                                            



                                        </div>


                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td valign="top">

                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyright">&nbsp;
                                    </td>
                                </tr>
                                <tr>
                                    <td class="supplyright">
     
                                                @Html.Raw(ViewBag.CMS_PAGE_PANEL_TWO)
                                            



                                        <!--<span style="color: #0096c9;">Instructions:</span> Enter your access code (found in your invitation email) below to complete Honeywell’s Site Security Survey.-->
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
}

<table width="89%" height="78" border="0" align="center" cellpadding="0" cellspacing="0">
    <tr>
        <td>&nbsp;
        </td>
    </tr>
    <tr>
        <td>

            <table class="infobox" width="665" border="0" align="center" cellpadding="0" cellspacing="0">
                <tr>
                    <td>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                            <tr>
                                <td height="25" colspan="2" class="infotitlebg">Contact Information <span class="infotitlenormal">(Please verify that your contact information is correct)</span>
                                </td>
                            </tr>
                            <tr>
                                <td valign="top" width="60%">
                                    <table width="400" border="0" cellpadding="0" cellspacing="0">
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        <tr>
                                            <td height="150">
                                                <table width="300" border="0" align="center" cellpadding="0" cellspacing="0">
                                                    <tr>
                                                        <td class="infobluecont">
                                                            <strong>
                                                                <span id="ctl00_contentQuestionnaireBody_lblFirstName">@Model.firstName</span>
                                                                <span id="ctl00_contentQuestionnaireBody_lblLastName">@Model.lastName</span>
                                                            </strong>
                                                            <br />
                                                            <span class="infobluecontnormal">
                                                                <span id="ctl00_contentQuestionnaireBody_lblTitle">@Model.title</span>
                                                                <br />
                                                                <span id="ctl00_contentQuestionnaireBody_lblEmail">@Model.email</span>
                                                                <br />
                                                                <span id="ctl00_contentQuestionnaireBody_lblPhone">@Model.phone</span>
                                                                <br />
                                                                <span id="ctl00_contentQuestionnaireBody_lblFax">@Model.fax</span>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td width="40%" align="right" valign="bottom">
                                    <table width="230" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td width="103" align="right">
                                                <input type="submit" name="btnEdit" id="btnEdit" onclick="window.location = 'EditContactInformation';" value="@ViewBag.CMS_PAGE_PREVIOUS_TEXT" style="border-width: 0px;" />
                                            </td>
                                            <td width="112" align="right">
                                                <form action="@Url.Action("CorrectContactInformation")">
                                                    <input type="submit" name="btnNext" id="btnNext" value="@ViewBag.CMS_PAGE_NEXT_TEXT" style="border-width: 0px;" />
                                                </form>
                                            </td>
                                            <td width="15">&nbsp;
                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2">&nbsp;
                                            </td>
                                            <td>&nbsp;
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2">&nbsp;
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td>&nbsp;
        </td>
    </tr>
</table>
