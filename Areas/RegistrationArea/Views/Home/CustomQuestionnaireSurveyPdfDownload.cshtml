@using System.Web.Mvc.Html
@using System.Web.Mvc
@using Generic.Helpers

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title></title>
</head>
<body>
    <table width="100%">
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(ViewBag.logoSrc))
                {
                    <img src="@ViewBag.logoSrc" runat="server" style="height:50px; width:300px; border:none" />
                }
            </td>
        </tr>
    </table>
    <table width="100%" style="margin-top:10px;">
        <tr>
            <td style="font-size: 25px; text-align:center; color: #081835">
                SUPPLIER CERTIFICATION and REPRESENTATION FOR CALENDAR YEAR 2016<br />
                U.S. GOVERNMENT REGULATIONS AND STATUTES
            </td>
        </tr>
        <tr>
            <td style="font-size: 15px; text-align:left; color: #081835">
                Procurement of materials, services and supplies for a United States Government-funded contract requires that prime contractors,
                subcontractors and suppliers comply with socioeconomic programs enacted into public law.  Other procurements require compliance with
                Executive Orders, Congressional Law, and other regulations.  Specific requirements are listed in the Sections below.
            </td>
        </tr>
    </table>



    @foreach (var item in ViewBag.partnerHeader)
    {
        <table width="100%" cellpadding="0" cellspacing="0" border="1">
            <tr style="height:40px">
                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                    ONESOURCE SUPPLIER ID# (DUNS#):  @ViewBag.partner.dunsNumber
                </td>
                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                    HONEYWELL SAP/LOCAL SUPPLIER #:  @ViewBag.partner.federalID
                </td>
            </tr>
            <tr style="height:40px">
                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                    SUPPLIER NAME: @ViewBag.partner.name
                </td>
            </tr>
            <tr>
                <td>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                SUPPLIER ADDRESS (Manufacturing address - no PO Box): @ViewBag.partner.address1
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                @ViewBag.partner.address2
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                CITY/TOWN: @ViewBag.partner.city
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                STATE/PROVINCE/REGION: @ViewBag.state
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                ZIP CODE:
                                @if (ViewBag.partner.zipcode != null)
                                {
                                    @MvcHtmlString.Create(ViewBag.partner.zipcode.ToString().Length > 5 ? ViewBag.partner.zipcode.ToString().Substring(0, 5) + "-" + ViewBag.partner.zipcode.ToString().Substring(5, ViewBag.partner.zipcode.ToString().Length - 5) : ViewBag.partner.zipcode);
                                }
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                COUNTRY: @ViewBag.country
                            </td>
                        </tr>
                    </table>
                </td>
                <td>
                    <table width="100%" cellpadding="0" cellspacing="0" style="height:150px; border-collapse:collapse" border="1">
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                CONTACT NAME: @ViewBag.partner.firstName @ViewBag.partner.lastName
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                CONTACT TELEPHONE#: @ViewBag.partner.phone
                            </td>
                            <td width="30%" style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                CONTACT FAX#: @ViewBag.partner.fax
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                CONTACT EMAIL ADDRESS: @ViewBag.partner.email
                                <br />
                                <br />
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    }

    <br />
    <br />

    <div>
        <p><b> 1. <i>BUSINESS SIZE AND TYPE CLASSIFICATION</i></b></p>
        <p><i>SUPPLIER</i> represents that it is a<b> <i><u style="color:blue">(Check ALL that apply)</u></i></b></p>

        <p style="height:3px; "><input type="checkbox" @ViewBag.CheckboxLarge /> Large Business </p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox1 /> Minority-Owned (Min)</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox2 /> Woman-Owned (Wom)</p>

        <p style="height:3px; "><input type="checkbox" @ViewBag.CheckboxSmall /> Small Business (Sm)</p>

        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox3 />Minority/Disadvantaged Business (Dis)</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox4 />Woman-Owned (Wom)</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox5 />Veteran-Owned (Vet)</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox6 />Service Disabled Veteran-Owned (SD)</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox7 />HUBZone Business** (HZ)</p>


        <p style="margin-left:40px; color:red;">
            <b>
                <i>
                    ** Please attach a copy of your company's SBA HUBZone Certification
                    Letter. You may ONLY certify as a HUBZone supplier if your company is listed on
                    the &quot;Qualified HUBZone Small Business Concerns List&quot; maintained by the Small
                    Business Administration.
                </i>
            </b>
        </p>

        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox8 /> Historically Black College or University</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox9 /> Minority Institution</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox10 /> University or College</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox11 /> Non-Profit Organization</p>
        <p style="height:3px; margin-left:40px;"><input type="checkbox" @ViewBag.Checkbox11_comment />with Disabled Persons	</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox12 /> Alaska Native Corps. &amp; Indian Tribes that have not been certified by the SBA as a Small Disadvantaged Business (ANC)</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox13 /> Alaska Native Corps. &amp; Indian Tribes that are not Small Businesses (Large, ANC)</p>


        <p style="height:4px">
            <input type="checkbox" @ViewBag.Checkbox14 /> Government Agency / Entity: Explain:
            <input type="text" style="width:450px; height:20px" value="@(ViewBag.Input0 ?? String.Empty)" />
        </p>

        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox15 /> Canadian</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox16 /> Non-U.S. Small Business (under 500 employees)</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox17 /> Non-U.S. Large Business (500 + employees)</p>

        <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
            <tr>
                <td style="text-align:center; width:150px" valign="top">
                    <p style="text-align:center"><b>NOTICE</b></p>
                    <p style="text-align:center"><b>OF</b></p>
                    <p style="text-align:center"><b>PENALTY</b></p>
                </td>
                <td valign="top">
                    <p>
                        Supplier understands, under 15 U.S.C. 645(d), any person who misrepresents a firm's status that is small, HUBZone small, small disadvantaged, service-disabled veteran-owned small, economically disadvantaged women-owned small, or women-owned small eligible under the WOSB Program in order to obtain a contract to be awarded under the preference programs established pursuant to section 8, 9, 15, 31 and 36 of the Small Business Act or any other provision of Federal law that specifically references section 8(d) for a definition of program eligibility, shall (i) be punished by imposition of fine, imprisonment, or both; (ii) be subject to administrative remedies, including suspension and debarment; and (iii) be ineligible for participation in programs conducted under the authority of the Act (FAR 52.219-1(d)(2)).
                    </p>
                </td>
            </tr>
            <tr>
                <td></td>
                <td>
                    <b><input type="checkbox" @ViewBag.Checkbox18 /> YES </b>
                    <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox19 /> NO </b>
                    <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input2 ?? String.Empty)" style="width:450px; height:20px" /></b>
                </td>
            </tr>
        </table>

        <p><b> MINORITY OWNERSHIP:  <i><u>ONLY</u></i>  IF SUPPLIER HAS REPRESENTED ITSELF ABOVE AS A SMALL DISADVANTAGED BUSINESS (SDB) OR WOMEN-OWNED SMALL DISADVANTAGED BUSINESS (WOSDB), PLEASE CHECK THE APPROPRIATE CATEGORY OF OWNERSHIP:  (FAR 52.219-1 Alt 1)</b></p>

        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox20 /> A. Black American</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox21 /> B. Hispanic American</p>
        <p style="height:3px"><input type="checkbox" @ViewBag.Checkbox22 /> C. Native American: American Indians, Eskimos, Aleuts, or Native Hawaiians</p>
        <p style="height:60px"><input type="checkbox" @ViewBag.Checkbox23 /> D. Asian-Pacific American: persons with origins from Burma, Thailand, Malaysia, Indonesia, Singapore, Brunei, Japan, China, Taiwan, Laos, Cambodia (Kampuchea), Vietnam, Korea, The Philippines, U.S. Trust Territory of the Pacific Islands (Republic of Palau), Republic of the Marshall Islands, Federated States of Micronesia, the Commonwealth of the Northern Mariana Islands, Guam, Samoa, Macao, Hong Kong, Fiji, Tonga, Kiribati, Tuvalu or Nauru</p>
        <p style="height:20px;">
            <input type="checkbox" @ViewBag.Checkbox24 />
            E. Subcontinent Asian (Asian-Indian) American: persons with origins from India, Pakistan, Bangladesh, Sri Lanka, Bhutan, the Maldives Islands, or Nepal
        </p>
        <p style="height:3px;">
            <input type="checkbox" @ViewBag.Checkbox25 /> F. Individual/concern, other than one of the preceding. Explain:
            <input type="text" value="@(ViewBag.Input3 ?? String.Empty)" style="width:450px; height:20px" />
        </p>

    </div>
    <p style="margin-top:60px; color:gray">
        <b>
            <i style="text-align:left">Page 1 of 5</i>
            <i style="margin-left:250px">Supplier Certifications and Representations</i>
            <i style="margin-left:200px">AF 0014I (2016)</i>
        </b>
    </p>
    <div style="margin-top:35px">
        <p><b> 2. <i>REPRESENTATION OF ADHERENCE TO HONEYWELL'S "CODE OF BUSINESS CONDUCT"</i></b></p>
        <p>It is the policy of Honeywell to take reasonable steps to ensure that its suppliers and potential suppliers have ethic programs that meet Honeywell requirements for integrity and compliance, and to require its suppliers to certify to the same.</p>
        <p>
            <b><i>SUPPLIER  acknowledges:</i></b>
        <p style="margin-left:20px">It has their own Code of Business Conduct in place which supports the spirit of Honeywell's requirements for integrity and compliance; OR has reviewed and understands the Honeywell Code of Business Conduct (Code), located at Internet website:</p>

        <p style="text-align:center"><a href="http://honeywell.com/About/Pages/code-of-business-conduct.aspx">http://honeywell.com/About/Pages/code-of-business-conduct.aspx</a></p>

        <p style="margin-left:20px">and agrees to fully comply and take all necessary steps to assist Honeywell in complying with the Code and its spirit.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox26 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox27 /> NO </b>
            <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input4 ?? String.Empty)" style="width:450px; height:20px" /></b>
        </p>

    </div>

    <div>
        <p><b> 3. <span class="style1"><i>NORTH AMERICAN INDUSTRY CLASSIFICATION SYSTEM (NAICS) CODE (FAR 19.102)</i></span></b></p>

        <p>If your facility is located in the United States, Canada, or Mexico, please provide your primary NAICS Code and any additional NAICS Codes if applicable.</p>

        <table border="1" cellpadding="0" cellspacing="0" style="text-align:center; margin-left:auto; margin-right:auto">
            <tr>
                <td valign="top" style="width:250px">
                    <b>Primary NAICS Code:</b>
                </td>
                <td style="width:250px">
                    <input type="text" value="@(ViewBag.Input5 ?? String.Empty)" />
                </td>
                <td><p>(Must be 6 digits)</p></td>
            </tr>
            <tr>
                <td valign="top" style="width:250px">
                    <b>List additional NAICS Code:</b>
                </td>
                <td style="width:250px">
                    <input type="text" value="@(ViewBag.Input6 ?? String.Empty)" />
                </td>
                <td><p>(Must be 6 digits)</p></td>
            </tr>

        </table>

        <p>The NAICS Code listings can be found through the Internet site: <a href="http://www.census.gov/epcd/www/naics.html">http://www.census.gov/eos/www/naics/</a> </p>

    </div>

    <div>
        <p><b> 4. <i>CERTIFICATION OF PREVIOUS CONTRACTS SUBJECT TO EQUAL OPPORTUNITY CLAUSE</i></b></p>

        <p> <i>SUPPLIER</i> has participated in a previous contract or subcontract subject to the Equal Opportunity Clause.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox28 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox29 /> NO </b>
        </p>

    </div>

    <div>
        <p><b> 5. <i>CERTIFICATION OF EQUAL OPPORTUNITY COMPLIANCE REPORTS</i></b></p>

        <p><i>SUPPLIER</i> has filed all required Compliance reports.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox30 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox31 />NO&nbsp;&nbsp;<input type="checkbox" @ViewBag.Checkbox73 />Less than 50 employees, therefore exempt</b>

        </p>
        <p><b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input7 ?? String.Empty)" style="width:450px; height:20px" /></b></p>
    </div>

    <div>

        <p><b> 6. <i>CERTIFICATION OF AFFIRMATIVE ACTION PROGRAM COMPLIANCE</i></b> <b><i style="color:blue;">(Check ONLY one)</i></b></p>

        <p><input type="checkbox" @ViewBag.Checkbox32 /> A. Supplier has developed and has on file, at each establishment, affirmative action programs required by the rules and regulations of the Secretary of Labor (41 CFR 60-1 and 60-2); OR

        <p><input type="checkbox" @ViewBag.Checkbox33 /> B. Supplier has not previously had contracts subject to the written affirmative action program requirement of the rules and regulations of the Secretary of Labor.
        <p><input type="checkbox" @ViewBag.Checkbox34 /> C. Supplier has less than 50 employees, therefore exempt.
    </div>
    <div>
        <p><b> 7. <i>CERTIFICATION OF COMPLIANCE WITH VETERANS EMPLOYMENT REPORTING REQUIREMENTS</i></b></p>

        <p><i>SUPPLIER</i> certifies for any Honeywell award subject to the reporting requirements of 38 U.S.C. 4212(d) (e.g., contracts containing FAR Clause 52.222-37, Employment Reports on Veterans) it has submitted the most recent VETS-100A Report as required by 52.222-37.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox35 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox36 /> NO&nbsp;&nbsp;<input type="checkbox" @ViewBag.Checkbox74 />Less than 50 employees, therefore exempt</b>
            <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input8 ?? String.Empty)" style="width:350px; height:20px" /></b>
        </p>

    </div>

    <div>
        <p>
            <b> 8. <i>CERTIFICATION REGARDING DEBARMENT, SUSPENSION, PROPOSED DEBARMENT AND OTHER RESPONSIBILITY MATTERS</i></b>
            <b><i style="color:blue;">(Check ONLY one)</i></b>
        </p>

        <p><input type="checkbox" @ViewBag.Checkbox37 /> A. Supplier certifies, to the best of its knowledge and belief that your firm and/or any of its Principals ARE presently debarred, suspended, proposed for debarment, or declared ineligible for the award of contracts by any Federal agency.</p>

        <p><input type="checkbox" @ViewBag.Checkbox38 /> B. Supplier certifies, to the best of its knowledge and belief that your firm and/or any of its Principals ARE NOT presently debarred, suspended, proposed for debarment, or declared ineligible for the award of contracts by any Federal agency</p>

    </div>
    <p style="margin-top:200px;color:gray">
        <b>
            <i style="text-align:left">Page 2 of 5</i>
            <i style="margin-left:250px">Supplier Certifications and Representations</i>
            <i style="margin-left:200px">AF 0014I (2016)</i>
        </b>
    </p>
    <div style="margin-top:60px">
        <p><b> 9. <i>CERTIFICATE OF INDEPENDENT PRICE DETERMINATION (<a href='https://www.acquisition.gov/far/current/html/52_200_206.html#wp1137583 '>FAR 52.203-2</a>)</i></b></p>

        <p>A. <i>SUPPLIER</i> certifies:</p>

        <p style="margin-left:40px">1.  The prices in all offers to Honeywell have been arrived at independently, without, for the purpose of restricting competition, any consultation, communication, or agreement with any other offeror or competitor relating to (i) those prices; (ii) the intention to submit an offer; or (iii) the methods or factors used to calculate the prices offered.</p>

        <p style="margin-left:40px">2. The prices in all offers to Honeywell have not been and will not be knowingly disclosed by the offeror, directly or indirectly, to any other offeror or competitor before bid opening (in the case of a sealed bid solicitation) or contract award (in the case of a negotiated solicitation) unless otherwise required by law; and</p>

        <p style="margin-left:40px">3. No attempt has been made or will be made by the offeror to induce any other concern to submit or not to submit an offer for the purpose of restricting competition.</p>

        <p>B. Each signature on an offer to Honeywell is considered to be a certification by the signatory that the signatory:</p>

        <p style="margin-left:40px">1. Is the person in the offeror's organization responsible for determining the prices being offered in any bid or proposal, and that the signatory has not participated and will not participate in any action contrary to subparagraphs A.1 through A.3 of this Section; or</p>

        <p style="margin-left:40px">2. (i) Has been authorized, in writing, to act as agent for the principals involved in certifying that those principals have not participated, and will not participate in any action contrary to subparagraphs A.1 through A.3 of this Section; (ii) As an authorized agent, does certify that such principals have not participated, and will not participate, in any action contrary to subparagraphs A.1 through A.3 of this Section; and (iii) As an agent, has not personally participated, and will not participate, in any action contrary to subparagraphs A.1 through A.3 of this Section.</p>

        <p>C. If <i>SUPPLIER</i> deletes or modifies subparagraph A.2 of this Section, <i>SUPPLIER</i> must furnish with its offer a signed statement setting forth in detail the circumstances of the disclosure.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox39 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox40 /> NO </b>
            <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input9 ?? String.Empty)" style="width:450px; height:20px" /></b>
        </p>

    </div>

    <div>
        <p><b>10. <i>CERTIFICATION REGARDING PAYMENTS TO INFLUENCE CERTAIN FEDERAL TRANSACTIONS (<a href='https://www.acquisition.gov/far/current/html/52_200_206.html#wp1137568'>FAR 52.203-11</a>)</i></b></p>

        <p><i>SUPPLIER</i> certifies, to the best of its knowledge and belief, <b><u>NO</u></b> Federal appropriated funds have been paid or will be paid to any person to influence or attempt to influence certain Government officials to award or modify a Federal contract.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox41 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox42 /> NO </b>
        </p>

    </div>

    <div>
        <p><b>11. <i>DISCLOSURE REGARDING PAYMENTS TO INFLUENCE CERTAIN FEDERAL TRANSACTIONS (<a href='https://www.acquisition.gov/far/current/html/52_200_206.html#wp1137568'>FAR 52.203-11</a>)</i></b></p>

        <p><i>SUPPLIER</i> agrees to submit to Honeywell OMB Standard Form LLL prior to any contract award of $150,000 or greater when supplier has paid or will pay Federal appropriated funds to influence certain Government officials to award or modify a Federal contract.</p>

        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox43 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox44 /> NO </b>
            <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input10 ?? String.Empty)" style="width:450px; height:20px" /></b>
        </p>

    </div>

    <div>
        <p><b>12. <i>STATEMENT TO PREVENT TRANSACTIONS WITH DENIED PERSONS/DEBARRED PARTIES/SDN</i></b></p>

        <p>To ensure compliance of U.S. export laws, Honeywell does not conduct any business transaction with the "Denied Persons List" published by the U.S. Department of Commerce, the "Denied Parties List" published by the Department of State and the "Specially Designated Nationals" list published by the Department of Treasury, Foreign Assets Control.  Honeywell expects all suppliers and its subcontractors to comply with these laws as well.  Supplier agrees to include this requirement in lower-tier Purchase Orders and/or subcontracts.  (You may view the U.S. Government web sites of the Agencies noted above to access their lists).
        <p>
            <b style="margin-left:40px"><input type="checkbox" @ViewBag.Checkbox45 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox46 /> NO </b>
            <b style="margin-left:20px">If NO, comment required: <input type="text" value="@(ViewBag.Input11 ?? String.Empty)" style="width:450px; height:20px" /></b>
        </p>

    </div>


    <div>
        <p><b>13. <i>FEDERAL AVIATION ADMINISTRATION (FAA) ANTI-DRUG AND ALCOHOL MISUSE PREVENTION PROGRAMS</i></b></p>

        <p>
            Is your firm an FAA approved Repair Station?  (14 CFR 145)
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox47 /> YES </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox48 /> NO </b>
        </p>

        <p>
            <b style="margin-left:20px"><i>If YES</i></b>, Federal Registration #: <input type="text" style="width:450px; height:20px" value="@(ViewBag.Input12 ?? String.Empty)" />
        </p>

        <p style="margin-left:40px">
            Do you have an FAA approved Anti-Drug Program?
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox49 /> Yes </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox50 /> No </b>
        </p>
        <p style="margin-left:60px"><b>If YES</b>, Anti-Drug Program Plan #:  <input type="text" style="width:450px; height:20px" value="@(ViewBag.Input13 ?? String.Empty)" /></p>

        <p style="margin-left:40px">
            Do you have an approved Alcohol Misuse Prevention Program?
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox51 /> Yes </b>
            <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox52 /> No </b>
        </p>
        <p style="margin-left:60px"><b>If YES</b>, Alcohol Misuse Prevention Program Plan #: <input type="text" style="width:450px; height:20px" value="@(ViewBag.Input14 ?? String.Empty)" /></p>

    </div>

    <div>
