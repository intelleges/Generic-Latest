        <td>
            <p style="font-size:16px;">
               @Html.Raw(@ViewBag.SAVE_FOR_LATER_TEXT_NOTICE)
            </p>
        </td>
    </tr>
    <tr>
        <td>
            <div style="float:right">
                <input type="button" name="btnCancel" id="btnCancel" value="@ViewBag.SAVE_FOR_LATER_TEXT_PAGE_NEXT_TEXT" style="border-width: 0px;" />
                <input type="button" name="btnExit" id="btnExit" value="@ViewBag.SAVE_FOR_LATER_TEXT_PAGE_PREVIOUS_TEXT" style="border-width: 0px;" />
            </div>
        </td>
    </tr>
</table>
<script>
    $(document).ready(function () {
        $(document).on("click", "#btnExit", null, function () {
            window.history.back();
        });
        $(document).on("click", "#btnCancelbtnExit", null, function () {
            if ("@ViewBag.ENTERPRISE_URL") {
                window.location.href = "http://@ViewBag.ENTERPRISE_URL";
                //window.location.host = ;
                //window.location.port = 80;
               // window.location.pathname = "";
            } else {
                window.location.href ="https://www.intelleges.com/"
            }
        });
    });
</script>
