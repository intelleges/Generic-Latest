@System.Web.Optimization.Styles.Render("~/bundles/alertifyCss")
@System.Web.Optimization.Styles.Render("~/bundles/registrationCss")
@System.Web.Optimization.Scripts.Render("~/bundles/jquery")
<script>
    $(document).ready(function () {
        var message = '@ViewBag.message';
        switch (message) {
            case "expired":
                alertify.alert("The access code you entered is no longer valid. For more information, please contact the administrator listed in the email invitation/reminder you received. Thank you.");
                break;
            case "wrongstatus":
                var satusCode = '@ViewBag.pptqaccesscode';
                alertify.alert("Access Code \"" + satusCode.toUpperCase() + "\" is not currently active. Please contact the system administrator in the email you received for further information.\n Thank you.");
                break;
            default: break;
        }
       
    });
</script>

