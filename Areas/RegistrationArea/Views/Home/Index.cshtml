@section BottomFooter{
    <div class="supplyfot">
        <table width="60%" border="0" align="center" cellpadding="0" cellspacing="0">
            <tr>
                <td height="60">&nbsp;
                </td>
            </tr>
        </table>
    </div>
}

@section Top{
    <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
            <td height="77" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td width="76%" align="right" valign="top" class="supplytitleblueone">
                            <span id="ctl00_lblSurvey">
                                @{
                                    
                                    @Html.Raw(ViewBag.CMS_TITLE);
                                   

                                    
                                    <span style="font-size: 12px">
                                        @Html.Raw(ViewBag.CMS_SUBTITLE);
                                    </span>
                                    
                                
                                }

                            </span>
                        </td>
                        <td width="13%" height="106" valign="bottom">
                            <img src="~/Contents/images/tickmark.gif" alt="" width="95" height="89" class="surveyban" />
                        </td>
                    </tr>
                </table>
            </td>

        </tr>
        <tr>
            <td height="119" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td valign="top">
                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyleft">&nbsp;
                                    </td>
                                </tr>
                                <tr>
                                    <!-- <td class="supplyleft">
                                                    Honeywell Site Security Survey is designed to capture information about your site’s
                                                    practices pertaining to safeguarding the supply chain.
                                                </td>-->
                                    <td class="supplyleft">

                                        <div id="ctl00_RegistrationPageText">
                                           
                                            
                                                @Html.Raw(ViewBag.CMS_PANEL_ONE);
                                            

                                        </div>


                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td valign="top">

                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyright">&nbsp;
                                    </td>
                                </tr>
                                <tr>
                                    <td class="supplyright">

                                        
                                            
                                                @Html.Raw(ViewBag.CMS_PANEL_TWO);
                                            

                                        <!--<span style="color: #0096c9;">Instructions:</span> Enter your access code (found in your invitation email) below to complete Honeywell’s Site Security Survey.-->
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
}
<table width="416" height="281" border="0" align="center" cellpadding="0" cellspacing="0">
