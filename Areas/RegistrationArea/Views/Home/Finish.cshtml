@inherits System.Web.Mvc.WebViewPage<Generic.eSignature>
@using System.Web.Mvc.Html
@{
    Layout = Generic.Helpers.LayoutHelper.GetRegistrationLayout();    
    //ViewBag.Title = "CompanyInfomation";
}
@section Bottom{
    <div class="">
        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="float: left;">
            <tr>
                <td width="20%" align="right">
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td valign="top">
                                <ul id="qm0" class="qmmc" style="width: 775px;">
                                    <li><a class="qmparent" href=""></a></li>
                                    <li><a class="qmparent" href="mailto:@ViewBag.QUESTIONNAIRE_CONTACT_US_EMAIL_LINK" id="contactUS">@ViewBag.CONTACT_US_EMAIL</a></li>
                                    <li><a class="qmparent" href="~/Registration/Home/PDFConfirmation" target="_blank">@ViewBag.QUESTIONNAIRE_PDF</a></li>  
                                    @*<li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_PDF" target="_blank">@ViewBag.QUESTIONNAIRE_PDF</a></li>*@
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_FAQ" target="_blank">@ViewBag.QUESTIONNAIRE_FAQ</a> </li>
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_DOC_OTHER" target="_blank">@ViewBag.QUESTIONNAIRE_DOC_OTHER</a> </li>
                                    <li><a class="qmparent" href="@ViewBag.QUESTIONNAIRE_VIDEO_LINK" target="_blank">@ViewBag.QUESTIONNAIRE_VIDEO</a> </li>
                                    <li><a class="qmparent" href="~/Registration/Home/FileDownloadCMS?CMSName=QUESTIONNAIRE_DOC_OTHER_2" target="_blank">@ViewBag.QUESTIONNAIRE_DOC_OTHER_2</a> </li>
                                    <li class="qmclear">&nbsp;</li>
                                </ul>
                            </td>
                            <td align="right" valign="top"></td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>
}

@section Top{
    <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
            <td height="77" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td width="76%" align="center" valign="top" class="supplytitleblueone">
                            <span id="ctl00_lblSurvey">   
                                @{
                                    @Html.Raw(ViewBag.CMS_PAGE_TITLE)
                                    <span style="font-size: 12px">
                                        @Html.Raw(ViewBag.CMS_PAGE_SUBTITLE)
                                    </span>
                                }
                            </span>
                        </td>
                        <td width="13%" height="106" valign="bottom">
                            <img src="~/Contents/images/tickmark.gif" alt="" width="95" height="89" class="surveyban" />
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td height="119" valign="top">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td valign="top">
                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyleft">&nbsp;</td>
                                </tr>
                                <tr>
                                    <td class="supplyleft">
                                        @Html.Raw(ViewBag.CMS_PAGE_PANEL_ONE)
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td valign="top">
                            <table width="400" border="0" align="center" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="supplyright">&nbsp;</td>
                                </tr>
                                <tr>
                                    <td class="supplyright">
                                        @Html.Raw(ViewBag.CMS_PAGE_PANEL_TWO)
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
}
<table width="89%" height="78" border="0" align="center" cellpadding="0" cellspacing="0">
    <tr>
        <td>&nbsp;</td>
    </tr>
    <tr>
        <td>
            <div class="supplycon">
                <div class="commonh"></div>
                    <div class="redheader" align="center">  <table width="100%"><tbody><tr><td align="center">
                        @*<span id="lblCompanyName" style="font-size:xx-large">            
                                                                                                                  @if(!((bool)ViewBag.isCompletedSurvey)){
                                                                                                                  @ViewBag.CONFIRMATION_PAGE_HEADLINE
                                                                                                                  }else{
                                                                                                                  @ViewBag.WARNING
                                                                                                                  }
                                                                                                              </span>*@
                        <a id="IntLogo" href="#"> 
                            @{
                                if (@ViewBag.logoSrc != null)
                                {    
                                    string imageBase64 = Convert.ToBase64String(@ViewBag.logoSrc);
                                    string imageSrc = string.Format("data:image/gif;base64,{0}", imageBase64);
                                    <img src="@imageSrc"  style="max-height: 50px;" />
                                }
                            }
                        </a>
                        </td>
                        </tr><tr>
                        <td align="center">
                        </td></tr>
                        </tbody></table>

                    </div>
                    <div align="center">
                        <table style="padding-top: 25px; padding-left: 50px; padding-right: 50px; padding-bottom: 25px;" width="100%">
                            <tbody>
                                <tr height="25" valign="top">
                                    <td colspan="2" style="font-size: 18px; font-weight: bold;" align="center">
                                        <div id="lblThankYou">

                                            @if(!((bool)ViewBag.isCompletedSurvey))
                                            {
                                               @Html.Raw(ViewBag.CONFIRMATION_PAGE_SIGNOFF_STATEMENT)
                                            } 
                                            else
                                            {
                                                @Html.Raw(ViewBag.CONFIRMATION_PAGE_SIGNOFF_INCOMPLETE_STATEMENT)
                                            }
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2">&nbsp;</td>
                                </tr>
                                <tr>
                                    <td colspan="2" style="font-size: 16px; padding-bottom: 75px;" align="center" width="30%">
                                        <span id="lblPrintAnswer">
                                            @*@if (ViewBag.CMS_PAGE_PREVIOUS_LINK == null) --> Commented by Jitendra for testing
    {
         <a href='@Url.Action("Finish", "/Home/PrintPDF/", new {accesscode = ViewBag.ACCESS_CODE}, Request.Url.Scheme)'>@ViewBag.CMS_PAGE_PREVIOUS_TEXT</a>*@
                                                @*<a href="checkToPrintPDF('@ViewBag.ACCESS_CODE')" target="_blank">@ViewBag.CMS_PAGE_PREVIOUS_TEXT</a>*@
                                            @*} 
                                            else
                                            {*@
                                                <a href='@Url.Action("Finish", "/Home/PrintCustomizedPDFConfirmation/", new {accesscode = ViewBag.ACCESS_CODE}, Request.Url.Scheme)'>@ViewBag.CMS_PAGE_PREVIOUS_TEXT</a>
                                            @*}*@
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-size: 12px;" align="left" width="70%"></td>
                                    <td style="font-size: 12px;" align="left" width="30%">  
                                        @{
                                            string link = @ViewBag.CMS_PAGE_NEXT_LINK;
                                        }
                                        <script>
                                            function redirect(url) {
                                                window.location.href = "http://" + url;
                                                return false;
                                            };

                                            function checkToPrintPDF(accesscode) {
                                                window.location.href = "@Url.Content("~/Registration/Home/PrintPDF/?accesscode=")" + accesscode;
                                            };

                                            function PrintCustomizedPDFConfirmation(accesscode) {
                                                window.location.href = "@Url.Content("~/Registration/Home/PrintCustomizedPDFConfirmation/?accesscode=")" + accesscode;
                                            };
                                        </script>
        
                                        <input type="button" name="btnNext" id="btnNext"
	                                       value="@ViewBag.CMS_PAGE_NEXT_TEXT"
	                                       onclick="redirect('@link    ')"
	                                       style="border-width:0;" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </td>
        </tr>
    <tr>
        <td>&nbsp;</td>
    </tr>
    <tr>
        <td></td>
    </tr>
</table>
@if(TempData["IncorrectZipCode"]!=null)
{
    <script>
        $(document).ready(function () {
            alertify.alert("@TempData["IncorrectZipCode"].ToString()");
        });
    </script>
}