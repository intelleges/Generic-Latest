@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc.Html
@using System.Web.Mvc
@using Generic.Helpers

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title></title>
    <style>
        body {
            font-family: "Calibri, serif";
        }

        h1 {
            font-size: 25px;
        }

        h2 {
            font-size: 18px;
        }

        h3 {
            font-size: 17px;
        }

        h4 {
            font-size: 16px;
        }

        p {
            font-size: 16px;
        }

        .ml25 {
            margin-left: 25px;
        }

        .ml50 {
            margin-left: 50px;
        }

        .ml75 {
            margin-left: 75px;
        }

        .text-center {
            text-align: center;
        }

        ul.hr li {
            display: inline;
            margin-right: 5px;
            padding: 3px;
        }

        li {
            list-style-type: none;
        }

        .mt20 {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <FONT FACE="Calibri, serif">
        <table width="100%">
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(ViewBag.logoSrc))
                    {
                        <img src="@ViewBag.logoSrc" runat="server" style="height:50px; width:300px; border:none" />
                    }
                </td>
            </tr>
        </table>
        <div>
            <ul class="ml25">
                <li><i><input type="checkbox" @ViewBag.Checkbox46269_70860 /> Commercial Unique</i></li>
                <li><i><input type="checkbox" @ViewBag.Checkbox46269_70859 /> Commercial (FAR Part 12)</i></li>
                <li><i><input type="checkbox" @ViewBag.Checkbox46268_Yes /> Non-Commercial (FAR Part 15)</i></li>
            </ul>
        </div>
        <table width="100%" style="margin-top:20px;">
            <tr>
                <td style="color: #081835" class="text-center">
                    <h1>SUPPLIER CERTIFICATION and ASSESSMENT<br />CALENDAR YEAR 2019</h1>
                </td>
            </tr>
            <tr>
                <td class="text-center">
                    <p>All current and prospective Honeywell suppliers (Suppliers) are required to complete the Annual Certification and Assessment each calendar year.  Suppliers are required to certify their compliance with the following requirements, including clauses from the Federal Acquisition Regulation and Defense Supplement, which can be found at https://www.acquisition.gov/.</p>
                </td>
            </tr>
        </table>
        @foreach (var item in ViewBag.partnerHeader)
        {
            <table width="100%" cellpadding="0" cellspacing="0" border="1">
                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        ONESOURCE SUPPLIER ID# (DUNS#):  @ViewBag.partner.dunsNumber
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        HONEYWELL SAP/LOCAL SUPPLIER #:  @ViewBag.partner.federalID
                    </td>
                </tr>
                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                        SUPPLIER NAME: @ViewBag.partner.name
                    </td>
                </tr>
                <tr>
                    <td>
                        <table width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                    SUPPLIER ADDRESS (Manufacturing address - no PO Box): @ViewBag.partner.address1
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; word-wrap:break-word; padding-left: 5px; padding-bottom:5px;">
                                    @ViewBag.partner.address2
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    CITY/TOWN: @ViewBag.partner.city
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    STATE/PROVINCE/REGION: @ViewBag.state
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    ZIP CODE:
                                    @if (ViewBag.partner.zipcode != null)
                                    {
                                        @MvcHtmlString.Create(ViewBag.partner.zipcode.ToString().Length > 5 ? ViewBag.partner.zipcode.ToString().Substring(0, 5) + "-" + ViewBag.partner.zipcode.ToString().Substring(5, ViewBag.partner.zipcode.ToString().Length - 5) : ViewBag.partner.zipcode);
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                                    COUNTRY: @ViewBag.country
                                </td>
                            </tr>
                        </table>
                    </td>
                    <td>
                        <table width="100%" cellpadding="0" cellspacing="0" style="height:150px; border-collapse:collapse" border="1">
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                    CONTACT NAME: @ViewBag.partner.firstName @ViewBag.partner.lastName
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                    CONTACT TELEPHONE#: @ViewBag.partner.phone
                                </td>
                                <td width="30%" style="font-size: 11px; padding-left: 5px; padding-bottom:5px; width:inherit;">
                                    CONTACT FAX#: @ViewBag.partner.fax
                                </td>
                            </tr>
                            <tr>
                                <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;" colspan="2">
                                    CONTACT EMAIL ADDRESS: @ViewBag.partner.email
                                    <br />
                                    <br />
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        }

        <br />
        <div>
            <h2><b>1.&nbsp;<i><u>Honeywell Code of Business Conduct</u></i></b></h2>
            <p class="ml25">It is the policy of Honeywell to take reasonable steps to ensure that its suppliers and potential suppliers have the highest level of business ethics consistent with, or similar to Honeywell's requirements for integrity and compliance and requires its suppliers to certify to the same. </p>
            <h4 class="ml50"><b><i>Supplier acknowledges</i></b></h4>
            <p class="ml50">
                It has implemented the systems, procedures and processes consistent with, or similar to, the Honeywell Inc and Honeywell Supplier Code of Business Conduct (http://honeywell.com/About/Pages/code-of-business-conduct.aspx)
                <b><i><u>or will adhere to their own Code of Business Conduct, which supports the spirit of Honeywell's requirements for integrity and compliance.</u></i></b>
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox46240_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46240_No /> No </b></li>
                <li><b>If NO, comment required:</b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; @(ViewBag.Checkbox46240_Comment ?? String.Empty)</li>
            </ul>
        </div>
        <div>
            <h2><b>2.&nbsp;<i><u>Overall Supplier Capabilities</u></i></b></h2>
            <p class="ml25">Supplier has adequate financial resources, technical equipment, facilities and the organizational experience, skills and controls available or has the ability to obtain them, as required, to perform contracts as awarded.</p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox46241_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46241_No /> No </b></li>
                <li><b>If NO, comment required:</b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; @(ViewBag.Checkbox46241_Comment ?? String.Empty)</li>
            </ul>
        </div>
        <div>
            <h2><b>3.&nbsp;<i><u>North American Industrial Classification System (NAICS) Code</u></i></b></h2>
            <p class="ml25">If Supplier's facility is located within the United States, Canada, or Mexico, please provide your primary NAICS Code, that best represents the product/service your company supplies to Honeywell Aerospace.  NAICS Code can be found at http://www.census.gov/eos/www/naics/.</p>
            <ul class="ml75 hr">
                <li><b>Primary NAICS Code: @ViewBag.Input46251</b> (Must be 6-digits)</li>
            </ul>
            <p class="ml25">
                Do you have additional NAICS Codes you would like to list?
            </p>
            <ul class="ml75 hr">
                <li><b>Secondary NAICS Code: @ViewBag.Input46250 </b> (Must be 6-digits)</li>
            </ul>

        </div>
        <div>
            <h2><b>4.&nbsp;<i><u>Business Size and Type Classification - Non-US </u></i></b></h2>
            <p class="ml25">
                Supplier represents it is a
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox46254_Yes /> Canadian business </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46255_Yes /> Non-US Small business (under 500 employees) </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46256_Yes /> Non-US Large business (500+ employees) </b></li>
            </ul>
        </div>
        <div>
            <h2><b>5.&nbsp;<i><u>Business Size and Type Classification - US</u></i></b></h2>
            <p class="ml25">
                Supplier represents it is a<b> <i><u style="color:blue">(Check ALL that apply)</u></i></b>
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.CheckboxSmall /> Small Business </b></li>
                <li>
                    <ul>
                        <li><b><input type="checkbox" @ViewBag.Checkbox3 />Disadvantaged/Minority Owned (Dis/Min)</b></li>
                        <li><b><input type="checkbox" @ViewBag.Checkbox4 />Woman-Owned (Wom)</b></li>
                        <li><b><input type="checkbox" @ViewBag.Checkbox5 />Veteran-Owned (Vet)</b></li>
                        <li><b><input type="checkbox" @ViewBag.Checkbox6 />Service Disabled Veteran-Owned (SD)</b></li>
                        <li><b><input type="checkbox" @ViewBag.Checkbox7 />HUBZone Business** (HZ)</b></li>
                        <li>
                            <p style="color:red;">
                                <b>
                                    <i>
                                        ** Please attach a copy of your company's SBA HUBZone Certification
                                        Letter. You may ONLY certify as a HUBZone supplier if your company is listed on
                                        the &quot;Qualified HUBZone Small Business Concerns List&quot; maintained by the Small
                                        Business Administration.
                                    </i>
                                </b>
                            </p>
                        </li>
                    </ul>
                </li>
                <li><b><input type="checkbox" @ViewBag.CheckboxLarge /> Large Business </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox8 /> Historically Black College or University</b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox9 /> Minority Institution</b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox10 /> University or College</b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox11 /> Non-Profit Organization</b></li>
                <li><b class="ml25"><input type="checkbox" @ViewBag.Checkbox11_comment />With Disabled Persons</b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox12 /> Alaska Native Corps. &amp; Indian Tribes that have not been certified by the SBA as a Small Disadvantaged Business (ANC)</b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox13 /> Alaska Native Corps. &amp; Indian Tribes that are not Small Businesses (Large, ANC)</b></li>
                <li>
                    <b>
                        <input type="checkbox" @ViewBag.Checkbox14 /> Government Agency / Entity: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Explain:
                        <input type="text" style="width:450px; height:20px" value="@(ViewBag.Input0 ?? String.Empty)" />
                    </b>
                </li>
            </ul>
            <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
                <tr>
                    <td style="text-align:center; width:150px" valign="top">
                        <p style="text-align:center"><b>NOTICE</b></p>
                        <p style="text-align:center"><b>OF</b></p>
                        <p style="text-align:center"><b>PENALTY</b></p>
                    </td>
                    <td valign="top">
                        <p>
                            Supplier understands, under 15 U.S.C. 645(d), any person who misrepresents a firm's status as a small business concern, a qualified HUBZone small business concern, a small business concern owned and controlled by socially and economically disadvantaged individuals, or a small business concern owned and controlled by women in order to obtain for oneself or another any: (a) prime contract to be awarded pursuant to Section 638, 644 or 657a of this title; (b) subcontract to be awarded pursuant to Section 637(a)of this title; (c) subcontract that is to be included as part or all of a goal contained in a subcontracting plan required pursuant to section 637(d) of this title; or (d) prime or subcontract to be awarded as a result, or in furtherance, of any other provision of Federal law that specifically references Section 637(d) of this title for a definition of program eligibility, shall be:  (a)punished by a fine of not more than $500,000 or by imprisonment for not more than 10 years, or both; (b) subject to the administrative remedies prescribed by the Program Fraud Civil Remedies Act of 1986 (31 U.S.C. 3801-3812); (c) subject to suspension and debarment as specified in subpart 9.4 of title 48, Code of Federal Regulations (or any successor regulation); and (d) ineligible for participation in any program or activity conducted under the authority of this chapter or the Small Business Investment Act of 1958 (15 U.S.C. 661 et seq) for a period not to exceed 3 years.
                        </p>
                    </td>
                </tr>
                <tr>
                    <td></td>
                    <td>
                        <b><input type="checkbox" @ViewBag.Checkbox46258_Yes /> Yes </b>
                        <b style="margin-left:20px"><input type="checkbox" @ViewBag.Checkbox46258_No /> No </b>
                        <b style="margin-left:20px">If NO, comment required:</b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; @(ViewBag.Input1 ?? String.Empty)
                    </td>
                </tr>
            </table>

            <p class="ml25">
                <b>
                    <i><u>MINORITY OWNERSHIP: Only</u> if supplier has represented itself above as a Small Disadvantaged Business (SDB) or Women-Owned Small Disadvantaged Business (WOSDB), please check the appropriate category of ownership:</i>
                </b>
            </p>
            <ul class="ml75">
                <li><input type="checkbox" @ViewBag.Checkbox20 /> Black American</li>
                <li><input type="checkbox" @ViewBag.Checkbox21 /> Hispanic American</li>
                <li><input type="checkbox" @ViewBag.Checkbox22 /> Native American (American Indians, Eskimos, Aleuts, or Native Hawaiians)</li>
                <li><input type="checkbox" @ViewBag.Checkbox23 />Asian-Pacific American (persons with origins from Burma, Thailand, Malaysia, Indonesia, Singapore, Brunei, Japan, China, Taiwan, Laos, Cambodia (Kampuchea), Vietnam, Korea, The Philippines, Republic of Palau, Republic of the Marshall Islands, Federated States of Micronesia, the Commonwealth of the Northern Mariana Islands, Guam, Samoa, Macao, Hong Kong, Fiji, Tonga, Kiribati, Tuvalu or Nauru)</li>
                <li>
                    <input type="checkbox" @ViewBag.Checkbox24 />
                    Subcontinent Asian (Asian-Indian) American (persons with origins from India, Pakistan, Bangladesh, Sri Lanka, Bhutan, the Maldives Islands, or Nepal)
                </li>
                <li>
                    <input type="checkbox" @ViewBag.Checkbox25 /> Individual/concern, other than one of the preceding. Explain: @ViewBag.Input2
                </li>
            </ul>
        </div>
        <div>
            <h2>
                <b>
                    6.&nbsp;<i>
                        <u>
                            52.203-13, Contractor Code of Business Ethics and Conduct
                        </u>  (Oct 2015)
                    </i>
                </b>
            </h2>
            <p class="ml25">
                Supplier is currently compliant with 48 CFR 52.203-13 or will be compliant if applicable to a subsequently awarded purchase order or contract.
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox46321_70924 /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46321_70925 /> No </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46321_70926 /> N/A </b>- Supplier does not have a PO/Contract from Honeywell with a value in excess of $5.5 million and a performance period of more than 120 days </li>
                <li class="mt20"><b>If No, explanation required: </b>@ViewBag.Checkbox46321_Comment</li>
            </ul>
        </div>
        <div>
            <h2>
                <b>
                    7.&nbsp;<i>
                        <u>
                            52.203-19, Prohibition on Requiring Certain Internal Confidentiality Agreements or Statements
                        </u>  (Jan 2017)
                    </i>
                </b>
            </h2>
            <p class="ml25">
                Supplier is currently compliant with 48 CFR 52.203-19 or will be compliant if applicable to a subsequently awarded purchase order or contract.
            </p>
            <ul class="ml75 hr">
                <li><b><input type="checkbox" @ViewBag.Checkbox46322_Yes /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46322_No /> No </b></li>
                <li><b>If No, comment required: </b>@ViewBag.Checkbox46322_Comment</li>
            </ul>
        </div>
        <div>
            <h2>
                <b>
                    8.&nbsp;<i>
                        <u>
                            52.204-10(d)(3), Executive Compensation Reporting
                        </u>  (Oct 2018)
                    </i>
                </b>
            </h2>
            <p class="ml25">
                Supplier certifies it
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox46323_70927 /> HAS </b> derived 80% or more and $25,000,000 or more of its annual gross revenues from Federal contracts (and subcontracts), loans, grants (and sub-grants), cooperative agreements and other forms of Federal financial assistance in the preceding fiscal year</li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46323_70928 /> NOT HAS </b> derived 80% or more and $25,000,000 or more of its annual gross revenues from Federal contracts (and subcontracts), loans, grants (and sub-grants), cooperative agreements and other forms of Federal financial assistance in the preceding fiscal year </li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46323_70929 /> N/A </b> - Work will be performed outside the US by employees not recruited within the US, District of Columbia, Puerto Rico, Northern Mariana Islands, American Samoa, Guam, US Virgin Islands and Wake Island</li>
            </ul>
            <p class="ml25">
                Executive Compensation
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox46324_70930 /> IS </b> available to the public through periodic reports filed under Section 13(a) or 15(d) of the Securities Exchange Act of 1934 (15 U.S.C. 78m(a), 78o(d)) or under Section 6104 of the Internal Revenue Code of 1986</li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46324_70931 /> Is NOT </b> available to the public through periodic reports filed under Section 13(a) or 15(d) of the Securities Exchange Act of 1934 (15 U.S.C. 78m(a), 78o(d)) or under Section 6104 of the Internal Revenue Code of 1986 </li>
            </ul>
            <p class="ml25">
                <b>Total Compensation</b> (as defined in FAR 52.204-10(a)):  If supplier <b>HAS</b> derived 80% or more and $25,000,000 or more of its annual gross revenues from Federal awards and other forms of Federal financial assistance in the preceding fiscal year <b>AND</b> its Executive Compensation is <b>NOT</b> available to the public, Honeywell is required to report the earnings of the five (5) most highly compensated executives, during the preceding fiscal year, to the Government:
            </p>
            <table width="100%" cellpadding="0" cellspacing="0" border="1">
                <tr>
                    <td style="font-size: 15px; padding-left: 5px; padding-bottom:5px;">
                        Name
                    </td>
                    <td style="font-size: 15px; padding-left: 5px; padding-bottom:5px;">
                        Title
                    </td>
                    <td style="font-size: 15px; padding-left: 5px; padding-bottom:5px;">
                        Total Compensation
                    </td>
                </tr>
                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input15 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input16 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input17 ?? String.Empty)
                    </td>
                </tr>

                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input18 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input19 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input20 ?? String.Empty)
                    </td>
                </tr>

                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input21 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input22 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input23 ?? String.Empty)
                    </td>
                </tr>

                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input24 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input25 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input26 ?? String.Empty)
                    </td>
                </tr>

                <tr style="height:40px">
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input27 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input28 ?? String.Empty)
                    </td>
                    <td style="font-size: 11px; padding-left: 5px; padding-bottom:5px;">
                        @Html.Raw(ViewBag.Input29 ?? String.Empty)
                    </td>
                </tr>
            </table>

            <p>
                Please provide explanation for not listing compensation for all top 5 executives:<br />
                @Html.Raw(ViewBag.Executives)
            </p>
        </div>
        <div>
            <h2>
                <b>
                    9.&nbsp;<i>
                        <u>
                            52.204-10(d)(2), First-Tier Subcontract Awards Reporting
                        </u>  (Oct 2018)
                    </i>
                </b>
            </h2>
            <p class="ml25">
                Did supplier in the previous tax year have a <u>gross</u> income, from <b><u>all</u></b> sources, over $300,000?
            </p>
            <ul class="ml75">
                <li><b><input type="checkbox" @ViewBag.Checkbox46344_70932 /> Yes </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46344_70933 /> No </b></li>
                <li><b><input type="checkbox" @ViewBag.Checkbox46344_70934 /> N/A </b>- Awarded subcontract(s) did not flow down FAR 52.204-10 </li>
            </ul>
            <p class="ml25">
                <b><i>NOTE:</i></b>  If <b>Yes</b>, Honeywell is required to report to the US Government any <u>subcontract award(s) issued to supplier</u>, valued at $30,000 or more, that peg to prime contracts containing FAR 52.204-10.  Information pertaining to the subcontract award(s), along with the following information required by FAR 52.204-10(d)(2), will be made public.
            </p>
            <p class="ml25">To comply with FAR 52.204-10(d)(2), please provide the place of performance address if different than this Certification.  Supplier certifies the physical place of performance is:</p>
            <ul class="ml75">
                <li>Supplier Name: @Html.Raw(ViewBag.Input46346??"")</li>
                <li>Street Address: @Html.Raw(ViewBag.Input46347 ?? "")</li>
                <li>City: @Html.Raw(ViewBag.Input46348 ?? "") &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; State/Province: @Html.Raw(ViewBag.Input46349 ?? "") &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Country: @Html.Raw(ViewBag.Input46350 ?? "") &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Postal Code: @Html.Raw(ViewBag.Input46351??"")</li>
                <li>Congressional District:  @Html.Raw(ViewBag.Input46351 ?? "")</li>
            </ul>
        </div>

        <div>
            <h2>
                <b>
                    10.&nbsp;<i>
                        <u>
                            52.204-21, Basic Safeguarding of Covered Contractor Information Systems (Jun 2016), Other Than Subcontracts for Commercially Available Off-The-Shelf (COTS) Items
                        </u>  (Jun 2016)
