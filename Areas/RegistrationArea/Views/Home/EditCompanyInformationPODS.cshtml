@inherits System.Web.Mvc.WebViewPage<Generic.partner>
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Telerik.Web.Mvc.UI;
@using Telerik.Web.Mvc.UI.Html;
@using Generic.Areas.RegistrationArea.Models
@using Generic;
@using System.Web.Optimization;
@{
	Layout = Generic.Helpers.LayoutHelper.GetNewRegistrationLayout();
	//Layout = Generic.Helpers.LayoutHelper.GetRegistrationLayout();
	//Layout = "~/Views/Shared/_NewRegistrationLayout.cshtml";
	ViewBag.Title = "Edit Company Infomation";
	var formData = new ViewBagModel();
	if (ViewBag.FormData != null)
	{
		formData = ViewBag.FormData as ViewBagModel;
	}
}

@Styles.Render("~/bundles/registrationCss")
@Scripts.Render("~/bundles/jquery")

@*@section Top{
		@Html.Partial("_TopSection");
	}


	<table class="tablesign2" height="78" border="0" align="center" cellpadding="0" cellspacing="0">
		<tr>
			<td>
				&nbsp;
			</td>
		</tr>
		<tr>
			<td>
				@using (Html.BeginForm())
				{


					<table class="infobox" border="0" align="center" cellpadding="0" cellspacing="0">
						<tr>
							<td>
								<table class="innertable" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td height="25" colspan="2" class="infotitlebg">
											@formData.COMPANY_INFORMATION_TEXT <span class="infotitlenormal">(@formData.VERIFY_COMPANY_INFO)</span>
										</td>
									</tr>
									<tr>
										<td colspan="2" align="center">
											<p>
												<span id="ctl00_contentQuestionnaireBody_lblErrorMessage" style="color: Red;"></span>
											</p>
										</td>
									</tr>
									<tr>
										<td width="60%">
											<div id="ctl00_contentQuestionnaireBody_panelContent">

												<table border="0" style="width: 400px;">
													<tr>
														<td colspan="3" style="height: 20px;">&nbsp;</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.Company *</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@Html.EditorFor(model => model.name)
															@Html.ValidationMessageFor(model => model.name)

														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right">
															<p>
																<br />
																<b>@formData.PHYSYCAL_ADDRESS</b><br />
															</p>
														</td>
														<td colspan="2"></td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.ADDRESS_ONE *</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">


															@Html.EditorFor(model => model.address1)
															@Html.ValidationMessageFor(model => model.address1)

														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.ADDRESS_TWO</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@Html.EditorFor(model => model.address2)
															@Html.ValidationMessageFor(model => model.address2)
														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.CITY*</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@Html.EditorFor(model => model.city)
															@Html.ValidationMessageFor(model => model.city)
														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.STATE_TEXT</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@(Html.Telerik().ComboBox()
				.Name("state")
				.AutoFill((bool)ViewBag.combobox.ComboBoxAttributes.AutoFill)
				.BindTo(new SelectList((IEnumerable<state>)ViewBag.states, "id", "stateCode", (int)ViewBag.combobox.ComboBoxAttributes.SelectedIndex))
				.HtmlAttributes(new { style = string.Format("width:{0}px", ViewBag.combobox.ComboBoxAttributes.Width) })
				.Filterable(filtering =>
				{
					if ((int)ViewBag.combobox.ComboBoxAttributes.FilterMode != 0)
					{
						filtering.FilterMode(AutoCompleteFilterMode.StartsWith);
					}
				})
				.HighlightFirstMatch((bool)ViewBag.combobox.ComboBoxAttributes.HighlightFirst)
															)


															@Html.ValidationMessageFor(model => model.state)


														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.POSTAL_CODE *</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">


															@Html.EditorFor(model => model.zipcode)
															@Html.ValidationMessageFor(model => model.zipcode)
														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.PROVINCE</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@Html.EditorFor(model => model.province)
															@Html.ValidationMessageFor(model => model.province)

														</td>
													</tr>
													<tr>
														<td class="esigncont" align="right" style="width: 148px;">@formData.COUNTRY_TEXT *</td>
														<td style="width: 10px;">&nbsp;</td>
														<td style="width: 242px;">

															@(Html.Telerik().ComboBox()
				.Name("country")
				.AutoFill((bool)ViewBag.comboboxCountry.ComboBoxAttributes.AutoFill)
				.BindTo(new SelectList((IEnumerable<country>)ViewBag.countries, "id", "name", (int)ViewBag.comboboxCountry.ComboBoxAttributes.SelectedIndex))
				.HtmlAttributes(new { style = string.Format("width:{0}px", ViewBag.comboboxCountry.ComboBoxAttributes.Width) })
				.Filterable(filtering =>
				{
					if ((int)ViewBag.comboboxCountry.ComboBoxAttributes.FilterMode != 0)
					{
						filtering.FilterMode(AutoCompleteFilterMode.StartsWith);
					}
				})
				.HighlightFirstMatch((bool)ViewBag.comboboxCountry.ComboBoxAttributes.HighlightFirst)
															)
															@Html.ValidationMessageFor(model => model.country)




														</td>
													</tr>
												</table>
											</div>
										</td>
										<td width="40%" align="right" valign="bottom">
											<table width="230" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td width="103" align="right" valign="bottom">

														<input type="submit" name="btnCancel" id="btnCancel" value="@formData.CMS_PAGE_PREVIOUS_TEXT" onclick="javascript: history.go(-1); return false;" style="border-width: 0px;" />

													</td>
													<td width="112" align="right" valign="bottom">
														<input type="submit" name="btnNext" id="btnNext" value="@formData.CMS_PAGE_NEXT_TEXT" style="border-width: 0px;" />
													</td>
												</tr>
												<tr>
													<td>
														&nbsp;
													</td>
													<td>
														&nbsp;
													</td>
												</tr>

											</table>
										</td>

									</tr>
									<tr>
										<td>
											&nbsp;
										</td>
										<td>
											&nbsp;
										</td>
									</tr>
								</table>
							</td>
						</tr>
						<tr>
							<td colspan="2">
								&nbsp;
							</td>
						</tr>
					</table>

				}
			</td>
		</tr>
	</table>



	<span style="color: #8faebb;">* @formData.REQUIRED_FIELDS</span>*@

<div class="top-margin">

</div>

<section class="page-inner">
	<div class="small-container">
		@Html.Partial("_TopSection")

		@using (Html.BeginForm())
		{
			@Html.Hidden("ispods", formData.IsPODS)
			<div class="sub-box">
				<div class="shadow-box form-deault padding-none full-width">
					<div class="black-box-hd">@formData.COMPANY_INFORMATION_TEXT (@formData.VERIFY_COMPANY_INFO)</div>
					<div class="row main-content" id=" ctl00_contentquestionnairebody_panelcontent">

						<div class="form-horizontal black-box-form">
							<span id="ctl00_contentQuestionnaireBody_lblErrorMessage" style="color: Red;"></span>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.Company:<i class="fa fa-asterisk"></i> </label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.dunsNumber, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.dunsNumber)

									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.PHYSYCAL_ADDRESS:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.name, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.name)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.ADDRESS_ONE:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.address1, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.address1)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.ADDRESS_TWO:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.address2, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.address2)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.CITY:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.city, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.city)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.STATE_TEXT:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9 selectbox">
										@Html.TextBoxFor(model => model.province, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.province)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.POSTAL_CODE:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.zipcode, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.zipcode)
									</div>
								</div>
							</div>
							<div class="col-md-9">
								<div class="form-group">
									<label for="inputEmail3" class="col-sm-3 control-label">@formData.PROVINCE:<i class="fa fa-asterisk"></i></label>
									<div class="col-sm-9">
										@Html.TextBoxFor(model => model.title, new { @class = "form-control" })
										@Html.ValidationMessageFor(model => model.title)
									</div>
								</div>
							</div>

							<div class="col-md-3">
								<button type="submit" name="btnCancel" id="btnCancel" onclick="javascript: history.go(-1); return false;" class="btn btn-default pull-left save-btn">@formData.CMS_PAGE_PREVIOUS_TEXT</button>
								<button type="submit" name="btnNext" id="btnNext" class="btn btn-default pull-left save-btn">@formData.CMS_PAGE_NEXT_TEXT</button>
							</div>
						</div>



					</div>
				</div>

				<div class="sub-honeywell text-center">
					<label for="exampleInputName2"><i class="fa fa-asterisk"></i>@formData.REQUIRED_FIELDS</label>
				</div>
			</div>
		}
	</div>
</section>
