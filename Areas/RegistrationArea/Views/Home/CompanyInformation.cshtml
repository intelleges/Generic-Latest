<table width="89%" height="78" border="0" align="center" cellpadding="0" cellspacing="0">
    <tr>
        <td>&nbsp;
        </td>
    </tr>
    <tr>
        <td>
            <table class="infobox" width="665" border="0" align="center" cellpadding="0" cellspacing="0">
                <tr>
                    <td>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                            <tr> 
                                <td height="25" colspan="2" class="infotitlebg">@ViewBag.COMPANY_INFORMATION_TEXT <span class="infotitlenormal">(@ViewBag.VERIFY_COMPANY_INFO)</span>
                                </td>
                            </tr>
                            <tr>
                                <td valign="top" width="60%">
                                    <table width="400" border="0" cellpadding="0" cellspacing="0">
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        <tr>
                                            <td height="150">
                                                <table width="300" border="0" align="center" cellpadding="0" cellspacing="0">
                                                    <tr>
                                                        <td class="infobluecont">
                                                            <span class="infobluecontnormal">
                                                                <!-- show Content -->
                                                                <!-- show company name -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblCompanyName">
                                                                    <p><b>@Model.name</b><p>&nbsp;</p>
                                                                    </p>
                                                                </span>
                                                                <!-- end show company name -->
                                                                <!-- show physical address -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblAddress">@Model.address1<br />@Model.address2<br />@Model.city, @ViewBag.state @Model.zipcode<br />@ViewBag.country</p></span>
                                                                <!-- end show physical address -->
                                                                <!-- show remit address -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblRemitAddress"></span>
                                                                <!-- end show remit address -->
                                                                <!-- show federalId -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblFederalId"></span>
                                                                <!-- end show federalId -->
                                                                <!-- show dunsNumber -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblDunsNumber"></span>
                                                                <!-- end show dunsNumber -->
                                                                <!-- show naicsCode -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblNaicsCode"></span>
                                                                <!-- end show naicsCode -->
                                                                <!-- show businessDescription -->
                                                                <span id="ctl00_contentQuestionnaireBody_lblBusinessDescription"></span>
                                                                <!-- end show businessDescription -->
                                                                <!-- end show content -->
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td width="40%" align="right" valign="bottom">
                                    <table width="230" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td width="103" align="right">

                                                <input type="submit"  name="btnEdit" id="btnEdit" onclick="window.location = 'EditCompanyInformation';"  value="@ViewBag.CMS_PAGE_PREVIOUS_TEXT" style="border-width:0px;" />
                                            </td>

                                            <td width="112" align="right">

                                                <form action="@Url.Action("CorrectCompanyInformation")">
                                                    <input type="submit"  name="btnNext" id="btnNext" value="@ViewBag.CMS_PAGE_NEXT_TEXT" style="border-width:0px;" />
                                                </form>
                                            </td>
                                            <td width="15">&nbsp;
                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2">&nbsp;
                                            </td>
                                            <td>&nbsp;
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2">&nbsp;
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td>&nbsp;
        </td>
    </tr>
</table>





