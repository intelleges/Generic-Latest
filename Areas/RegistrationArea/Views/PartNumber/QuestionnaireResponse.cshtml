        var last = "NameUnlikelyToBeUsedAsAnElementName";

        var s = sender.id;

        var parts = s.split("_");

        var result = parts[parts.length - 2];

        var divname = "Div_" + result;

        for (i = 0; i < allInputs.length; i++) {
            //            animatedcollapse.addDiv('y' + divname, 'fade=1,height=50px');
