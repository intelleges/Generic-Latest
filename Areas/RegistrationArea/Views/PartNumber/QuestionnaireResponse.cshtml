@section zCodes{
    @if (ViewBag.zcodeList is List<Generic.pr_getTransactionRecordAll_Result>)
    {
        List<Generic.pr_getTransactionRecordAll_Result> list = ViewBag.zcodeList as List<Generic.pr_getTransactionRecordAll_Result>;

        @Html.Telerik().Grid(list).Name("getTransactionRecordAllGrid").Columns(columns =>
   {
       columns.Bound(o => o.id).Title("Id");
       columns.Bound(o => o.bankName).Title("Bank Name").Width(150);
       columns.Bound(o => o.bankRole).Title("Bank Role").Width(250);
       columns.Bound(o => o.country).Title("Country").Width(100);
       columns.Bound(o => o.entityName).Title("Entity Name").Width(250);
       columns.Bound(o => o.orderNumber).Title("Order Number");
       columns.Bound(o => o.orderPrice).Title("Order Price");
       columns.Bound(o => o.orderTime).Title("Order Time");
       columns.Bound(o => o.orderType).Title("Order Type");
       columns.Bound(o => o.pptq).Title("Pptq");
       columns.Bound(o => o.profit).Title("Profit");
       columns.Bound(o => o.size).Title("Size");
       columns.Bound(o => o.sortOrder).Title("Sort Order");
       columns.Bound(o => o.stopLoss).Title("Stop Loss");
       columns.Bound(o => o.swap).Title("Swap");
       columns.Bound(o => o.symbol).Title("Symbol");
       columns.Bound(o => o.takeProfit).Title("Take Profit");
       columns.Bound(o => o.tradePrice).Title("Take Price");
       columns.Bound(o => o.tradeTime).Title("Take Time");
   }).Filterable(o => o.Enabled(true)).Resizable(o => o.Columns(true));
    }
    else if (ViewBag.zcodeList is List<Generic.ZcodeGridItem>)
    {
        List<Generic.ZcodeGridItem> list = ViewBag.zcodeList as List<Generic.ZcodeGridItem>;
        @Html.Telerik().Grid(list).Name("getTransactionRecordAllGrid").Columns(columns =>
   {
       columns.Bound(o => o.PartNumber).Title("Part Number");
       columns.Bound(o => o.Site).Title("Site");
       columns.Bound(o => o.Zcode).Title("Zcode");
       columns.Bound(o => o.LIFNR).Title("LIFNR");
       columns.Bound(o => o.MATNR).Title("MATNR");
       columns.Bound(o => o.WERKS).Title("WERKS");
       columns.Bound(o => o.ZPOST).Title("ZPOST");
       columns.Bound(o => o.ZCFLAG).Title("ZCFLAG");
       columns.Bound(o => o.COMPLETED_DATE).Title("COMPLETED DATE");
   }).Filterable(o => o.Enabled(true)).Resizable(o => o.Columns(true));
    }


}
