                                animatedcollapse.hide('y' + divname);
                            }
                            else if (radios[j].value == 76) {
                                //                                document.getElementById('n' + divname).style.display = 'none';
                                //                                document.getElementById('y' + divname).style.display = 'none';
                                animatedcollapse.hide('y' + divname);
                                animatedcollapse.hide('n' + divname);
                                //                                document.getElementById('y' + divname).style.display = 'none';
