                    //                    input.focus();
                    //                    return false;
                    //            }                                   
                }
            }

        }
    }

    function showdivRadioList(sender) {
        //alert("Hello");
        var allInputs = document.getElementsByTagName("input");
        var last = "NameUnlikelyToBeUsedAsAnElementName";

        var s = sender.id;

