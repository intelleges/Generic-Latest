<script type="text/javascript">

    $("frmCreateGroup").submit(function (e) {

        if ($(this).valid()) {

            $.post('@Url.Action("~/Registration/PartNumber/QuestionnaireResponse")', $(this).serialize(), function (data) {

                $("#dynamicData").html(data);

                $.validator.unobtrusive.parse($("#dynamicData"));

            });

        }

        e.preventDefault();

    });
   
    $(document).ready(function () {

        var message = '@ViewBag.message';
        if (message !== "") {
            alertify.alert(message);//"");
        }
        
        $("#btnSaveForLater").click(function (e) {

            window.location.replace("Saveforlater");
           
        });
        

        $("#imgBtnPrevious").click(function (e) {

            window.location.replace("PreviousPartNumberUI");

        });


        $("#imgBtnNext").click(function (e) {

            window.location.replace("NextPartNumberUI");

        });
        
    });

</script>

