            $(cont).find("input").each(function () {
                var id = $(this).attr("id");
                if (document.getElementById(id).checked) {
                    var splitter = $(this).attr("id").split("_");
                    //alert(splitter);
                    var logic = splitter[(splitter.length) - 1];

                    var question_id = splitter[(splitter.length) - 3];
                    // alert(question_id);
                    if (logic == 1) {
                        //alert(""+question_id+"_R");

