@using System.Web.Optimization
@inherits System.Web.Mvc.WebViewPage<Generic.ViewModel.FreeTrialViewModel>

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <title>FreeTrial</title>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="author" content="SemiColonWeb" />
    <meta name="version" content="2.0.0" />
    <!-- Stylesheets
    ============================================= -->
    <link href="//fonts.googleapis.com/css?family=Lato:300,400,400italic,600,700|Raleway:300,400,500,600,700|Crete+Round:400italic" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/bootstrap.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/style.css?v=3" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/dark.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/font-icons.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/animate.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/magnific-popup.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/components/radio-checkbox.css" type="text/css" />
    <link rel="stylesheet" href="~/Content/login/css/responsive.css" type="text/css" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    @Styles.Render("~/bundles/alertifyCss")
    <script src="@Url.Content("~/Scripts/alertify.js")"></script>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            $("#login_submit_button").on("click", function () {
                return validate()
            });
        })
        function isEmail(email) {
            var regex = /^([a-zA-Z0-9!#$%&'*+-/=?^_`{|}~'])+\@@(([a-zA-Z0-9-])+\.)+([a-zA-Z0-9]{2,4})+$/;
            return regex.test(email);
        }
        function validate() {
            var email = $("#emailAddress").val();
            var proId = $('#productId').val();
            if (isEmail(email) && proId != 0) {
                return true;
            }
            else if (proId == 0) {
                alertify.alert("Please select product. Thank you.");
                return false;
            }
            else {
                alertify.alert("Please use a valid email. Thank you.");
                return false;
            }
        }
    </script>
</head>
<body class="stretched">
    <div id="wrapper" class="clearfix">
        <!-- Content
        ============================================= -->
        <section id="content">
            <div class="content-wrap nopadding">
                <div class="section nopadding nomargin" style="width: 100%; height: 100%; position: absolute; left: 0; top: 0; background: #444;"></div>
                <div class="section nobg full-screen nopadding nomargin">
                    <div id="login-wrapper" class="container vertical-middle divcenter clearfix">
                        <div class="panel panel-default divcenter noradius noborder login">
                            <div class="panel-body">
                                @using (Html.BeginForm("FreeTrial", "admin", FormMethod.Post, new { id = "freetrial-form", name = "freetrial-form", @class = "nobottommargin" }))
                                {
                                    @Html.AntiForgeryToken()

                                    <div class="login-logo">
                                        <a href="http://www.intelleges.com/"> <img src="~/Content/login/images/intelleges/refinedLogo.png" alt="logo"></a>
                                        <span class="tooltiptext">To find out more click <a href="https://intelleges.webflow.io">here</a></span>
                                    </div>
                                    <div class="trialdiv">
                                        <span class="trialText">Start a 15-day Free Trial</span>
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-email">First Name:</label>
                                        @Html.TextBoxFor(x => x.FirstName, new { @class = "form-control not-dark", @maxlength = "200" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-email">Last Name:</label>
                                        @Html.TextBoxFor(x => x.LastName, new { @class = "form-control not-dark", @maxlength = "200" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-email">Email:</label>
                                        @Html.TextBoxFor(x => x.emailAddress, new { @type = "email", @class = "form-control not-dark", @maxlength = "300" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-email">Phone:</label>
                                        @Html.TextBoxFor(x => x.PhoneNumber, new { @class = "form-control not-dark", @maxlength = "15", @type = "number" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-email">Company:</label>
                                        @Html.TextBoxFor(x => x.Company, new { @class = "form-control not-dark", @maxlength = "500" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-password">Select Industry:</label>
                                        @Html.DropDownListFor(x => x.industryId, Model.industries, new { @class = "form-control not-dark" })
                                    </div>
                                    <div class="form-cell">
                                        <label for="login-form-password">Area of Interest:</label>
                                        @Html.DropDownListFor(x => x.productId, Model.products, new { @class = "form-control not-dark" })
                                    </div>
                                    if (ViewBag.useReCaptcha != null && (bool)ViewBag.useReCaptcha)
                                    {
                                        <div class="g-recaptcha" data-sitekey="@System.Configuration.ConfigurationManager.AppSettings["recaptchaPublicKey"]" data-callback="recaptcha_callback"></div>
                                    }
                                    <div class="submit-container">
                                        <button id="login_submit_button" class="button button-3d nomargin fright" value="login" onclick="validate">Submit</button>
                                    </div>

                                }

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section><!-- #content end -->
    </div>
    <!-- External JavaScripts
    ============================================= -->
    <script type="text/javascript" src="~/Content/login/js/jquery.js"></script>
    <script type="text/javascript" src="~/Content/login/js/plugins.js"></script>
    <script>
    var enterpriseId = @ViewBag.EnterpriseId ;
    </script>
    <!-- Footer Scripts
    ============================================= -->
    <script type="text/javascript" src="~/Content/login/js/functions.js"></script>
    @Scripts.Render("~/Scripts/validator.js")
    <script src="@Url.Content("~/Contents/IntellegesLogin_files/contact-us.js?v=1")"></script>
</body>
</html>
