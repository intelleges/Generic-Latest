@inherits System.Web.Mvc.WebViewPage
@{
    ViewBag.Title = "Change Password";
    Layout = Generic.Helpers.LayoutHelper.GetLayout();
    
}

<div class="tw-bs">
    <div class="container">
        <h2>Change your password</h2>
  <form style="width:600px" id="changePassForm" method="post">
      <div class="form-group">
          <label for="currentPassword">Current password</label>
          <input type="password" class="form-control" id="currentPassword" name="currentPassword" placeholder="Enter current password" data-val="true" data-val-required="Required field" data-val-password="The password is invalid" data-val-password-use="true">
          <span data-valmsg-replace="true" data-valmsg-for="currentPassword" class="field-validation-valid help-inline" />
      </div>
      <div class="form-group">
          <label for="newPassword">New password</label>
          <input type="password" class="form-control" id="newPassword" placeholder="Enter new password" data-val="true" data-val-required="Required field" name="newPassword" data-val-max="50" data-val-length="The field password must be a string with a maximum length of 50 and minimum of 3" data-val-length-max="50" data-val-length-min="3">
          <span data-valmsg-replace="true" data-valmsg-for="newPassword" class="field-validation-valid help-inline" />
      </div>
      <div class="form-group">
          <label for="confirmPassword">Confirm password</label>
          <input type="password" class="form-control" id="confirmPassword" placeholder="Enter password confirmation" data-val="true" data-val-required="Required field" name="confirmPassword" data-val-passwordConfirmation="Invalid confirmation value">
           <span data-valmsg-replace="true" data-valmsg-for="confirmPassword" class="field-validation-valid help-inline" />
      </div>
      <button type="submit" class="btn btn-default" id="btnSubmit" >Submit</button>
      <script>
          jQuery(document).ready(function ($) {
              var message = '@ViewBag.message';
              if (message==="done") {
                  alertify.alert("Congratulations, you have successfully updated your Intelleges password. Please login with your new password.", function () {
                                   window.location.href = "Logout";
                               });
              }
          });
      </script>
  </form>
        
</div>
 </div>


@System.Web.Optimization.Scripts.Render("~/Scripts/bootstrap.min.js")
