@inherits System.Web.Mvc.WebViewPage<Generic.ViewModel.Dashboard1>
    @using System.Web.Mvc.Html;
    @using Generic.Helpers;
    @using Telerik.Web.Mvc.UI;

    @{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = ViewBag.enterpriseName + "Admin";
    int counter = Model.partnerType.Count() + 3;

    int groupCount = Model.groups.Count();
    int groupAdded = 0;

    decimal c = decimal.Parse(Model.groups.Count().ToString()) / 3;
    int c2 = Model.groups.Count() % 3 > 0 ? 1 : 0;
    int partnerTablesCount = int.Parse(Math.Floor(c).ToString()) + c2;

    }
    <style type="text/css">
        table.PartnerTypes {
            border-collapse: collapse;
            border: 1px solid black;
        }

        table.TestTable {
            border-collapse: collapse;
            border: 1px solid black;
            float: left;
            margin-right: 10px;
        }

        table td {
            border: 1px solid black;
            font-size: 12px;
        }

        table th {
            border: 1px solid black;
            font-size: 12px;
            text-align: right;
            padding-right: 0;
        }

        table.PartnerTypes td.AlgnRight {
            text-align: right;
            color: darkblue;
            padding-right: 0;
        }

        table.TestTable th {
            border: 1px solid black;
            font-size: 12px;
            text-align: center;
            padding-right: 0;
        }

        table.TestTable td.AlgnRight {
            text-align: right;
            color: darkblue;
            padding-right: 0;
            width: 30px;
            font-weight: bold;
        }
    </style>

    @for (int m = 0; m < partnerTablesCount; m++)
    {


    <table id="OuterTable">
        <tr>
            <td style="border-right:0">
                <table class="PartnerTypes">
                    <tr style="background-color: darkblue; color: white;">
                        <th>
                            PARTNER TYPE&nbsp;
                        </th>
                    </tr>
                    <tr>
                        <td>
                            &nbsp;
                        </td>
                    </tr>
                    @foreach (var partnerType in Model.partnerType)
                    {
                    <tr>
                        <td id="@partnerType.ID" class="AlgnRight"><span>&nbsp;&nbsp;@partnerType.Description.Trim()&nbsp;&nbsp;</span></td>
                    </tr>
                    }
                    <tr>
                        <td class="AlgnRight"><span>&nbsp;&nbsp;<strong>Total</strong>&nbsp;&nbsp;</span></td>
                    </tr>
                </table>
            </td>
            <td style="border-left:0">
                @for (int n = 0; n < 3; n++)
                {

                if (groupAdded < groupCount)
                {
                <table class="TestTable">
                    @for (int i = 1; i <= counter; i++)
                    {
                    if (i == 1)
                    {
                    <tr style="background-color:darkblue;; color: white;">
                        <th colspan="8">
                            @Model.groups[groupAdded].description

                        </th>
                    </tr>
                    }
                    else
                    {
                    if (i == 2)
                    {
                    <tr>
                        <td class="AlgnRight" title="Goal">G&nbsp;</td>
                        <td class="AlgnRight" title="UnConfirmed">U&nbsp;</td>
                        <td class="AlgnRight" title="Review">R&nbsp;</td>
                        <td class="AlgnRight" title="Confirmed">C&nbsp;</td>
                        <td class="AlgnRight" title="No Response">N/R&nbsp;</td>
                        <td class="AlgnRight" title="Response Incomplete">R/I&nbsp;</td>
                        <td class="AlgnRight" title="Response Complete">R/C&nbsp;</td>
                        <td class="AlgnRight" title="Total">T&nbsp;</td>
                    </tr>
                    }
                    else
                    {
                    <tr>
                        <td class="AlgnRight"> @Model.ptqGroups[groupAdded].goal &nbsp;</td>
                        <td class="AlgnRight">0&nbsp;</td>
                        <td class="AlgnRight">0&nbsp;</td>
                        <td class="AlgnRight">0&nbsp;</td>
                        <td class="AlgnRight" style="background-color: #E56D38">

                           

                            <a style="text-decoration:none" href="~/Admin/DashboardPartners?Status=@((int)Generic.Helpers.PartnerHelper.PartnerStatus.Invited_NoResponse)&Group=@Model.groups[groupAdded].id" target="_blank">
                             @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.statusID== (int)Generic.Helpers.PartnerHelper.PartnerStatus.Invited_NoResponse ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault()  
                            </a>
                             &nbsp;</td>
                        <td class="AlgnRight" style="background-color:#FDEB41">
                             <a style="text-decoration:none" href="~/Admin/DashboardPartners?Status=@((int)Generic.Helpers.PartnerHelper.PartnerStatus.Responded_Complete)&Group=@Model.groups[groupAdded].id" target="_blank">
                            @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.statusID== (int)Generic.Helpers.PartnerHelper.PartnerStatus.Responded_Complete ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault()
                                 </a>
                                 
                                   &nbsp;</td>
                        <td class="AlgnRight" style="background-color: #BCD637">
                            <a style="text-decoration:none" href="~/Admin/DashboardPartners?Status=@((int)Generic.Helpers.PartnerHelper.PartnerStatus.Responded_Incomplete)&Group=@Model.groups[groupAdded].id" target="_blank">
                            @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.statusID== (int)Generic.Helpers.PartnerHelper.PartnerStatus.Responded_Incomplete ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault()
                                </a>
                                &nbsp;</td>
                        <td class="AlgnRight">
@{ 
                    @Html.Raw(        @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.status=="Invited/No Response" ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault()  +
                            @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.status=="Responded/Complete" ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault()   +
                            @Model.ptqDashboard.Where(x=> x.group==@Model.groups[groupAdded].id && x.status=="Responded/Incomplete" ).Select(s=>s.total).DefaultIfEmpty(0).FirstOrDefault() )
}
&nbsp;</td>
                    </tr>
                    }
                    }
                    }






                </table>


                groupAdded++;
                }

                }
            </td>
        </tr>
    </table>


    }

