<link rel="stylesheet" type="text/css" href="http://ajax.googleapis.com/ajax/libs/jqueryui/1/themes/flick/jquery-ui.css" />
<script type="text/javascript" src="http://ajax.googleapis.com/ajax/libs/jqueryui/1/jquery-ui.min.js"></script>

<script type="text/javascript">
    function onUpload(e) {
        // Array with information about the uploaded files
        var files = e.files;

        // Check the extension of each file and abort the upload if it is not .jpg
        $.each(files, function () {
            if (this.extension != ".xlsx") {
                alert("Only .xlsx files can be uploaded")
                e.preventDefault();
                return false;
            }
        });
    }

    var timerId = null;
    function submitform1()
    {

        $.fancybox({
            'content': $('#send-email-progress').html(),
            closeBtn: false,
            closeClick: false,
            modal: true,
            type: 'html',
            minWidth: 400,
            minHeight: 100
        });

        var progressbar = $(".fancybox-inner #progressbar"),
            progressLabel = $(".fancybox-inner .progress-label");

        progressbar.progressbar({
            value: false,
            change: function () {

            },
            complete: function () {
                progressLabel.text("Complete!");
            }
        });

        //
    }

    $(document).ready(function () {


        @if (ViewBag.Accesscode!=null) {
            <text>
                alertify.set({
                    labels: {
                    ok: "Ok", cancel: "Close"
				}
        });


                alertify.confirm("Congralutions, you just loaded @ViewBag.Count CFDB records", function (e) {
				if (e) {
					// Click no
		
			} else {
			// click yes

		}
	});





            </text>
        }



		if ("@ViewBag.Message" == "1") {
			debugger;
			alertify.set({
				labels: {
					ok: "Invite Now", cancel: "Cancel"
				}
			});
			alertify.confirm("", function (e) {
				if (e) {
					// Click no
					$.ajax({
						url: "@Url.Content("~/partner/InvitePartners")",
						type: "post",
					success: function (data) {

						alertify.set({
							labels: {
								ok: "ok", cancel: "cancel"
							}
						});

						//dataClear();
						alertify.alert(data.Data.message);
						$('#alertify-ok').text('OK');
						var len = data.EventNotification.length;
						$('#btnInviteList').show();
						if (len == 0) {
							alertify.alert("Please wait, data processing");
							$('#alertify-ok').text('OK');
						} else {

							var events = "<table><tr><td>Email</td><td>Loadgroup</td><td>Accesscode</td><td>Event</td><td>Reason</td><td>Protocol Touchpoint</td><td>Date</td></tr>";
							for (i = 0; i < len; i++)
								events += "<tr><td>" + data.EventNotification[i].email + "</td><td>" + data.EventNotification[i].loadgroup + "</td><td>" + data.EventNotification[i].accesscode + "</td><td>" + data.EventNotification[i].event + "</td><td>" + data.EventNotification[i].reason + "</td><td>" + data.EventNotification[i].protocolTouchpoint + "</td><td>" + data.EventNotification[i].timestamp + "</td></tr>";


							$('#DivEventNotification').html(events);
						}

					},
					error: function (data) {

					}
				});
			} else {
			// click yes

		}
	});
	}
	if ("@ViewBag.Message" == "2") {

		alertify.alert('@ViewBag.MessageDetail');
		dataClear();
	}
	if ("@ViewBag.Message" == "error") {

		alertify.alert('@ViewBag.MessageDetail');
		dataClear();
	}
		$("#btnClear").click(function (e) {
			alertify.confirm("Are you sure?", function (result) {
				if (result) {
					$("#addPartner input[type=text], #addPartner textarea").val("");
					$("#addPartner textarea").text("");
				}
			});

		});
	});
	function submitForm() {
		alertify.alert("Saved");
	}
</script>
