<div id="buy-buy" style="display:none;">
    <div style="padding: 10px 20px;">
        <h3>Which type of Buy to Buy (Supplier to Supplier) activity is this?</h3>
        <div class="form-group">
            <div class="radio">
                <label><input type="radio" name="bbType" value="Build to Print (BTP)">Build to Print (BTP)</label>
            </div>
            <div class="radio">
                <label><input type="radio" name="bbType" value="Build to Spec (ASL)">Build to Spec (ASL)</label>
            </div>
            <div class="radio disabled">
                <label><input type="radio" name="bbType" value="Supplier Reposition">Supplier Reposition</label>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12" style="text-align: right;">
                <button type="button" class="btn btn-primary btn-sm" onclick="setBuyToBuy();">OK</button>
            </div>
        </div>
    </div>
</div>

<div id="send-email-progress" style="display:none;">
    <div style="padding: 10px 20px;">
        <div class="progress-bar progress-bar-striped active" role="progressbar"
             aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" style="width:100%">
            Uploading please wait...
        </div>
    </div>
</div>


@if (list != null)
            {
                var selectedClausesIds = selectedClauses.Select(o => o.clause).ToList();
    <div id="team" style="display:none;">
        <div style="padding: 10px 20px;">
            <h3>Select @ViewBag.PrName Team Member</h3>
            <div class="row">
                <div class="col-lg-5">
                    <div class="form-group">
                        <h4>Available names:</h4>
                        <select multiple class="form-control" id="list1">
                            @foreach (var item in list.Where(o => !unassignedByEnterprise.Select(b => b.id).ToList().Contains(o.id)))
                            {
                                <option value="@item.id">@item.firstName @item.lastName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="form-group">
                        <h4>&nbsp;</h4>
                        <h4>&nbsp;</h4>
                        <button type="button" class="btn btn-default btn-sm" onclick="selectAll();"><i class="glyphicon glyphicon-forward"></i></button>
                        <button type="button" class="btn btn-default btn-sm" onclick="selectItems();"><i class="glyphicon glyphicon-chevron-right"></i></button>

                        <button type="button" class="btn btn-default btn-sm" onclick="unselectItems();"><i class="glyphicon glyphicon-chevron-left"></i></button>
                        <button type="button" class="btn btn-default btn-sm" onclick="unselectAll();"><i class="glyphicon glyphicon-backward"></i></button>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="form-group">
                        <h4>Selected names:</h4>
                        <select multiple class="form-control" id="list2">
                            @foreach (var item in unassignedByEnterprise)
                            {
                                <option value="@item.id">@item.firstName @item.lastName</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12" style="text-align: right;">
                    <button type="button" class="btn btn-primary btn-sm" onclick="next();">Next></button>
                </div>
            </div>
        </div>
    </div>

    <div id="clause" style="display:none;">
        <div style="padding: 10px 20px;">
            <div class="row">
                <div class="col-lg-7">
                    @Html.LabelFor(o => o.partnertype, new { @class = "control-label col-sm-3" })
                    <div class="col-sm-9">
                        @Html.DropDownListFor(m => m.partnertype, (System.Web.Mvc.SelectList)ViewBag.partnertypeList, new { @class = "form-control", @data_val = "true", @data_val_required = " ", onchange = "onchangeType()" })
                        @Html.ValidationMessageFor(model => model.partnertype)
                    </div>
                </div>
                <div class="col-lg-5">
                    <label><input type="radio" name="bbChannel" @(ViewBag.ChannelValue == 1 ? "checked" : "") value="1" @ViewBag.Check onchange="onchangeType()">Channel 1 Only</label>&nbsp;&nbsp;&nbsp;
                    <label><input type="radio" name="bbChannel" @(ViewBag.ChannelValue == 2 ? "checked" : "") value="2" @ViewBag.Check onchange="onchangeType()">Channel 2 Only</label>
                    <label><input type="radio" name="bbChannel" @(ViewBag.ChannelValue == 3 ? "checked" : "") value="3" @ViewBag.Check onchange="onchangeType()">Both Channel 1 &amp; 2</label>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-5">
                    <div class="form-group">
                        <h4>Available clauses:</h4>
                        <select multiple class="form-control" id="list3">
                            @foreach (var item in allClause)
                            {
                                <option value="@item.id">@item.clause</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-lg-2">

                    <div class="form-group">
                        <h4>&nbsp;</h4>
                        <h4>&nbsp;</h4>
                        <button type="button" class="btn btn-default btn-sm" onclick="selectClausesAll();"><i class="glyphicon glyphicon-forward"></i></button>
                        <button type="button" class="btn btn-default btn-sm" onclick="selectClausesItems();"><i class="glyphicon glyphicon-chevron-right"></i></button>
                        <button type="button" class="btn btn-default btn-sm" onclick="unselectClausesItems();"><i class="glyphicon glyphicon-chevron-left"></i></button>
                        <button type="button" class="btn btn-default btn-sm" onclick="unselectClausesAll();"><i class="glyphicon glyphicon-backward"></i></button>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="form-group">
                        <h4>Selected clauses:</h4>
                        <select multiple class="form-control" id="list4">
                            @foreach (var item in selectedClauses)
                            {
                                <option value="@item.id">@item.clause</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12" style="text-align: right;">
                    <button type="button" class="btn btn-primary btn-sm" onclick="next2();">Next></button>
                </div>
            </div>
        </div>
    </div>


    <div id="clausePersonPartnertype" style="display:none;">
        <div style="padding: 10px 20px;">
            <div class="row">
                <div class="col-lg-12" id="table-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th id="at">Active Type (<span id="atType">@ViewBag.ActiveType</span>) Clauses</th>
                                <th>Send Data To</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Items != null)
                            {
                                List<Generic.pr_getClausePersonPartnertypeSortOrderByPartnertype_Result> items = ViewBag.Items as List<Generic.pr_getClausePersonPartnertypeSortOrderByPartnertype_Result>;
                                foreach (var item in items)
                                {
                                    <tr>
                                        <input type="hidden" class="id" value="@item.cfdbclause" />
                                        <td class="text">@item.clause</td>
                                        <td>
                                            <select value="" class="form-control sendDataTo">
                                                @foreach (var item1 in unassignedByEnterprise)
                                                {
                                                    if (item1.id == item.person)
                                                    {
                                                        <option value="@item1.id" selected>@item1.firstName @item1.lastName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@item1.id">@item1.firstName @item1.lastName</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            }

                        </tbody>
                    </table>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12" style="text-align: right;">
                    <button type="button" class="btn btn-default btn-sm" onclick="$.fancybox.close(); window.location = '@Url.Content("~/lce/Create")';">Skip</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="next1_new();">Next></button>
                </div>
            </div>
        </div>
    </div>

    <div id="clause-members" style="display:none;">
        <div style="padding: 10px 20px;">
            <div class="row">
