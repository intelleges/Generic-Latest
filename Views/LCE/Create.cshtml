@inherits System.Web.Mvc.WebViewPage<Generic.Models.LCEModel>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;

@{
    #region My
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "LC & E Checklist";
    #endregion

    List<Generic.pr_getPersonTeamAssignedByTouchpoint_Result> list = ViewBag.TeamAssigned as List<Generic.pr_getPersonTeamAssignedByTouchpoint_Result>;
    List<Generic.pr_getCFDBClauseAllForDisplay_Result> allClause = ViewBag.AllClause as List<Generic.pr_getCFDBClauseAllForDisplay_Result>;
    List<Generic.pr_getCFDBClauseAll_Result> selectedClauses = ViewBag.SelectedClauses as List<Generic.pr_getCFDBClauseAll_Result>;
    List<Generic.pr_getPersonTouchpointTeamUnassignedByEnterprise_Result> unassignedByEnterprise = ViewBag.UnassignedByEnterprise as List<Generic.pr_getPersonTouchpointTeamUnassignedByEnterprise_Result>;
}

<script type="text/javascript">
    function onUpload(e) {
        // Array with information about the uploaded files
        var files = e.files;

        // Check the extension of each file and abort the upload if it is not .jpg
        $.each(files, function () {
            if (this.
                extension != ".xlsx" && this.
                    extension != ".xlsm") {
                alert("Only .xlsx files can be uploaded")
                e.preventDefault();
                return false;
            }
        });
    }

    function onCompleteCfdb(e) {

        $.get('@Url.Content("~/lce/GetCountByPptqId")'+ '?pptqId=@ViewBag.Pptq', function (data) {
           alertify.confirm("Congratulations, you just loaded "+data.count+" CFDB records", function (e) {
               //For testing only
               window.location = '@Url.Content("~/lce/Create")';

