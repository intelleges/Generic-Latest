		$("#btnClear").click(function (e) {
            alertify.confirm("Are you sure?", function (result) {
                if (result) {
                    window.location = '@Url.Content("~/lce/Create")';
                }
            });

        });
    });

    function onchangePartnerType(el) {
        if ($(el).val() == 253) {
            $.fancybox({
                'content': $('#buy-buy').html(),
                closeBtn: false,
                closeClick: false,
                modal: true,
                type: 'html',
                width: 500,
                height: 220,
                minWidth: 500,
                minHeight: 220,
                maxHeight: 220
            });
        }
        else {
            $('#BuyToBuyType').val('');
        }
    }

    function setBuyToBuy()
    {
        $('#BuyToBuyType').val($('.fancybox-inner [name="bbType"]').val());
        $.fancybox.close();
    }

    function onchangeType()
    {
        partnerType = $('.fancybox-inner #partnertype').val();
        $.fancybox.showLoading();
        $.get('@Url.Content("~/lce/getClause")' + '?id=' + partnerType + '&channel=' + $('.fancybox-inner [name="bbChannel"]:checked').val(), function (data) {
            $('.fancybox-inner #list3')
                    .find('option')
                    .remove();

                $.each(data.all, function (key, value) {
                    $('.fancybox-inner #list3')
                        .append($("<option></option>")
                            .attr("value", value.id)
                            .text(value.clause));
                });


                $('.fancybox-inner #list4')
                    .find('option')
                    .remove();

                $.each(data.selected, function (key, value) {
                    $('.fancybox-inner #list4')
                        .append($("<option></option>")
                            .attr("value", value.id)
                            .text(value.clause));
                });

                $.fancybox.hideLoading();
            });
    }

    function selectItems() {
        $(".fancybox-inner #list1 option:selected").remove().appendTo('.fancybox-inner #list2');
    }

    function unselectItems() {
        $(".fancybox-inner #list2 option:selected").remove().appendTo('.fancybox-inner #list1');
    }

    function selectAll() {
        $(".fancybox-inner #list1 option").remove().appendTo('.fancybox-inner #list2');
    }

    function unselectAll() {
        $(".fancybox-inner #list2 option").remove().appendTo('.fancybox-inner #list1');
    }


    function selectClausesItems() {
        $(".fancybox-inner #list3 option:selected").remove().appendTo('.fancybox-inner #list4');
    }

    function unselectClausesItems() {
        $(".fancybox-inner #list4 option:selected").remove().appendTo('.fancybox-inner #list3');
    }

    function selectClausesAll() {
        $(".fancybox-inner #list3 option").remove().appendTo('.fancybox-inner #list4');
    }

    function unselectClausesAll() {
        $(".fancybox-inner #list4 option").remove().appendTo('.fancybox-inner #list3');
    }

    var teams = [];
    var clauses = [];
    var ac = '';
    var defs = [];

    function next()
    {
        teams = [];

        var arr = [];
        $.each($(".fancybox-inner #list2 option"), function (index, val) {
            arr.push(Number($(val).attr('value')));
            teams.push({ text: $(val).text(), id: Number($(val).attr('value')) });
        });

        $.post('@Url.Content("~/lce/addPPTQTeam")', { Id: '@ViewBag.Pptq', Ids: arr })
            .done(function (data) {

                $('#clause-members tbody').html('');

                $.each(clauses, function (index, val) {

                    var val1 = '';
                    var val2 = '';

                    for (var i = 0; i < defs.length; i++) {
                        if (defs[i].id == val.id) {
                            val1 = defs[i].defSendData;
                            val2 = defs[i].defApproval;
                        }
                    }

                    var selected1 = false;
                    var options1 = '';

                    $.each(teams, function (index, val) {
                        if (val1 == val.id) {
                            options1 += '<option selected value="' + val.id + '">' + val.text + '</option>';
                            selected1 = true;
                        }
                        else
                            options1 += '<option value="' + val.id + '">' + val.text + '</option>';
                    });

                    if (selected1 == false) options1 = '<option disabled selected value></option>' + options1;

                    var selected2 = false;
                    var options2 = '';

                    $.each(teams, function (index, val) {
                        if (val2 == val.id) {
                            options2 += '<option selected value="' + val.id + '">' + val.text + '</option>';
                            selected2 = true;
                        }
                        else
                            options2 += '<option value="' + val.id + '">' + val.text + '</option>';
                    });

                    if (selected2 == false) options2 = '<option disabled selected value></option>' + options2;


                    $('#clause-members tbody').append('<tr>' +
                        '<input type="hidden" class="id" value="' + val.id + '"/>' +
                        '<td class="text">' + val.text + '</td>' +
                        '<td><select value="" class="form-control sendDataTo">' + options1+'</select></td>'+
                        '<td><select value="" class="form-control getApprovalFrom">' + options2 +'</select></td>'+
                        '<td><input class="form-control approvalNeededBy" type="date"></td>'
                        +'</tr>');
                });

                $.fancybox({
                    'content': $('#clause-members').html(),
                    closeBtn: false,
                    closeClick: false,
                    modal: true,
                    type: 'html',
                    width: 600,
                    height: 300,
                    minWidth: 600,
                    minHeight: 300,
                    maxHeight: 400
                });
            });

    }

    function next1_new() {

          var arr = [];

        $.each($('.fancybox-inner tbody tr'), function (index, obj) {
            arr.push({
                id: $(obj).find('.id').val(),
                sendDataTo: $(obj).find('.sendDataTo').val(),
                text: $(obj).find('.text').text(),
            });
        });

        $.fancybox.showLoading();
        $.post('@Url.Content("~/lce/senddata")', { pptq: Number('@ViewBag.Pptq'), items: arr })
            .done(function (data) {

                $.fancybox.hideLoading();
                $.fancybox.close();
                alertify.set({
                    labels: {
                        ok: "Ok", cancel: "Close"
                    }
                });
               window.location = '@Url.Content("~/lce/Create")';

            });
    }

    function next3()
    {
        var arr = [];

        $.each($('.fancybox-inner tbody tr'), function (index, obj) {
            arr.push({
                id: $(obj).find('.id').val(),
                sendDataTo: $(obj).find('.sendDataTo').val(),
                text: $(obj).find('.text').text(),
                getApprovalFrom: $(obj).find('.getApprovalFrom').val(),
                approvalNeededBy: $(obj).find('.approvalNeededBy').val()
            });
        });

        $.fancybox.showLoading();
        $.post('@Url.Content("~/lce/setClauses")', { pptq: Number('@ViewBag.Pptq'), partnerType: partnerType, items: arr })
            .done(function (data) {
                $.each(data.list, function (index, obj) {

                    var val1 = '';
                    var val2 = '';
                    var options1 = '';
                    var selected1 = false;

                    $.each(teams, function (index1, val) {
                        if (val1 == val.id) {
                            options1 += '<option selected value="' + val.id + '">' + val.text + '</option>';
                            selected1 = true;
                        }
                        else
                            options1 += '<option value="' + val.id + '">' + val.text + '</option>';
                    });

                    if (selected1 == false) options1 = '<option disabled selected value></option>' + options1;

                    var selected2 = false;
                    var options2 = '';

                    $.each(teams, function (index1, val) {
                        if (val2 == val.id) {
                            options2 += '<option selected value="' + val.id + '">' + val.text + '</option>';
                            selected2 = true;
                        }
                        else
                            options2 += '<option value="' + val.id + '">' + val.text + '</option>';
                    });

                    if (selected2 == false) options2 = '<option disabled selected value></option>' + options2;

                    $('#PPTQ-team tbody').append('<tr>' +
                        '<input type="hidden" class="id" value="' + obj.section + '"/>' +
                        '<td class="text">' + obj.sectionDesc + '</td>' +
                        '<td><select value="" class="form-control responsible">' + options1 + '</select></td>' +
                        '<td><input class="form-control dueDate" type="date" value="' + obj.dueDate+'"></td>'+
                        '<td><select value="" class="form-control accountableApprove">' + options2 + '</select></td>' +
                        '<td><input class="form-control approvalDueDate" type="date" value="' + obj.approvalDueDate + '"></td>'
                        + '</tr>');
                });
                $.fancybox.hideLoading();


                $.fancybox({
                    'content': $('#PPTQ-team').html(),
                    closeBtn: false,
                    closeClick: false,
                    modal: true,
                    type: 'html',
                    width: 600,
                    height: 300,
                    minWidth: 600,
                    minHeight: 300,
                    maxHeight: 400
                });
          });
    }

    function next4() {
           $.fancybox.hideLoading();
           $.fancybox.close();
           window.location = '@Url.Content("~/lce/Create")';
    }

    var partnerType = null;
    var channel = '@ViewBag.ChannelValue';

    function next2() {
        clauses = [];
        channel = $('.fancybox-inner [name="bbChannel"]:checked').val();

        var arr = [];
        $.each($(".fancybox-inner #list4 option"), function (index, val) {
            arr.push(Number($(val).attr('value')));
            clauses.push({ text: $(val).text(), id: Number($(val).attr('value')) });
        });
        $.fancybox.showLoading();

        $.post('@Url.Content("~/lce/addClause")', { channel: channel, Id: '@ViewBag.Pptq', partnerSpreadsheetDataLoadId: '@ViewBag.PartnerSpreadsheetDataLoadId', partnerType: partnerType, Ids: arr })
            .done(function (data) {
                defs = data.list;

                onchangeType();

                $.fancybox.hideLoading();

                $.fancybox({
                    'content': $('#team').html(),
                    closeBtn: false,
                    closeClick: false,
                    modal: true,
                    type: 'html',
                    width: 600,
                    height: 300,
                    minWidth: 600,
                    minHeight: 300
                });
            });
    }
</script>
