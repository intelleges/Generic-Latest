@inherits System.Web.Mvc.WebViewPage < IEnumerable < Generic.enterprise >>
@using System.Web.Mvc.Html
@using Telerik.Web.Mvc.UI;
@using Generic.Helpers
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Enterprise";
}
<style>
    div#EnterpriceGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }

    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        margin-top: -45px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

        .display_menu > ul {
            padding: 0 16px;
        }

        .display_menu li {
            list-style: none outside none;
            width: 143px;
        }
</style>


<br/>




@( Html.Telerik().Grid(Model).Name("EnterpriceGrid")
        .Columns(columns =>
        {
            columns.Bound(o => o.description).Title("Enterprise").Width(100);

            //columns.Bound(o => o.sortOrder).Width(100);

            //columns.Bound(o => o.active).Width(100);

            //columns.Bound(o => o.logo).Width(100);

            //columns.Bound(o => o.applicationPath).Width(100);

            columns.Bound(o => o.companyName).Title("Company Name").Width(100);
          
            //columns.Bound(o => o.instanceName).Width(100);

            //columns.Bound(o => o.archivedDate).Width(100);

            //columns.Template(s => Html.ActionLink("Edit", "Edit", new { s.id })).Title("Edit").Width(100);
            //columns.Template(s => Html.ActionLink("Details", "Details", new { s.id })).Title("Details").Width(100); ;
            //columns.Template(s => Html.ActionLink("Delete", "Delete", new { s.id })).Title("Delete").Width(100);
             
            
        })
         .Pageable()
        .Sortable().Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height("auto"))
)


