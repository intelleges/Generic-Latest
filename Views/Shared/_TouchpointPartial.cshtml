@inherits System.Web.Mvc.WebViewPage<Generic.Models.TouchpointComboModel>
@using Telerik.Web.Mvc.UI;
@using Telerik.Web.Mvc.UI.Html;
@using System.Web.Mvc;
@using Generic;
@using Generic.Controllers;
@{
    Layout = null;
    // ViewBag.Title = "View1";
}


@(Html.Telerik().ComboBox()
            .Name("ComboBox")
            .AutoFill(Model.ComboBoxAttributes.AutoFill.Value)
            //.SelectedIndex(Model.ComboBoxAttributes.SelectedIndex.Value)
            .BindTo(new SelectList(Model.Touchpoints, "id", "description"))
            .ClientEvents(e=>e.OnChange("ComboBoxOnChange"))
            .HtmlAttributes(new { style = string.Format("width:{0}px", Model.ComboBoxAttributes.Width) })
            .Filterable(filtering =>
            {
                if (Model.ComboBoxAttributes.FilterMode != 0) 
                {
                    filtering.FilterMode(AutoCompleteFilterMode.StartsWith);
                }
            })
            .HighlightFirstMatch(Model.ComboBoxAttributes.HighlightFirst.Value)
    )

<script>

    function ComboBoxOnChange(e) {
        debugger;
        $.ajax({
            type: 'POST',
            url: '@Url.Action("ChangeTouchpoint", "Admin")',
            data: { selectedTouchpoint: e.value },
                    async: false,
                    success: function (result) {
                    },
                    error: function (err, msg) {
                    }
                });
    }
</script>