@inherits System.Web.Mvc.WebViewPage
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    
    Layout = Generic.Helpers.LayoutHelper.GetMasterLayout();   
}

<style>
    .footer {
        background-color: white!important;
        border-top: 2px #a9c2c9 solid!important;
    }
</style>
<script type="text/javascript">
    try {
        var pageTracker = _gat._getTracker("UA-7827202-1");
        pageTracker._trackPageview();
    } catch (err) { }</script>

<link rel="icon" href="@Url.Content("~/Contents/images/favicon.ico")" type="image/ico">
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<title>Intelleges</title>
<link href="@Url.Content("~/Contents/RegistrationStyle/css/styles.css")" rel="stylesheet" type="text/css" />
<link href="@Url.Content("~/Contents/RegistrationStyle/css/menu.css")" rel="stylesheet" type="text/css" />
<link rel="stylesheet" href="@Url.Content("~/Contents/RegistrationStyle/divwindow/css/dhtmlwindow.css")" type="text/css" />
<script type="text/javascript" src="https://www.google.com/uds/solutions/dynamicfeed/gfdynamicfeedcontrol.js">s</script>
<link href="@Url.Content("~/Contents/css/gfdynamicfeedcontroller.css")" type="text/css" rel="stylesheet" />
@RenderSection("styles",false)
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/modernizr")
@Scripts.Render("~/bundles/registrationJs")

<script>
    $(document).ready(function () {
        $("td.supplyright, td.supplyleft").each(function (item) {
            if ($(this).html().length > 400) {
                $(this).addClass("smaller");
            }
        });
    });
</script>


@*@Html.Telerik().StyleSheetRegistrar().DefaultGroup(group => group
    .Add("telerik.common.css")
    .Add("telerik.vista.css"))*@

@(Html.Telerik().StyleSheetRegistrar().DefaultGroup(group => group
                .Add("telerik.common.css")
                .Add("telerik.rtl.css")
                .Add("telerik.vista.css")
                .Combined(true)
                .Compress(true)))


<div id="splitterWrapper" style="display: none;height: 100px !important;">
@{Html.Telerik().Splitter().Name("Splitter1")
      .ClientEvents(ev => ev.OnLoad("onLoad"))
      .ClientEvents(ev => ev.OnCollapse("onCollapsed"))
      .ClientEvents(ev => ev.OnExpand("onExpand"))
      .HtmlAttributes(new { style = "height: 640px;" })
     

      .Orientation(SplitterOrientation.Vertical)
      .Panes(vPanes =>
      {
          vPanes.Add()
              .Size("100px")              
              //.HtmlAttributes(new { style = "height: 100px;"})
              .Collapsible(true)
              .Collapsed(true)
              .Resizable(false)
              .Content(@<div>
    @RenderSection("zCodes", required: false)
</div>);

          vPanes.Add()
              .Scrollable(false)
              .Content(Html.Telerik().Splitter().Name("Splitter2")
                      .HtmlAttributes(new { style = "height: 100%; width: 100%; border: 0; overflow: hidden;" })
                      .Orientation(SplitterOrientation.Horizontal)
                      .Panes(hPanes =>
                      {
                          hPanes.Add()
                              .Size("150px")
                              .Collapsible(true).Collapsed(true)
                              .Resizable(false)
                              .Content(@<p>Inner splitter :: left pane</p>);

                          hPanes.Add()
                              .Content(@<div id="container">


                                  <div id="dhtmlwindowholder"><span style="display: none"></span></div>
                                  <div>
                                      @RenderSection("Bottom", required: false)
                                  </div>

                                  <div class="main">
                                      <div class="content">
                                          <div class="infologinbanner">
                                              @RenderSection("Top", false)
                                          </div>
                                          <div class="supplycon">
                                              <div class="commonh">
                                              </div>
                                              <div style="border-bottom: 2px solid gray;">
                                                  <table width="89%" height="78" border="0" align="center" cellpadding="0" cellspacing="0">
                                                      <tr>
                                                          <td>&nbsp;
                                                          </td>
                                                      </tr>
                                                      <tr>
                                                          <td>
                                                              @RenderBody()
                                                          </td>
                                                      </tr>
                                                      <tr>
                                                          <td></td>
                                                      </tr>
                                                  </table>
                                              </div>
                                          </div>

                                          <div>
                                              @RenderSection("BottomFooter", required: false)
                                          </div>
                                      </div>
                                      
                                  </div>





                              </div>);

                          hPanes.Add()
                              .Size("20%")
                               .Resizable(false)
                              .Collapsible(true).Collapsed(true)
                              .Content(@<p>Inner splitter :: right pane</p>);
                                                                          
                      }).ToString());

          vPanes.Add()
              .Size("20%")
               .Resizable(false)
              .Collapsible(true).Collapsed(true)
              .Content(@<div class="footer2">
                                          <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                              <tr>
                                                  <td width="66%" class="textone"></td>
                                                  <td width="34%" align="right" class="texttwo">
                                                      <div style="margin-right: 18px;">
                                                          Copyright &copy; @DateTime.Now.Year, Intelleges @Html.Raw("&#174;"). All rights reserved.
                                                      </div>
                                                  </td>
                                              </tr>
                                          </table>
                                      </div>
                                     );
      })
      .Render();
}
    </div>




@RenderSection("scripts", required: false)

<script type="text/javascript">
   //jQuery.noConflict();
    jQuery(document).ajaxStart(jQuery.blockUI).ajaxStop(jQuery.unblockUI);
    
    

    function onCollapsed(e) {
        localStorage["collapsed"] = 1;

    }
    function onExpand(e) {
        localStorage["collapsed"] = 2;

    }
    function onLoad(e) {
        $('#splitterWrapper').css('display', '');

        
        var splitter = $("#Splitter1").data("tSplitter");

        if (splitter == null || splitter == undefined)
        {
            return;
        }
        var pane = $("#Splitter1 > .t-pane")[0]; // the first pane
        
        if (window.location.href.indexOf('PartNumber') == -1) {
            splitter.collapse(pane);
        }
        else if (localStorage["collapsed"] == 1) {
            splitter.collapse(pane);
        }
        //$(pane).height($(window).height());
        else {
            splitter.expand(pane);
        }

    }
    

</script>

@(Html.Telerik().ScriptRegistrar()
    .DefaultGroup(group => group
        .Combined(true)
        .Compress(true)
     )
    )

