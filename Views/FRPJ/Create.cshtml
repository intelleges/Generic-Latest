<div class="addPartnerDiv">
	<h2>Create FRPJ</h2>
</div>
@section Scripts{
	@System.Web.Optimization.Scripts.Render("~/bundles/jqueryval")
<script>
	$(document).ready(function () {
		$('#Protocol').change(function () {
			var objProtocolID = $('#Protocol').val();
			formData = { protocolId: objProtocolID };
			if (objProtocolID == "") {
				var touchpointSelectList = "<option value=''>-Select-</option>";
				$('#Touchpoint').html(touchpointSelectList);
				return;
			}
			$.ajax({
				url: "@Url.Content("~/touchpoint/GetTouchPointWithTitleByprotocolId")",
				type: "post",
			data: formData,
			success: function (data) {
				var len = data.Data.length;
				var i = 0;
				var touchpointSelectList = "<option value=''></option>";
				for (i = 0; i < len; i++) {
					touchpointSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].title + "</option>";
				}

				$('#Touchpoint').html(touchpointSelectList);
				//$('#touchpointDiv').show();

			},
			error: function (data) {
				var touchpointSelectList = "<option value=''> -Select-</option>";
				$('#Touchpoint').html(touchpointSelectList);
			}
		});
		});
	
		
		$("#btnClear").click(function (e) {
			alertify.confirm("Are you sure?", function (result) {
				if (result) {
					$("#addPartner input[type=text], #addPartner textarea").val("");
					$("#addPartner textarea").text("");
				}
			});

		});

		if ('@ViewBag.Message') {
			alertify.alert('@ViewBag.MessageDetail');
		}
	});
	</script>
}
