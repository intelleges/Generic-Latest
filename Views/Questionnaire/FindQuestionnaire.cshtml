@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Generic.Helpers;
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Find Questionnaire";
}
<style>
    #panelFind select {
        width: 210px;       
    }
   .txtBox {
        width: 205px;  
         border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none; 
        margin: 0 0 0 0;     
    }
    .txtBox2 {
        width: 205px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none;
    }
    .t-input {
    height:16px;
    
    }
    #panelFind td {
  padding: 0 0 0 0; 
}
</style>
<h2>Find Questionnaire</h2>
<form id="FindpersonForm" method="post" enctype="multipart/form-data">
    <div id="panelFind">
         <table width="70%; " style="float:left" border="0">
            <tbody>
                <tr>
                    <td class="tLeftColumn">Name</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="name" class="txtBox" type="text" name="name">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">DESCRIPTION</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="description" class="txtBox" type="text" name="description">
                    </td>
                </tr>
                 <tr>
                    <td class="tLeftColumn">PROTOCOL</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                          @Html.DropDownList("protocol", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">CAMPAIGN</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                          @Html.DropDownList("touchpoint", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">PROVIDER TYPE</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                           @Html.DropDownList("partnertype", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">AUTHOR</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                           @Html.DropDownList("author", String.Empty)
                    </td>

                </tr>
               
            </tbody>
        </table>
        <table style="float: left">
            <tr>
                <td></td>
                <td>

                    <input id="btnFind" class="txtBox1" value="Find" type="submit" style="width: 100px; height: 28px" name="btnFind">
                    &nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="btnCancel" class="txtBox1" value="Cancel" type="button" style="width: 100px; height: 28px" name="btnCancel">
                </td>
            </tr>

        </table>
    </div>
</form>

n