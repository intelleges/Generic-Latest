@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Generic.Helpers;
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Find Questionnaire";
}
<style>
    #panelFind select {
        width: 350px;
    }

    #panelFind input {
        width: 350px;
    }

    .form-control {
        margin: 5px;
    }

    #panelFind [type="button"] {
        width: 110px;
        margin: 5px;
    }

    #panelFind [type="submit"] {
        width: 110px;
        margin: 5px;
    }
   .txtBox {
        width: 205px;  
         border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none; 
        margin: 0 0 0 0;     
    }
    .txtBox2 {
        width: 205px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none;
    }
    .t-input {
    height:16px;
    
    }
    #panelFind td {
  padding: 0 0 0 0; 
}
</style>
<h2>Find Questionnaire</h2>
<form id="FindquestionnaireForm" method="post" enctype="multipart/form-data">
    <div id="panelFind" class="row">
        <div class="col-lg-12">
            <table width="70%; " style="float:left" border="0">
                <tbody>
                    <tr>
                        <td class="tLeftColumn form-label">Name</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="name" class="form-control" type="text" name="name">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">DESCRIPTION</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="description" class="form-control" type="text" name="description">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">PROTOCOL</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("protocol", null,String.Empty,new {@class="form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">CAMPAIGN</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("touchpoint", null, String.Empty,new {@class="form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">PROVIDER TYPE</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("partnertype", null,String.Empty,new {@class="form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">AUTHOR</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("author",null, String.Empty,new {@class="form-control" })
                        </td>

                    </tr>

                </tbody>
            </table>
      
            <table style="float: left">
                <tr>
                    <td></td>
                    <td>

                        <input id="btnFind" class="btn btn-default" value="Find" type="submit" name="btnFind">
                        &nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="btnCancel" class="btn btn-default" value="Cancel" type="button" name="btnCancel">
                    </td>
                    <td>
                        &nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="btnFacebookTest" class="btn btn-default" value="Facebook Test Button" type="button"  name="btnFacebookTest" style="width:250px;" onclick="testFacebook();">
                    </td>
                </tr>

            </table>
        </div>
    </div>
</form>

<script type="text/javascript">
    function testFacebook() {
        window.location = '@Url.Action("Subscribe", "Partner")' +'?questionnaire=5164&partnertype=666&touchpoint=4314&protocol=2214&group=2503&person_id=13201';
    }
</script>