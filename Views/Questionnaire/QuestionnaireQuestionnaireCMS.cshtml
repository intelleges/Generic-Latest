@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.view_QuestionnaireCMS>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Questionnaire Detail View";
}

<style>
    div#QuestionnaireDetailViewGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }
    .btnprocess {
        height: 21px !important;
line-height: 4px !important;
font-size: 100% !important;
    }
     .input_size {
        font-size: 11px!important;
        padding: 1px!important;
        position: relative;
        top: 2px;
    }
</style>

@*commands.Template("<input id='File' type='file' value='Upload' />");*@
@*commands
        .Custom()
        .HtmlAttributes(new { id = "export" })
        .Text("Export to Excel")
        .Action("ExportExcelQuestionnaireDetail", "Questionnaire");*@


@( Html.Telerik().Grid(Model).Name("QuestionnaireDetailViewGrid")
.ToolBar(commands =>
{
    //commands.Template("<form method='post' enctype='multipart/form-data' action='/Questionnaire/UploadExcelData/" + this.ViewContext.RouteData.Values["id"] + "'><a class='t-button' href='~/Questionnaire/ExportExcelQuestionnaireDetail/" + this.ViewContext.RouteData.Values["id"] + "' id='export'>Export to Excel</a><input style='display: none' type='file' id='file' name='file' accept='.csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel' /><a class='t-button' id='btn-upload' href='#'>Upload</a><input type='submit' class='btnprocess t-button' value='Process File'></input></form>");
    commands.Template("<form method='post' enctype='multipart/form-data' action='" + @Url.Action("UploadExcelData", "Questionnaire") + "/" + this.ViewContext.RouteData.Values["id"] + "'><a class='t-button' href='" + @Url.Action("ExportExcelQuestionnaireDetail", "Questionnaire") + "/" + this.ViewContext.RouteData.Values["id"] + "' id='export'>Export to Excel</a><input type='file' id='file'  name='file' class='input_size'  /><input type='submit' class='btnprocess t-button' value='Upload'></input></form>");
})
.Columns(columns =>
        {

            columns.Bound(o => o.questionnaireCMS).Title("CMS").Width(50).Template(@<text><a href='#' id='@item.questionnaireCMS' class="menu_block">@item.questionnaireCMS</a>
<div class="display_menu" style="display: none;">
    <ul>
        <li><a href="javascript:openEditPopup(@ViewBag.questionnaire,@item.questionnaireCMS)">Edit/Correct</a></li>
        <li><a href="javascript:openRemovePopup(@ViewBag.questionnaire,'@item.questionnaireCMS')">Remove</a></li>
        <li><a href="javascript:openArchivePopup(@ViewBag.questionnaire,'@item.questionnaireCMS')">Archive</a></li>
        <li><a href="javascript:openViewDetailPopup(@ViewBag.questionnaire)">View Detail</a></li>
        <li><a href="javascript:uploadFile(@ViewBag.questionnaire ,@item.questionnaireCMS)">Upload document</a></li>
        <li>@Html.ActionLink("Download document", "DownloadQDoc", new { selectedQ = ViewBag.questionnaire, cmsId = item.questionnaireCMS }, new {target="_blank" })</li>

    </ul>
</div>
</text>).Filterable(false);
            columns.Bound(o => o.description).Title("Description").Width(100);
            columns.Bound(o => o.text).Title("Text").Width(80).Filterable(false).Template(@<text>
                <a href='#' class='menu_block title'>@item.text</a>
                <div class='display_menu' style='display: none;width:200px;'>
                    <span style='width:100%'><p>@item.text</p></span>
                </div>
            </text>);
            columns.Bound(o => o.link).Title("Link").Width(100).Filterable(false);
            columns.Bound(o => o.doc).Title("Download").Width(50).Template(@<text><a href='#'>Download</a></text>).Filterable(false);
            


        })
        //.DataKeys(keys => keys.Add(o => o.questionnaire))
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" }).Filterable(conf=>conf.Enabled(true))



)
<form id="hiddenUploaderForm" enctype="multipart/form-data"  >
    <input type="file" id="hiddenUploaderInput" style="display:none;" />
</form>
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });
        $('#popup').bind('dialogclose', function (event) {
            window.location.replace(window.location.href);
        });
        $("td a.menu_block.title").each(function () {
            if ($(this).text().length > 20) {
                $(this).text($(this).text().substr(0, 20) + "...");
            }
        });
        $("#hiddenUploaderForm").submit(function (e) {
            e.preventDefault();
            var formdata = new FormData(); //FormData object
            var fileInput = $("#hiddenUploaderInput").prop("files")[0];
            formdata.append('file', fileInput);
            formdata.append('cmsId', selectedCms);
            formdata.append('selectedQ', selectedQ);
            $.ajax({
                url:"@Url.Action("UploadQDoc","Questionnaire")" ,
                type: 'POST',
                data: formdata,
                processData: false,
                contentType: false,
                cache: false
            }).done(function (data) {
                if (data) {
                    //$('#IntellegesLogoHref').html(data);
                    alertify.alert(data);
                }
            });
        });
        $("#hiddenUploaderInput").change(function (e) {
            $("#hiddenUploaderForm").submit();
        });
    });
    var selectedQ = null;
    var selectedCms = null;
    function uploadFile(q,cms) {
        selectedQ = q;
        selectedCms = cms;
        $("#hiddenUploaderInput").click();
    }
    
    
    function CloseMe() {
        $("#genericPopup").dialog('close');
        //$(".t-icon .t-refresh").trigger('click');

        window.location.replace(window.location.href);
    }
    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("/WrongContact/Index", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        // alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id, cmsId) {
        $.get("@Url.Content("~/Questionnaire/EditQuestionCMSDetail/")", { id: id, cmsId: cmsId }, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Remove : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Questionnaire/ArchiveQuestionCMSDetail/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }


    function openArchivePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Archive : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Questionnaire/ArchiveQuestionCMSDetail/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }

    function openViewDetailPopup(id) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Questionnaire/QuestionnaireCMSDetail")" + id, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    $(function () {
        $('#btn-upload').click(function (e) {
            e.preventDefault();
            $('#file').click();
        }
       );
    });

</script>

