@model Generic.ViewModel.QuestionnaireCMSModel
@{
    Layout = null;
}
<style type="text/css">
    .clsDesc{
    margin-left: 20px;
    }
</style>
@*@using (Html.BeginForm("EditQuestionCMSDetaill", "Questionnaire", FormMethod.Post, new { @id = "frmeditcms" }))
{*@
<div class="clsDesc" >
    <div>
        @Html.HiddenFor(x => x.questionnaireId)
        @Html.HiddenFor(x => x.questionnaireCMSId)
        @Html.TextAreaFor(x => x.cmsText, new { @rows = 25, @cols =200})
    </div>
    <div>
        <input type="button" id="btnSubmitCMS" value="Submit" />
    </div>
</div>
@*}*@

<script type="text/javascript">
    $(document).ready(function () {
        $('#btnSubmitCMS').click(function () {
            var questionnaireId = $('#questionnaireId').val();
            var questCMSId = $('#questionnaireCMSId').val();
            var cmsText = $('#cmsText').val();
            $.post("@Url.Action("EditQuestionCMSDetail", "Questionnaire")", { questId: questionnaireId, cmsId: questCMSId, text: cmsText }, function (data) {
                if (data.Status == false) {
                    alertify.alert("There is an error occurred while Updating AutoMail Message!!!");
                    return false;
                }
                else {
                    alertify.alert("Questionnaire CMS Updated Successfully!!!");
                    $("#genericPopup").dialog('close');
                    window.location.replace(window.location.href);
                }
            });
        });
    });
</script>