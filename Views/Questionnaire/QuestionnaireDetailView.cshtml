@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.question>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Questionnaire Detail View";
}

<style>
    div#QuestionnaireDetailViewGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }
</style>


@*.@( Html.Telerik().Grid(Model).Name("QuestionnaireDetailViewGrid")
.ToolBar(commands => commands
                .Custom()
                    .HtmlAttributes(new { id = "export" })
                    .Text("Export to Excel")
                    .Action("ExportExcelQuestionnaireDetail", "Questionnaire"))*@

@( Html.Telerik().Grid(Model).Name("QuestionnaireDetailViewGrid")    
.ToolBar(commands =>
    {
    commands.Template("<a class='t-button ' href='/Questionnaire/ExportExcelQuestionnaireDetail/"+ this.ViewContext.RouteData.Values["id"]+"' id='export'>Export to Excel</a>        <input style='display:none;' type='file' id='file' name='file' /><a class='t-button ' id='btn-upload' href='#'>Upload</a>");
    })

        .Columns(columns =>
        {

            columns.Bound(o => o.name).Title("Name").Width(800).Template(@<text><a href='#' id='@item.name' class="menu_block">@item.name</a>
<div class="display_menu" style="display: none;">
    <ul>
        <li><a href="javascript:openEditPopup(@item.id)">Edit/Correct</a></li>
        <li><a href="javascript:openRemovePopup(@item.id,'@item.name')">Remove</a></li>
        <li><a href="javascript:openArchivePopup(@item.id,'@item.name')">Archive</a></li>
        <li><a href="javascript:openViewDetailPopup(@item.id)">View Detail</a></li>

       

    </ul>
</div>
</text>);
            columns.Bound(o => o.question1).Title("Question").Width(800);
            columns.Bound(o => o.title).Title("Title").Width(100);
            columns.Bound(o => o.tag).Title("Tag").Width(100);
            columns.Bound(o => o.responseType).Title("Response Type").Width(100);
            columns.Bound(o => o.required).Title("Required").Width(100);
            columns.Bound(o => o.weight).Title("Weight").Width(100);
            columns.Bound(o => o.skipLogicAnswer).Title("Skipped Logic Answer").Width(100);
            columns.Bound(o => o.skipLogicJump).Title("Skip Logic Jump").Width(100);
            columns.Bound(o => o.accessLevel).Title("Access Level").Width(100);
            columns.Bound(o => o.commentRequired).Title("Comment Required").Width(100);
            columns.Bound(o => o.commentBoxTxt).Title("Comment").Width(200);
            columns.Bound(o => o.commentUploadTxt).Title("Upload Comment").Width(20);
            columns.Bound(o => o.commentType).Title("Comment Type").Width(100);
            columns.Bound(o => o.spinOffQuestionnaire).Title("Spin Off Questionnaire").Width(100);
            columns.Bound(o => o.spinOffQID).Title("Spin Off QID").Width(100);
            columns.Bound(o => o.emailAlert).Title("Email Alert").Width(100);
            columns.Bound(o => o.emailAlertList).Title("Email Aler tList").Width(100);
            columns.Bound(o => o.updated).Title("Updated").Width(100);
           

        })
        .DataKeys(keys => keys.Add(o => o.id))
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })



)
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });
        $('#popup').bind('dialogclose', function (event) {
            window.location.replace(window.location.href);
        });
    });

    function CloseMe() {
        $("#genericPopup").dialog('close');
        //$(".t-icon .t-refresh").trigger('click');

        window.location.replace(window.location.href);
    }
    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("/WrongContact/Index", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        // alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id) {
        $.get("@Url.Content("~/Questionnaire/EditQuestionDetail/")" + id, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Remove : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Questionnaire/ArchiveQuestionDetail/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }


    function openArchivePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Archive : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Questionnaire/ArchiveQuestionDetail/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }

    function openViewDetailPopup(id) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Questionnaire/QuestionDetail/")" + id, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    $(function () {
        $('#btn-upload').click(function (e) {
            e.preventDefault();
            $('#file').click();
        }
       );
    });

</script>

