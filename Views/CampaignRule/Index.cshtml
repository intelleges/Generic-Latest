    $(function () {
        //jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });

        $('#popup').bind('dialogclose', function (event) {
            window.location.replace(window.location.href);
        });



    });
    var currentPTQAccessCode = null;
    function changePTQ(accessCode) {
        currentPTQAccessCode = accessCode;
        $("#ptqList").data("tDropDownList").reload();
        $("#changePtqDialog").modal("toggle");
    }

    function CloseMe() {
        $("#genericPopup").dialog('close');
        //$(".t-icon .t-refresh").trigger('click');

        window.location.replace(window.location.href);
    }

    function remind(accessCodeValue) {
        $.post("Remind", { accessCode: accessCodeValue }).done(function (result) {

            if (result) {
                alertify.alert(result);
            }
        });
    }


    function OpenEmailDialog(ac) {
        //jQuery.noConflict();

        $.get("@Url.Content("~/WrongContact/Index")", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        // alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id) {
        $.get("@Url.Content("~/Partner/Edit/")" + id, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup(id, internalid, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Remove " + internalid + " : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Partner/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }


    function openArchivePopup(id, internalid, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Archive " + internalid + " : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Partner/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }

    function openViewDetailPopup(id) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Partner/Details/")" + id, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    function openCompletePopup(accesscode) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Registration?Accesscode=")" + accesscode, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "Complete" });
        $("#genericPopup").dialog('open');
    }
    function checkToPrintPDF(status, accesscode) {
        $.getJSON('@Url.Content("~/Partner/PartnertypeTouchpointQuestionnaireCampaignStatus")', { accessCode: accesscode }, function (data) {
            alertify.confirm(data[0].nextStep + " Continue to PDF?", function (e) {
                if (e) {
                    // click yes
                    window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + accesscode;

                } else {
                    // click no
                }
            });
            @*if (status.toLowerCase() == 'responded/complete') {
                    window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + accesscode;
                } else {
                    alert("it's not responded yet");
            }*@
        }).fail(function (jqXHR, textStatus, errorThrown) {
            debugger;
            alertify.alert('Error getting Touch Point!');
        });
    }

    function checkToPrintHTML(status, accesscode) {
        if (status.toLowerCase() == 'responded/complete') {
            window.location.href = "@Url.Content("~/Partner/PrintHTML/?accesscode=")" + accesscode;
        } else {
            alert("it's not responded yet");
        }
    }

    $(function () {
        $(".t-widget.t-dropdown.t-header").css("width", "100%");
    });
    $("#changePtqBtn").click(function () {

    })
</script>
<div class="tw-bs">
    <div class="container-fluid">
        <div class="modal fade" id="changePtqDialog" role="dialog" aria-labelledby="gpsLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span aria-hidden="true">&times;</span><span class="sr-only"></span>
                        </button>
                        <h4 class="modal-title" id="gpsLabel">Change  Partner type Touchpoint Questionnaire </h4>
                    </div>
                    <div class="modal-body">

                        <form id="changePtqForm">
                            <div class="form-group">
                                @Html.Label("ptqList", "Questionnaire")
                                @Html.Telerik().DropDownList().Name("ptqList").DataBinding(conf => conf.Ajax().Select("CurrentPtqList", "Campaign")).DropDownHtmlAttributes(new { style = "width:500px;white-space:nowrap;" })
                            </div>
                            <button type="button" class="btn btn-default btn-block" id="changePtqBtn">Save</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>