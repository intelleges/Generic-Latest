@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.pr_getCampaignRuleAll_Result>>

@using System.Web.Mvc.Html
@using System.Collections.Generic
@using Generic
@using System.Web.Optimization
@using Telerik.Web.Mvc.UI;
@using Generic.Helpers
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = ViewBag.enterpriseName + " Campaigns Rule";
}

<style>
    div#CampaignRuleGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }

    .modal-dialog {
        z-index: 1050;
    }
</style>

@( Html.Telerik().Grid(Model).Name("CampaignRuleGrid")
        .ToolBar(commands => commands
        .Custom()
        .HtmlAttributes(new { id = "export" })
        .Text("Export to Excel")
        .Action("ExportExcel", "partner"))


        .Columns(columns =>
        {
            columns.Bound(o => o.id).Title("ID").Width(30).Encoded(false);
            columns.Bound(o => o.campaign).Title("Campaign Name").Width(130).Template(@<text>
                @{

                    var columnData = item.campaign;
                    var width = 100;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
                    }
                    <a href='#' id='@item.campaign' class="menu_block" title="@columnData">@visibleText</a>
                }
            </text>);
            columns.Bound(o => o.initTest).Title("initTest").Width(60).Encoded(false);
            columns.Bound(o => o.ptqCurrent).Title("ptqCurrent").Width(150).Template(@<text>

                @{
                    var columnData = item.ptqCurrent;
                    var width = 130;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
                    }

                    <p title="@columnData">@visibleText</p>
                }
            </text>);

            columns.Bound(o => o.status).Title("Status").Width(50).Encoded(false);
            columns.Bound(o => o.statusLogic).Title("statusLogic").Width(80).Encoded(false);
            columns.Bound(o => o.score).Title("score").Width(50).Encoded(false);
            columns.Bound(o => o.scoreLogic).Title("scoreLogic").Width(80).Encoded(false);
            columns.Bound(o => o.responseInterval).Title("responseInterval").Width(120).Encoded(false);
            columns.Bound(o => o.responseIntervalLogic).Title("responseIntervalLogic").Width(150).Encoded(false);
            columns.Bound(o => o.straightline).Title("straightline").Width(80).Encoded(false);
            columns.Bound(o => o.delayInterval).Title("delayInterval").Width(100).Encoded(false);
            columns.Bound(o => o.delayIntervalLogic).Title("delayIntervalLogic").Width(120).Encoded(false);
            columns.Bound(o => o.ptqNext).Title("ptqNext").Width(150).Template(@<text>

                @{
                    var columnData = item.ptqNext;
                    var width = 80;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
                    }
                    <p title="@columnData">@visibleText</p>
                }


            </text>);

            columns.Bound(o => o.ptqNext).Title("switchOffDate").Width(100).Template(@<text>
        @{
            var strswitchOffDate = ((DateTime)item.switchOffDate).ToString("MM/dd/yyyy");
            <p title="switchOffDate">@strswitchOffDate</p>
        }
            </text>);
            columns.Bound(o => o.ptqNext).Title("hardEndDate").Width(100).Template(@<text>
        @{
            var strhardEndDate = ((DateTime)item.hardEndDate).ToString("MM/dd/yyyy");
            <p title="switchOffDate">@strhardEndDate</p>
        }
            </text>);


        })
                        .DataKeys(keys => keys.Add(o => o.id))
                        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
                        .Sortable(sorting => sorting.Enabled(true))
                        .Scrollable(scrolling => scrolling
                        .Enabled(true)
                        .Height(380))
                        .HtmlAttributes(new { @class = "ra" })



)

<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content {
        overflow-x: scroll !important;
    }

        .t-grid-content tr > td:hover .menu_block + .display_menu {
            display: block !important;
        }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }

    #madalEmailForm .table td[colspan='5'] {
        text-align: center;
    }
</style>
@*<script src="~/Scripts/jquery-1.8.2.js"></script>
    <script src="~/Scripts/jquery-ui-1.9.2.js"></script>*@
