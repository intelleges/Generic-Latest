@inherits System.Web.Mvc.WebViewPage<Generic.touchpoint>
@using System.Web.Mvc.Html
@using Generic.Helpers
@{
    Layout = null;//LayoutHelper.GetLayout();
    ViewBag.Title = "Touch Point";
}
<style type="text/css">
    .threecol, twocol {
        width: 100%;
        display: inline-block;
    }

    .twocol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .twocol .editor-field {
        width: 35%;
        display: inline-block;
    }

    .threecol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .threecol .editor-field {
        width: 20%;
        display: inline-block;
    }

        .threecol .editor-field label, .threecol .editor-field input, .threecol .editor-field select, .twocol .editor-field input, .twocol .editor-field select {
            width: 90%;
            display: inline-block;
            font-size: 11px;
        }
</style>
<h2>Edit</h2>

@using (Html.BeginForm())
{
    @Html.ValidationSummary(true)

    <fieldset>
        <legend>touchpoint</legend>
        <div class="twocol">
            @Html.HiddenFor(model => model.id)

            <div class="editor-label">
                @Html.LabelFor(model => model.protocol)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.protocol)
                @Html.ValidationMessageFor(model => model.protocol)
            </div>

            <div class="editor-label">
                @Html.LabelFor(model => model.person)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.person)
                @Html.ValidationMessageFor(model => model.person)
            </div>
        </div>

         <div class="threecol">
        <div class="editor-label">
            @Html.LabelFor(model => model.sponsor)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.sponsor)
            @Html.ValidationMessageFor(model => model.sponsor)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.admin)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.admin)
            @Html.ValidationMessageFor(model => model.admin)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.title)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.title)
            @Html.ValidationMessageFor(model => model.title)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.description)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.description)
            @Html.ValidationMessageFor(model => model.description)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.abbreviation)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.abbreviation)
            @Html.ValidationMessageFor(model => model.abbreviation)
        </div>


        <div class="editor-label">
            @Html.LabelFor(model => model.purpose)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.purpose)
            @Html.ValidationMessageFor(model => model.purpose)
        </div>


        <div class="editor-label">
            @Html.LabelFor(model => model.target)
        </div>
        <div class="editor-field">
            @Html.DropDownList("target", String.Empty)
            @Html.ValidationMessageFor(model => model.target)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.startDate)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.startDate)
            @Html.ValidationMessageFor(model => model.startDate)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.endDate)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.endDate)
            @Html.ValidationMessageFor(model => model.endDate)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.automaticReminder)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.automaticReminder)
            @Html.ValidationMessageFor(model => model.automaticReminder)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.sortOrder)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.sortOrder)
            @Html.ValidationMessageFor(model => model.sortOrder)
        </div>

        <div class="editor-label">
            @Html.LabelFor(model => model.active)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.active)
            @Html.ValidationMessageFor(model => model.active)
        </div>
        <p style="float: right; width: 20%;">
            @*<input type="submit" value="Save" />*@
            <input type="button" value="Save" onclick="savedata()" />
            <input type="button" onclick="CloseMe()" value="Cancel" />
        </p>
    </fieldset>
}



@*@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}*@
