@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.view_ProtocolData>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Protocol";
}

<style>
    div#ProtocolGrid
    {
        font-size: 11px;
    }

    #modal
    {
        height: 489px;
    }

    .ui-dialog
    {
        width: 99% !important;
        left: 0;
    }
</style>
<div style="margin-top:10px;">
    <form action="@Url.Content("~/Protocol/RemoveProtocol")" method="post">
        <input id="searchType" type="hidden" value="@ViewBag.searchType" name="searchType">

        @( Html.Telerik().Grid(Model).Name("ProtocolGrid")
   .ToolBar(commands => commands
                .Custom()
                    .HtmlAttributes(new { id = "go" })
                    .Text("Go")
                    .Action("Go", "Protocol"))

        .Columns(columns =>
        {

            columns.Bound(o => o.enterprise)

                   .Title("<input type='checkbox' onchange='Selectall();' id='chkSelectAll' style='margin-left: 11px;' name='checkedRecords' value='<#= IsSelected #>' />")
                   .Template(@<text><input type='checkbox' id='chkMessage' name='chkSelect' value='@item.id' /></text>)
                   .Width(50)
                   .HtmlAttributes(new { style = "text-align:center" });



            columns.Bound(o => o.name).Title("Protocol Name").Width(400).Template(@<text><a href='#' id='@item.name' class="menu_block">@item.name</a>
<div class="display_menu" style="display: none;">
    <ul>
        <li><a href="javascript:openEditPopup(@item.id)">Edit/Correct</a></li>
        <li><a href="javascript:openRemovePopup(@item.id,'@item.name')">Remove</a></li>
        <li><a href="javascript:openArchivePopup(@item.id,'@item.name')">Archive</a></li>
        <li><a href="javascript:openViewDetailPopup(@item.id)">View Detail</a></li>

    </ul>
</div>
</text>);
            columns.Bound(o => o.Protocol_Admin).Title("Protocol_Admin").Width(100);
            columns.Bound(o => o.Protocol_Sponsor).Title("Protocol_Sponsor").Width(100);
           // .FooterTemplate(@<text><input style="width: 80px;" type="submit" value="Go" /></text>);

            columns.Bound(o => o.User_Count).Title("User_Count").Width(100);

            columns.Bound(o => o.Partner_Count).Title("Partner_Count").Width(100);
            columns.Bound(o => o.Group_Count).Title("Group_Count").Width(100);




        })

         //.ClientEvents(events => events.OnDataBound("onDataBound"))
        .DataKeys(keys => keys.Add(o => o.id))
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(false))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })



)
    </form>
</div>
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu
    {
        display: block !important;
    }
    .t-grid-header .t-header {
        padding-top: 3px !important;
        padding-bottom: 13px !important;
    }
    .display_menu
    {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td
    {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul
    {
        padding: 0 16px;
    }

    .display_menu li
    {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });


    });

    function CloseMe() {
        $("#genericPopup").dialog('close');
        //$(".t-icon .t-refresh").trigger('click');

        window.location.replace(window.location.href);
    }


    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("@Url.Content("~/WrongContact/Index")", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id) {
        $.get("@Url.Content("~/Protocol/Edit/")" + id, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Remove "  + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Protocol/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }


    function openArchivePopup(id, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Archive " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Protocol/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }

    function openViewDetailPopup(id) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Protocol/Details/")" + id, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    function openCompletePopup() {
        $("#genericPopup").html("<h1>Your Complete content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "Complete" });
        $("#genericPopup").dialog('open');
    }





    function Selectall() {
        // if check all is checked, all checkboxes are checked
        // if check all is unchecked, all checkboxes are cleared

        if ($('#chkSelectAll').is(':checked')) {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).attr('checked', 'checked');
                });
        }
        else {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).removeAttr('checked');
                });
        }
    }

    $('input:checkbox[name$=chkSelect]').click(
    function () {
        // if any of the checkbox is unchecked
        // check all checkbox should be cleared
        if (!$(this).is(':checked')) {
            $('#chkSelectAll').removeAttr('checked');
        }
        else {
            // if all of the checkbox is checked
            // check all checkbox should be checked
            if ($('input:checkbox[name$=chkSelect]').length ==
            $('input:checkbox[name$=chkSelect]:checked').length) {
                $('#chkSelectAll').attr('checked', 'checked');
            }
        }
    });





</script>

