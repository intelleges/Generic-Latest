@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.view_ProtocolData>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetPopupLayout();
    ViewBag.Title = "Partner";
}

<style>
    div#PartnerGrid
    {
        font-size: 11px;
    }

    #modal
    {
        height: 489px;
    }

    .ui-dialog
    {
        width: 99% !important;
        left: 0;
    }
</style>

@( Html.Telerik().Grid(Model).Name("ProtocolGrid")
        .Columns(columns =>
        {
            columns.Bound(o => o.name).Title("Name").Width(100).Encoded(false);
            columns.Bound(o => o.enterprise).Title("Enterprise").Width(100);

            columns.Bound(o => o.Group_Count).Title("GroupCount").Width(100);
            columns.Bound(o => o.Partner_Count).Title("PartnerCount").Width(100);
            columns.Bound(o => o.Protocol_Admin).Title("ProtocolAdmin").Width(200);

            columns.Bound(o => o.Protocol_Sponsor).Title("ProtocolSponsor").Width(200);

            columns.Bound(o => o.User_Count).Title("UserCount").Width(100);

        })

        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })



)
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu
    {
        display: block !important;
    }

    .display_menu
    {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td
    {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul
    {
        padding: 0 16px;
    }

    .display_menu li
    {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });

    });
    function CloseMe() {
        $("#genericPopup").dialog('close');
        $("#PartnerGrid").data("kendoGrid").read();

    }
    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("/WrongContact/Index", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id) {
        $.get("/Partner/Edit/" + id, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup() {
        $("#genericPopup").html("<h1>Your Remove content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "Remove" });
        $("#genericPopup").dialog('open');
    }

    function openArchivePopup() {
        $("#genericPopup").html("<h1>Your Archive content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "Archive" });
        $("#genericPopup").dialog('open');
    }

    function openViewDetailPopup() {
        $("#genericPopup").html("<h1>Your View Detail content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    function openCompletePopup() {
        $("#genericPopup").html("<h1>Your Complete content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "Complete" });
        $("#genericPopup").dialog('open');
    }


</script>

