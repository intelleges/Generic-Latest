@inherits System.Web.Mvc.WebViewPage<Generic.protocol>
@using System.Web.Mvc.Html
@using Generic.Helpers
@{
    Layout = null;//LayoutHelper.GetLayout();
    ViewBag.Title = "Protocol";
}

<style type="text/css">
    .threecol, twocol {
        width: 100%;
        display: inline-block;
    }

    .twocol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .twocol .editor-field {
        width: 35%;
        display: inline-block;
    }

    .threecol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .threecol .editor-field {
        width: 20%;
        display: inline-block;
    }

        .threecol .editor-field label, .threecol .editor-field input, .threecol .editor-field select, .twocol .editor-field input, .twocol .editor-field select {
            width: 90%;
            display: inline-block;
            font-size: 11px;
        }
</style>
<h2>Edit</h2>

