@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Generic.Helpers;
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Find Group";
}

<style>
    #panelFind select {
        width: 350px;
    }

    #panelFind input {
        width: 350px;
    }

    .form-control {
        margin: 5px;
    }
    #panelFind [type="button"] {
        width: 110px;
        margin: 5px;
    }

    #panelFind [type="submit"] {
        width: 110px;
        margin: 5px;
    }
   .txtBox {
        width: 205px;  
         border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none; 
        margin: 0 0 0 0;     
    }
    .txtBox2 {
        width: 205px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none;
    }
    .t-input {
    height:16px;
    
    }
    #panelFind td {
  padding: 0 0 0 0; 
}
</style>

<script type="text/javascript">
    $(document).ready(function(){
        $('#touchpointID').change(function () {
            var objtouchpointID = $('#touchpointID').val();
            if (objtouchpointID == "") {
                objtouchpointID = 0;
            }
            var formData = { touchpointId: objtouchpointID };
            $.ajax({
                url: "@Url.Content("~/Group/GetGroupByTouchpointid")",
                  type: "post",
                  data: formData,
                  success: function (data) {
                      var len = data.Data.length;
                      var i = 0;
                      var groupSelectList = "<option value=''></option>";
                      for (i = 0; i < len; i++) {
                          groupSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].description + "</option>";
                      }

                      $('#group').html(groupSelectList);


                  },
                  error: function (data) {
                      var touchpointSelectList = "<option value=''></option>";
                      $('#group').html(touchpointSelectList);
                  }
            });
        });
    });
   
</script>
<h2>Find Group</h2>

<form id="FindpersonForm" method="post" enctype="multipart/form-data">
<div id="panelFind" class="row">
    <div class="col-lg-8">
        <table width="70%; " style="float:left" border="0">
            <tbody>
                <tr id="ctl00_contentMain_rowName">
                    <td class="tLeftColumn form-label">NAME</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtNameFind" class="form-control" type="text" name="txtNameFind">
                    </td>
                </tr>

                <tr>
                    <td class="tLeftColumn form-label">Campaign </td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        @Html.DropDownList("touchpoint", null,String.Empty,new { @class="form-control"})
                    </td>
                </tr>
                <tr id="ctl00_contentMain_rowBy1">
                    <td class="tLeftColumn form-label">Owner </td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtProviderFind" class="form-control" type="text" name="txtProviderFind">
                    </td>
                </tr>

                <tr id="ctl00_contentMain_rowDescription">
                    <td class="tLeftColumn form-label">DESCRIPTION</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="ctl00_contentMain_txtDescriptionFind" class="form-control" type="text" name="ctl00$contentMain$txtDescriptionFind">
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
    <div class="col-lg-4">
        <table style="float: left">
            <tr>
                <td></td>
                <td>

                    <input id="btnFind" class="btn btn-default" value="Find" type="submit"  name="btnFind">
                    &nbsp;&nbsp;&nbsp;&nbsp;
                    <input id="btnCancel" class="btn btn-default" value="Cancel" type="button"  name="btnCancel">
                </td>
            </tr>

        </table>
    </div>
    </div>
</form>

 
