@( Html.Telerik().Grid(Model).Name("GigfestPersonGrid")
        .DataBinding(dataBinding => dataBinding.Ajax().Select("CheckData", "Gigfest"))
        .EnableCustomBinding(true)
.ToolBar(commands => commands
                .Custom()
                    .HtmlAttributes(new { id = "export" })
                    .Text("Export to Excel")
                    .Action("ExportExcel", "Gigfest"))
        .Columns(columns =>
        {
        columns.Bound(o => o.SearchTerm).Title("Search Term").Width(100);
        columns.Bound(o => o.CompanyName).Title("Company Name").Width(100).Template(@<text>
        @{
            var columnData = item.CompanyName;
            var width = 12;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <a href='#' class="menu_block" title="@columnData">@visibleText</a>
        }
        <div class="display_menu" style="display: none;">
            <ul>

                <li><a href="https://www.google.com/search?q=@item.CompanyName+@item.JobTitle&as_eq=pub.dir&as_sitesearch=linkedin.com%2Fin" target="_blank">LinkedIn</a></li>
                <li><a href="@item.JobUrl" target="_blank">Job AD</a></li>
            </ul>
        </div>
        </text>);
            columns.Bound(o => o.JobTitle).Title("Job Title").Width(100).Template(@<text>
            @{
                <p title="@item.JobSnippet">@item.JobTitle</p>

            }
            </text>);

                columns.Bound(o => o.JobAdDate).Format("{0:MM/dd/yyyy}").Title("Job Date").Width(80);
                columns.Bound(o => o.JobUrl).Title("URL").Width(150).Template(@<text>
                <a href="@item.CompanyWebsite" target="_blank">@item.CompanyWebsite</a>
                </text>);

        })
                            .DataKeys(keys => keys.Add(o => o.JobInternalId))
                            .Pageable(pager => pager.Enabled(true))
                            //.Sortable(sorting => sorting.Enabled(true))
                            .Scrollable(scrolling => scrolling
                               .Enabled(true)
                               .Height(380))
                                                       .HtmlAttributes(new { @class = "ra" })




)

