@inherits System.Web.Mvc.WebViewPage<Generic.campaign>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = ViewBag.Project + " Edit Campaign";
}

<h2>Edit Campaign</h2>
<style type="text/css">
    .threecol, .twocol {
        width: 100%;
        display: inline-block;
    }

    .twocol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .twocol .editor-field {
        width: 35%;
        display: inline-block;
    }

    .threecol .editor-label {
        width: 10%;
        display: inline-block;
        font-size: 11px;
    }

    .threecol .editor-field {
        width: 20%;
        display: inline-block;
    }

        .threecol .editor-field label, .threecol .editor-field input, .threecol .editor-field select, .twocol .editor-field input, .twocol .editor-field select {
            width: 90%;
            display: inline-block;
            font-size: 11px;
        }

    .txtClass {
        border-radius: 5px;
    }

    .ddlClass {
        height: 25px;
        width: 96% !important;
        border-radius: 5px;
    }

    #DueDate {
        border-radius: 5px;
        height: 18px;
    }


    .btn {
        background: #3498db;
        background-image: -webkit-linear-gradient(top, #3498db, #2980b9);
        background-image: -moz-linear-gradient(top, #3498db, #2980b9);
        background-image: -ms-linear-gradient(top, #3498db, #2980b9);
        background-image: -o-linear-gradient(top, #3498db, #2980b9);
        background-image: linear-gradient(to bottom, #3498db, #2980b9);
        -webkit-border-radius: 12;
        -moz-border-radius: 12;
        border-radius: 28px;
        font-family: Arial;
        color: #ffffff;
        font-size: 15px;
        padding: 3px 20px 5px 20px !important;
        text-decoration: none;
    }

        .btn:hover {
            background: #3cb0fd;
            background-image: -webkit-linear-gradient(top, #3cb0fd, #3498db);
            background-image: -moz-linear-gradient(top, #3cb0fd, #3498db);
            background-image: -ms-linear-gradient(top, #3cb0fd, #3498db);
            background-image: -o-linear-gradient(top, #3cb0fd, #3498db);
            background-image: linear-gradient(to bottom, #3cb0fd, #3498db);
            text-decoration: none;
        }
</style>
<p>

    @Html.ActionLink("Back to list", "Index")
</p>
@using (Html.BeginForm("Edit", "Campaign", FormMethod.Post, new { id = "createCampaignForm" }))
{
    @Html.ValidationSummary(true)

    <fieldset>
        <legend>Create New Campaign</legend>
        <div class="threecol">
            <div class="editor-label">
                @Html.LabelFor(model => model.touchpoint, "Touchpoint")
            </div>
            <div class="editor-field">
                @Html.DropDownListFor(
    x => x.touchpoint,
    (SelectList)ViewBag.protocol,
 "<select touchpoint>"
)
                @Html.ValidationMessageFor(model => model.touchpoint)
            </div>
            <div class="editor-label">
                @Html.LabelFor(model => model.description, "Description")
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.description)
                @Html.ValidationMessageFor(model => model.description)
            </div>
            <div class="editor-label">
                @Html.LabelFor(model => model.year, "Year")
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.year)
                @Html.ValidationMessageFor(model => model.year)
            </div>
        </div>
        <div class="threecol">
            <div class="editor-label">
                @Html.LabelFor(model => model.startDate, "Start Date")
            </div>
            <div class="editor-field">
                @Html.Telerik().DatePickerFor(model => model.startDate)
                @Html.ValidationMessageFor(model => model.startDate)
            </div>
            <div class="editor-label">
                @Html.LabelFor(model => model.endDate, "End Date")
            </div>
            <div class="editor-field">
                @Html.Telerik().DatePickerFor(model => model.endDate)

                @Html.ValidationMessageFor(model => model.endDate)
            </div>
            
                <div class="editor-label">
                    @Html.LabelFor(model => model.status, "Status")
                </div>
                <div class="editor-field">
                    @Html.DropDownListFor(
x => x.status,
(SelectList)ViewBag.statuses,
    "<select status>"
)
                    @Html.ValidationMessageFor(model => model.status)
                </div>
            </div>

            <p style="float: right; width: 20%;">
                <button type="submit" value="Save" class="btn">Save</button>
                
            </p>
    </fieldset>
}

<script>
    $(document).ready(function () {
       
        var message = "@ViewBag.message";
        if (message) {
            alertify.alert(message);
            $("#btnClear").click();
        }
    });
</script>
@section Scripts {
    @System.Web.Optimization.Scripts.Render("~/bundles/jqueryval")
}