<script>

	function onchangeProtocol()
	{
		if ($("#protocol option:selected").text() == 'PODS') {
			alertify.set({
				labels: {
					ok: "PODS",
					cancel: "Cancel"
				}
			});
			alertify.confirm("Please be advised you’re currently completing the Certs-Reps Manual add form, but selected the PODS protocol.  If you wish to continue with the Certs-Reps add form, click Cancel and select Certs-Reps as the protocol, otherwise if you’d like to be redirected to the PODS add form, click PODS.", function (res, value) {
				if (!res) {
					$("#protocol").val('1056');
				}
				else {
					setCookie("supplierName", $('#name').val(), 1);
					setCookie("supplierNumber", $('#internalID').val(), 1);
					setCookie("buyerFirstName", $('#firstName').val(), 1);
					setCookie("buyerLastName", $('#lastName').val(), 1);
					setCookie("buyerEmail", $('#email').val(), 1);
					setCookie("protocol", $('#protocol').val(), 1);


					window.location = '@Url.Content("~/POD/Create")';
				}
			});
		}
	}

	function setCookie(cname, cvalue, exdays) {
		var d = new Date();
		d.setTime(d.getTime() + (exdays * 24 * 60 * 60 * 1000));
		var expires = "expires=" + d.toUTCString();
		document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
	}

	function submitForm() {
		$("form").submit();
    }

    function submitTestForm() {
        function getFormattedDate(date) {
            var year = date.getFullYear();

            var month = (1 + date.getMonth()).toString();
            month = month.length > 1 ? month : '0' + month;

            var day = date.getDate().toString();
            day = day.length > 1 ? day : '0' + day;

            return month + '/' + day + '/' + year;
        }
        $("#protocol").prop("selectedIndex", 1).trigger("change");
        setTimeout(
        function () {
            $("#touchpoint").prop("selectedIndex", 1).trigger("change");
                setTimeout(function () {
                    $("#partnertype").prop("selectedIndex", 1).trigger("change");
                    setTimeout(function () {
                        $("#internalID").val(Math.floor(Math.random() * 1000000).toString());
                        $("#name").val("FirstName LastName");
                        $("#address1").val("address 1 - test");
                        $("#address2").val("address 2 - test");
                        $("#city").val("city -test");
                        $("#state").prop("selectedIndex", 1);
                        $("#zipcode").val("123456");
                        $("#country").prop("selectedIndex", 1);
                        $("#phone").val("1234567890");
                        $("#firstName").val("FirstName -Test");
                        $("#lastName").val("Lastname - test");
                        $("#title").val("Compliance Manager");
                        $("#email").val($("#hdfLoginEMail").val());
                        $("#dunsNumber").val("12345");
                        $("#group").prop("selectedIndex", 1).trigger("change");
                        $("#owner").prop("selectedIndex", 1).trigger("change");
                        $("#DueDate").val(getFormattedDate(new Date()));
                    }, 3000);
                }, 3000);
            }, 3000);
    }


    //#region First declaration
    jQuery(document).ready(function ($) {
        $("form").submit(function () {
            return validateControl();

        });

        //#endregion
        //#region validation
        function validateControl() {

        	alertify.set({
        		labels: {
        			ok: "OK",
        			cancel: "Cancel"
        		}
        	});

            if ($("#name").val() == "") {
                alertify.alert("Name is required");
                return false;
            }
            if ($("#internalID").val() == "") {
                alertify.alert("internalID is required");
                return false;
            }

            if ($("#firstName").val() == "") {
                alertify.alert("First Name is required");
                return false;
            }
            if ($("#lastName").val() == "") {
                alertify.alert("Last Name is required");
                return false;
            }
            if ($("#email").val() == "") {
                alertify.alert("Email is required");
                return false;
            }
            if ($("#protocol").val() == "") {
                alertify.alert("Protocol is required");
                return false;
            }
            if ($("#touchpoint").val() == "") {
                alertify.alert("Touchpoint is required");
                return false;
            }
            if ($("#DueDate").val() == "") {
                alertify.alert("Due Date is required");
                return false;
            }
            if ($("#group").val() == "") {
                alertify.alert("Group is required");
                return false;
            }
            if ($("#partnertype").val() == "") {
                alertify.alert("Partner type is required");
                return false;
            }
            if ($("#owner").val() == "") {
                alertify.alert("Owner is required");
                return false;
            }
            //#endregion

            if ($("#address1").val() === "" && $("#address2").val() === "") {
                alertify.alert("Address is required");
                return false;
            }
            if ($("#city").val() === "") {
                alertify.alert("City is required");
                return false;
            }
            if ($("#state").val() === "") {
                alertify.alert("State is required");
                return false;
            }
            if ($("#zipcode").val() === "") {
                alertify.alert("Zip Code is required");
                return false;
            }
            if ($("#country").val() === "") {
                alertify.alert("Country is required");
                return false;
            }
            if ($("#phone").val() === "") {
                alertify.alert("Phone is required");
                return false;
            }
            if ($("#title").val() === "") {
                alertify.alert("Title is required");
                return false;
            }
            if ($("#dunsNumber").val() === "") {
                alertify.alert("DUNS Number is required");
                return false;
            }
            if ($("#dunsNumber").val() === "") {
                alertify.alert("DUNS Number is required");
                return false;
            }

        }
    });
</script>
