            <div class="threecol">
                <div class="editor-label">
                    @Html.Label("Protocol")
                </div>
                <div class="editor-field">
                    @Html.DropDownList("protocol", null, String.Empty, new { @class = "ddlClass", @data_val = "true", @data_val_required = " ", onchange = "onchangeProtocol();" })
                    <span class="field-validation-valid" data-valmsg-for="protocol" data-valmsg-replace="true"></span>
                </div>
                <div class="editor-label">
                    @Html.Label("Touchpoint")
                </div>
                <div class="editor-field">
                    <select id="touchpoint" name="touchpoint" class="ddlClass" data-val="true" data-val-required=" "></select>
                    <span class="field-validation-valid" data-valmsg-for="touchpoint" data-valmsg-replace="true"></span>
                </div>
                <div class="editor-label">
                    @Html.Label("Partner Type")
                </div>
                <div class="editor-field">
                    <select id="partnertype" name="partnertype" class="ddlClass" data-val="true" data-val-required=" "></select>
                    <span class="field-validation-valid" data-valmsg-for="partnertype" data-valmsg-replace="true"></span>
                    @*<a href="@Url.Content(" ~ /PartnerType/Create")">Add Partner Type</a>*@
                </div>
            </div>
            <div class="twocol">
                @Html.HiddenFor(model => model.id)

                <!-- #endregion-->
                <!-- #region Internal ID-->
                <div class="editor-label">
                    @*@Html.LabelFor(model => model.internalID)*@
                    @Html.Label("Internal ID")
                </div>
                <div class="editor-field">
                    @*@Html.EditorFor(model => model.internalID)*@
                    @Html.TextBoxFor(model => model.internalID, new { @class = "txtClass", onchange = "changeInrenalId();" })
                    @Html.ValidationMessageFor(model => model.internalID)
                </div>
                <!-- #endregion-->
                <!-- #region Name-->
                <div class="editor-label">
                    @Html.Label("Name")
                </div>
                <div class="editor-field">
                    @*@Html.EditorFor(model => model.name)*@
                    @Html.TextBoxFor(model => model.name, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.name)
                </div>
            </div>


            <div class="threecol">
                <div class="editor-label">
                    @Html.Label("Address 1")
                </div>
                <div class="editor-field">
                    @Html.TextBoxFor(model => model.address1, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.address1)
                </div>

                <div class="editor-label">
                    @*@Html.LabelFor(model => model.address2)*@
                    @Html.Label("Address 2")
                </div>
                <div class="editor-field">
                    @*@Html.EditorFor(model => model.address2)*@
                    @Html.TextBoxFor(model => model.address2, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.address2)
                </div>

                <div class="editor-label">

                    @Html.Label("City")
                </div>
                <div class="editor-field">

                    @Html.TextBoxFor(model => model.city, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.city)
                </div>

                <div class="editor-label">
                    @*@Html.LabelFor(model => model.state)*@
                    @Html.Label("State")
                </div>
                <div class="editor-field">
                    @Html.DropDownList("state", null, String.Empty, new { @class = "ddlClass" })

                    @Html.ValidationMessageFor(model => model.state)
                </div>

                <div class="editor-label">
                    @*@Html.LabelFor(model => model.province)*@
                    @Html.Label("Province")
                </div>
                <div class="editor-field">
                    @*@Html.EditorFor(model => model.province)*@
                    @Html.TextBoxFor(model => model.province, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.province)
                </div>

                <div class="editor-label">
                    @*@Html.LabelFor(model => model.zipcode)*@
                    @Html.Label("Zip Code")
                </div>
                <div class="editor-field">
                    @*@Html.EditorFor(model => model.zipcode)*@
                    @Html.TextBoxFor(model => model.zipcode, new { @class = "txtClass" })
                    @Html.ValidationMessageFor(model => model.zipcode)
                </div>

                <div class="editor-label">
                    @*@Html.LabelFor(model => model.country)*@
                    @Html.Label("Country")
                </div>
                <div class="editor-field">
                    @Html.DropDownList("country", null, String.Empty, new { @class = "ddlClass" })
                    @Html.ValidationMessageFor(model => model.country)
                </div>

