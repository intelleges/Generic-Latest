@using (Html.BeginForm("Create", "Partner", FormMethod.Post, new { @id = "frmCreate" }))
{
    @Html.ValidationSummary(true)
    <fieldset>
        <legend>partner</legend>
        <input type="hidden" value="@ViewBag.LoggedInOwner" id="hdfLoginEMail" />
