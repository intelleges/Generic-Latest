@section scripts{
    @System.Web.Optimization.Scripts.Render("~/bundles/jqueryval")
    <script type="text/javascript">
        function changeInrenalId() {

                              $.post("@Url.Action("ValidateInternalID", "Partner")", {
                partnertype: $('#partnertype').val(),
                touchpoint: $('#touchpoint').val(),
                internalID: $("#internalID").val()
            })
                                  .done(function (data) {

                    if (data.message !== null && data.message.length > 0 && data.message.split(';').length > 0) {
                        if (data.message.split(';')[0] == "1") {
                            alertify.alert(data.message.split(';')[2]);
                            $("#internalID").val('');
                        }
                        else if (data.message.split(';')[0] == "2") {
                            alertify.set({
                                labels: {
                                    ok: "Yes", cancel: "No"
                                }
                            });
                            //alertify.confirm("Would you like to logout and go to the <a href='https://intelleges.com'> Intelleges.com </a> website?", function (result) {
                            //    if (result) {
                            //        window.location.replace("https://intelleges.com");
                            //    }
                            //});
                            alertify.confirm(
                                data.message.split(';')[2],
                                function () {
                                    //alertify.alert('test');
                                    $.post("@Url.Action("GetPPTQIDByID", "Partner")", {
                                        pptqId: data.message.split(';')[1]
                                    })
                                        .done(function (data) {
                                            if (data.message !== null) {
                                                $("#name").val(data.message.name);
                                                $("#address1").val(data.message.address1);
                                                $("#address2").val(data.message.address2);
                                                $("#city").val(data.message.city);
                                                $("#state").val(data.message.state); //ddl
                                                $("#province").val(data.message.province);
                                                $("#zipcode").val(data.message.zipcode);
                                                $("#country").val(data.message.country); //ddl
                                                $("#phone").val(data.message.phone);
                                                $("#fax").val(data.message.fax);
                                                $("#firstName").val(data.message.firstName);
                                                $("#lastName").val(data.message.lastName);
                                                $("#title").val(data.message.title);
                                                $("#email").val(data.message.email);
                                                $("#dunsNumber").val(data.message.dunsNumber);
                                                $("#federalID").val(data.message.federalID);
                                                //$("#group").val(data.message.group); //ddl
                                                //$("#owner").val(data.message.owner); //ddl
                                                //$("#DueDate").val(data.message.dateApproved);
                                            }
                                        });
                                },
                                function () {
                                    $("#internalID").val('');
                                }
                            );
                        }
                        else if (data.message.split(';')[0] == "3") {
                            $('#hdnpptq').val(data.message.split(';')[1].split('-')[1]);
                            $('#hdnAccessCode').val(data.message.split(';')[1].split('-')[0]);

                            $("#dvSuggestContent").html(data.message.split(';')[2]);
                            $("#alertdialog").modal("toggle");
                        }
                    }
                });

        }
        var shadowAcceCode = null;
        var shadowPptq = null;
        function shadow(accessCode, pptq) {
            shadowAcceCode = accessCode;
            shadowPptq = pptq;
            $.post("shadow", { accessCode: accessCode, pptq: pptq }).done(function (result) {
                if (result.status === "") {

                    $("#updateDialog").modal("toggle");
                }
                else if (result.status === 'shadow') {
                    alertify.alert('This access code is already a SHADOW.');
                }
                else if (result.status === "reference") {
                    alertify.set({
                        labels: {
                            ok: "No",
                            cancel: "Yes"
                        },
                        buttonFocus: "cancel"
                    });
                    // button labels will be "Accept" and "Deny"
                    alertify.confirm("The REFERENCE already has SHADOWS. Do you still want to make this REFERENCE a SHADOW?", function (e) {
                        if (e) {
                            // Click no
                        } else {
                            // click yes
                            //  $.post("shadowconfirm", { accessCode: accessCode, pptq: pptq }).done(function (result) { });
                            $("#updateDialog").modal("toggle");
                        }
                    });
                }
            });
    }
    function confirmShadow(accesscode, pptq2) {
        $.post("shadowconfirm", { accessCode: accesscode, pptq: pptq2, shadowaccessCode: shadowAcceCode, shadowpptq: shadowPptq }).done(function (result) {
            alertify.set({
                labels: {
                    ok: "Ok",
                    cancel: "Cancel"
                },
                buttonFocus: "ok"
            });
            alertify.confirm(result.message, function (e) {
                if (e) {
                    $.post("shadowconfirm2", { accessCode: accesscode, pptq: pptq2, shadowaccessCode: shadowAcceCode, shadowpptq: shadowPptq }).done(function (result) { window.location.reload(); });
                } else {
                    // window.location.reload();
                }
            });

        });
    }
        $(document).ready(function () {
            $('#btnSuggestCancel').click(function () {
                $("#internalID").val('');
                $("#alertdialog").modal("toggle");
            });
            $('#btnalertSubmit').click(function () {
                var accessCode = $('#hdnAccessCode').val();
                var pptq = $('#hdnpptq').val();
               
                shadow(accessCode, pptq);
            });
            $('#btnoverride').click(function () {
                $("#alertdialog").modal("toggle");
            });
         
            $('#btnFind').click(function (e) {

               $.post("@Url.Action("FindPartner2", "Partner")", {
                    touchpoint: $('#touchpoint').val(),
                    group: $('#group').val(),
                   // country: $("#internalID").val(),
                    partnertype: $("#partnertype").val(),
                    partnerStatus: $("#partnerStatus").val(),
                    txtInternalIdFind: $("#txtInternalIdFind").val(),
                    txtDunsNumberFind: $("#txtDunsNumberFind").val(),
                    txtNameFind: $("#txtNameFind").val(),
                    txtFederalIdFind: $("#txtFederalIdFind").val(),
                    txtContactEmailFind: $("#txtContactEmailFind").val() ,
                    txtHROEmailFind: $("#txtHROEmailFind").val(),
                    txtZipCodeFind: $("#txtZipCodeFind").val(),
                    accesscode: $("#accesscode").val(),
                   searchType: $("#searchType").val(),
                })
                    .done(function (data) {
                        $('#panelFind').html(data);
                    });

            });
        });
    </script>
}
