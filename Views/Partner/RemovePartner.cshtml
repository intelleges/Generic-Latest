@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.ViewModel.PartnerViewModel>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Partner";
}

<style>
    div#PartnerGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }
</style>

<script>
    //jQuery.noConflict();
    jQuery(document).ready(function () {


        $("form").submit(function () {
            return validateControl();

        });
        function validateControl() {


            if ($('input:checkbox[name$=chkSelect]:checked').length == 0) {
                alertify.alert("Please select atleast one partner");
                return false;
            }

            if ("@ViewBag.searchType" == "Invite") {
                if ($('#DueDate').val() == "") {
                    alertify.alert("Due Date required");
                    return false;
                }



                var user_date = Date.parse($('#DueDate').val());
                var today_date = new Date();
                var diff_date = user_date - today_date;

                var num_years = diff_date / 31536000000;
                var num_months = (diff_date % 31536000000) / 2628000000;
                var num_days = ((diff_date % 31536000000) % 2628000000) / 86400000;
                if (Math.floor(num_days) < -1) {
                    alertify.alert("Due Date can not be less than today");
                    return false;
                }
            }





        }
    });
</script>


<form action="@Url.Content("~/Partner/RemovePartner")" method="post">
    <input id="searchType"  type="hidden" value="@ViewBag.searchType" name="searchType">

    @if (ViewBag.searchType == "Invite")
    {
        @Html.Raw("Due Date :");
        @Html.Telerik().DatePicker().Name("DueDate").HtmlAttributes(new { @style = "width:100px;" })
    }

     @*.ToolBar(commands => commands
               .Custom()
                   .HtmlAttributes(new { id = "go" })
                   .Text("Go")
                   .Action("Go", "Partner").HtmlAttributes(new { onclick = "resotreMultiple(event)" }))*@


    @( Html.Telerik().Grid(Model).Name("PartnerGrid")
         

 .ToolBar(commands =>
            {
                commands.Template("<input style='width: 50px;' type='submit' value='Go' />");
            })

        .Columns(columns =>
        {

            columns.Bound(o => o.IsSelected)

                   .Title("<input type='checkbox' onchange='Selectall();' id='chkSelectAll' style='margin-left: 11px;' name='checkedRecords' value='<#= IsSelected #>' />")
                   .Template(@<text>


    <input type='checkbox' id='chkMessage' name='chkSelect' class="chkPartners" value='@item.id' />

    <input type="hidden"  name='partnertypeID' value='@item.partnertypeID' />

    <input type="hidden"  name='touchpoint' value='@item.campaign' />

    <input type="hidden"  name='AccessCode' value='@item.AccessCode' />

    <input type="hidden"  name='ContactEmail' value='@item.ContactEmail' />

    </text>)
                   .Width(50)
                   .HtmlAttributes(new { style = "text-align:center" }).Sortable(false);


            columns.Bound(o => o.internalID).Title("Internal ID").Width(100).Encoded(false);
            columns.Bound(o => o.PartnerName).Title("Partner Name").Width(400).Template(@<text><a href='#' id='@item.PartnerName' class="menu_block">@item.PartnerName</a>
    <div class="display_menu" style="display: none;">
        <ul>
            <li><a href="javascript:openEditPopup(@item.id)">Edit/Correct</a></li>
            <li><a href="javascript:openRemovePopup(@item.id,'@item.internalID','@item.PartnerName')">Remove</a></li>
            <li><a href="javascript:openArchivePopup(@item.id,'@item.internalID','@item.PartnerName')">Archive</a></li>
            <li><a href="javascript:openViewDetailPopup(@item.id)">View Detail</a></li>
            <li><a href="javascript:openCompletePopup()">Complete</a></li>
        </ul>
    </div>
    </text>);
            columns.Bound(o => o.Contact).Title("Contact").Width(100);
            columns.Bound(o => o.phone).Title("Phone").Width(100);
            columns.Bound(o => o.ContactEmail).Title("Contact Email").Width(200).Template(@<text><a href="javascript://" onclick="OpenManualAddModal('../WrongContact/Index?accesscode=@item.AccessCode');">@item.ContactEmail</a></text>);
            // .FooterTemplate(@<text><input style="width: 80px;" type="submit" value="Go" /></text>);

            columns.Bound(o => o.ContactTitle).Title("Contact Title").Width(200);

            columns.Bound(o => o.owner).Title("Owner").Width(100);
            columns.Bound(o => o.Country).Title("Country").Width(100);
            columns.Bound(o => o.city).Title("City").Width(100);
            columns.Bound(o => o.state).Title("State").Width(100);

            columns.Bound(o => o.address).Title("Address").Width(200);
            columns.Bound(o => o.zipcode).Title("Zipcode").Width(100);

            columns.Bound(o => o.Touchpoint).Title("Touchpoint").Width(100);
            columns.Bound(o => o.Partnertype).Title("Partnertype").Width(100);
            columns.Bound(o => o.Group).Title("Group").Width(100);
            columns.Bound(o => o.AccessCode).Title("AccessCode").Width(100).Template(@<text><a href='#' id='@item.AccessCode' class="menu_block">@item.AccessCode</a><div class="display_menu" style="display: none;">
                <ul>
                    <li><a href="#">Remind
                    </a></li>
                    <li><a href="#">Re-Invite (intelleges.com)</a></li>
                    <li><a href="#">Re-Invite (racix.net)</a></li>
                    <li><a href="#">Rescind</a></li>
                    <li><a href="#">Remove</a></li>
                    <li><a href="#">Retrieve</a></li>
                </ul>
            </div></text>);
            columns.Bound(o => o.status).Title("Status").Width(200);


        })

         //.ClientEvents(events => events.OnDataBound("onDataBound"))
        .DataKeys(keys => keys.Add(o => o.internalID))
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(false))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })



)
</form>
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });


    });

    function resotreMultiple(event) {
        event.preventDefault();
        var arr = [];
        $(".chkPartners:checked").each(function (idx, item) {
            arr.push(parseInt(item.value));
        });
        if (arr.length > 0) {
            $.ajaxSettings.traditional = true
            $.get('@Url.Action("UnArchievePartners", "Partner")', { items: arr }, function (data) {
                if (data == true) {
                    window.location.replace(window.location.href);
                }
            });
        }

    }

    function CloseMe() {
        $("#genericPopup").dialog('close');
        //$(".t-icon .t-refresh").trigger('click');

        window.location.replace(window.location.href);
    }


    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("@Url.Content("~/WrongContact/Index")", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }
    $('#menu_block').hover(function () {
        alert("call");
        $('#display_menu').show();
    }, function () {
        $('#display_menu').hide();
    })

    $('#menu_block').mouseenter(function () {
        $('#display_menu').show();
    }).mouseleave(function () {

        $('#display_menu').hide();

    });

    function openEditPopup(id) {
        $.get("@Url.Content("~/Partner/Edit/")" + id, function (data) {
            $("#genericPopup").html(data);
        });

        $("#genericPopup").dialog({ height: 600, title: "Edit/Correct" });
        $("#genericPopup").dialog('open');
    }

    function openRemovePopup(id, internalid, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Remove " + internalid + " : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Partner/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }


    function openArchivePopup(id, internalid, name) {



        alertify.set({
            labels: {
                ok: "No",
                cancel: "Yes"
            },
            buttonFocus: "cancel"
        });
        // button labels will be "Accept" and "Deny"
        alertify.confirm("You are about to Archive " + internalid + " : " + name + ". Are you sure you want to do this?", function (e) {
            if (e) {
                // Click no
            } else {
                // click yes

                $.get("@Url.Content("~/Partner/Archive/")" + id, function (data) {
                    // $(".t-icon .t-refresh").trigger('click');
                    window.location.replace(window.location.href);
                });

            }
        });


    }

    function openViewDetailPopup(id) {
        $("#genericPopup").html("<p>Loading Data...</p>");
        $.get("@Url.Content("~/Partner/Details/")" + id, function (data) {
            $("#genericPopup").html(data);
        });
        $("#genericPopup").dialog({ height: 600, title: "View Detail" });
        $("#genericPopup").dialog('open');
    }

    function openCompletePopup() {
        $("#genericPopup").html("<h1>Your Complete content goes here</h1>");
        $("#genericPopup").dialog({ height: 500, title: "Complete" });
        $("#genericPopup").dialog('open');
    }





    function Selectall() {
        // if check all is checked, all checkboxes are checked
        // if check all is unchecked, all checkboxes are cleared

        if ($('#chkSelectAll').is(':checked')) {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).attr('checked', 'checked');
                });
        }
        else {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).removeAttr('checked');
                });
        }
    }

    $('input:checkbox[name$=chkSelect]').click(
    function (event) {

        // event.preventDefault();

        // if any of the checkbox is unchecked
        // check all checkbox should be cleared
        if (!$(this).is(':checked')) {
            $('#chkSelectAll').removeAttr('checked');
        }
        else {
            // if all of the checkbox is checked
            // check all checkbox should be checked
            if ($('input:checkbox[name$=chkSelect]').length ==
            $('input:checkbox[name$=chkSelect]:checked').length) {
                $('#chkSelectAll').attr('checked', 'checked');
            }
        }
    });





</script>

