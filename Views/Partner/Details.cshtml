<table style="width:100%">
     <tr>
        <td><input type="button" value="Remove selected" id="removePartnerEvent"/></td>
    </tr>
    <tr>
        <td>
            @( Html.Telerik().Grid((List<Generic.partnerPartnertypeTouchpointQuestionnaire>)ViewBag.events).Name("PartnerEventGrid")
        .Columns(columns =>
        {
            columns.Template(
                @<text> <input type="checkbox" id="@item.id" style="@(item.partNumberSiteZcodePPTQ.Any()?"display:none":"display:inherit")"/> </text>
            ).Width(20);
           // columns.Bound(o => o.accesscode).Title("Internal ID").Width(100);
            columns.Bound(o => o.accesscode).Title("Access Code").Width(100);
            columns.Bound(o => o.priority).Title("Priority").Width(100);


           // columns.Bound(o => o.).Title("Invited by").Width(100);
            columns.Bound(o => o.invitedDate).Title("Invited Date").Width(100);
            columns.Bound(o => o.dueDate).Title("Due Date").Width(100);
             columns.Bound(o => o.completedDate).Title("Completed Date").Width(100);
            columns.Bound(o => o.status).Title("Status").Width(100);
            columns.Bound(o => o.progress).Title("Progress").Width(100);


        })

                   // .Pageable(pager => pager.PageSize(10).Total(200).Enabled(true))
                    .Sortable(sorting => sorting.Enabled(true))

                    .Scrollable(scrolling => scrolling
                       .Enabled(true)
                       .Height(50))
                       .HtmlAttributes(new { @class = "ra" }).HtmlAttributes(new { style = "width:100%;Heigth:300px" }).Footer(false)



            )
        </td>
    </tr>
    @if (Generic.Helpers.CurrentInstance.MultiTenantProjectType == 2)
    {    //displays only for BAA
    <tr>
        <td><input type="button" value="Remove selected" id="removePartNumbers"/></td>
    </tr>
    <tr>
        <td>
            @( Html.Telerik().Grid((List<Generic.partnumber>)ViewBag.partNumbers).Name("partNumbersGrid")
        .Columns(columns =>
        {
            columns.Template(
                @<text> <input type="checkbox" id="@item.id"/> </text>
            ).Width(20);
            columns.Bound(o => o.nationalStockingNumber).Title("Part number").Width(200).Template(@<text>
                <a href="#" id="@item.nationalStockingNumber" class="menu_block">
                    @item.nationalStockingNumber
                </a>
            <div class="display_menu" style="display: none;top: -10px;left: 110px;height: 60px;width: 120px;">
                <ul style="margin-top: 5px;">
                    <li><a href="javascript:DetailsDialog.removePartNumber(@item.id)">Remove</a></li>
                    <li><a href="javascript:DetailsDialog.resetPartNumber(@item.id)">Reset</a></li>
                </ul>
            </div>
            </text>);
            columns.Bound(o => o.description).Title("Description").Width(280);
        })
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(65))
           .HtmlAttributes(new { @class = "ra" }).Footer(false).HtmlAttributes(new { style = "width:100%;Heigth:350px" })
)
        </td>
    </tr>
    }
        
</table>

<script>
    $("#removePartNumbers").click(function () {
        var numbers = [];
        $("#partNumbersGrid input[type='checkbox']:checked").each(function () {

            numbers.push(this.id);
        });
        $.ajax("RemoveStockNumbers", { type: "POST", data: { values: numbers } }).done(function (result) {
            if (result == "True") {
                $("#partNumbersGrid input[type='checkbox']:checked").each(function(){                   
                    $(this).parent().parent().remove();
                });
            }
        });
    });
    $("#removePartnerEvent").click(function () {
        var numbers = [];
        $("#PartnerEventGrid input[type='checkbox']:checked").each(function () {

            numbers.push(this.id);
        });
        $.ajax("RemovePartnersQuestinnarie", { type: "POST", data: { values: numbers } }).done(function (result) {
            if (result == "True") {
                $("#PartnerEventGrid input[type='checkbox']:checked").each(function () {
                    $(this).parent().parent().remove();
                });
            }
        });
    });     
</script>
