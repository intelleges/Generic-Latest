@inherits System.Web.Mvc.WebViewPage<Generic.partner>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = null;  // LayoutHelper.GetLayout();
    ViewBag.Title = "Partner";
}

<style type="text/css">
    .threecol, .twocol {
        width: 100%;
        display: inline-block;
        font-size: 13px!important;
    }

        .twocol .display-label {
            width: 10%;
            display: inline-block;
        }

        .twocol .display-field {
            width: 35%;
            display: inline-block;
        }

        .threecol .display-label {
            width: 10%;
            display: inline-block;
        }

        .threecol .display-field {
            width: 20%;
            display: inline-block;
        }

            .threecol .display-field label {
                width: 90%;
                display: inline-block;
                font-size: 13px!important;
            }

    #PartnerEventGrid {
        font-size: 12px;
    }
</style>



