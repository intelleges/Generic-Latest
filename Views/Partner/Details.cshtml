@( Html.Telerik().Grid((List<Generic.view_EventNotificationData>)ViewBag.events).Name("PartnerEventGrid")
        .Columns(columns =>
        {
            columns.Bound(o => o.description).Title("Description").Width(100).Encoded(false);
           
           
            columns.Bound(o => o.timestamp).Title("Date").Width(100);
           
            


        })
        
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })



)
