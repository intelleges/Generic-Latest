@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Generic.Helpers;
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Find Partner";
}
<style>
    #panelFind select {
        width: 350px;
    }
    #panelFind input {
        width: 350px;
    }

    .form-control {
        margin:5px;
    }

    .txtBox {
        width: 205px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none;
    }

    .t-input {
        height: 16px;
    }

    #panelFind td {
        padding: 0 0 0 0;
    }
    
    #panelFind [type="button"] {
        width: 110px;
        margin: 5px;
    }
    #panelFind [type="submit"] {
        width: 110px;
        margin: 5px;
    }
</style>
<h2>Find Partner</h2>

<script type="text/javascript">
    function clearInputs() {
        $("#panelFind #inputTable input, #panelFind #inputTable select").val("");
    }
        function getDatePicker(){
            var datepicker = $("#DatePicker").data("tDatePicker");
            return datepicker;
        }


    jQuery(document).ready(function () {
        if ('@(ViewBag.Error??"")'.length > 0) {
            alertify.alert('@ViewBag.Error');
        }
            //$(function () {
            //debugger;
            // $("#touchpoint").val($("#touchpoint option:first").val());
            if ($("#touchpoint option[value='@Session["touchpoint"]']").length > 0) {
                $("#touchpoint").val(@Session["touchpoint"]).change();
            }
            else {
                $("#touchpoint").prop("selectedIndex", 1).change();
            }
            $('#touchpoint').change(function () {



                var objtouchpointID = $('#touchpoint').val();


                if (objtouchpointID == "") {
                    objtouchpointID = 0;
                }

                var formData = { touchpointId: objtouchpointID };

                $.ajax({
                    url: "@Url.Content("~/Group/GetGroupByTouchpoint")",
                    type: "post",
                    data: formData,
                    success: function (data) {
                        var len = data.Data.length;
                        var i = 0;
                        var groupSelectList = "<option value=''></option>";
                        for (i = 0; i < len; i++) {
                            groupSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].description + "</option>";
                        }

                        $('#group').html(groupSelectList);


                    },
                    error: function (data) {
                        var touchpointSelectList = "<option value=''></option>";
                        $('#group').html(touchpointSelectList);
                    }
                });



                $.ajax({
                    url: "@Url.Content("~/PartnerType/GetPartnerTypeByTouchpoint")",
                     type: "post",
                     data: formData,
                     success: function (data) {
                         var len = data.Data.length;
                         var i = 0;
                         var partnerTypeSelectList = "<option value=''></option>";
                         for (i = 0; i < len; i++) {
                             partnerTypeSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].description + "</option>";
                         }

                         $('#partnertype').html(partnerTypeSelectList);


                     },
                     error: function (data) {
                         var partnerTypeSelectList = "<option value=''></option>";
                         $('#partnertype').html(partnerTypeSelectList);
                     }
                 });

            });
        $('#txtInternalIdFind').change(function () {
            if ($('#hdnSearch').val() == "") {
                $.post("@Url.Action("ValidatePartner", "Partner")", {
                    internalID: $("#txtInternalIdFind").val(),
                    acccessCode: $('#accesscode').val()
                }).done(function (response) {
                    if (response.message != "") {
                        alertify.set({
                            labels: {
                                ok: "Yes", cancel: "No"
                            }
                        });
                        alertify.confirm(response.message, function (result) {
                            if (result) {
                                $.post("@Url.Action("ActivatePartner", "Partner")", {
                                    internalID: $("#txtInternalIdFind").val(),
                                    acccessCode: $('#accesscode').val()
                                }).done(function (resp) {
                                });
                            }
                        });
                    }
                });
            }
            });
        $('#accesscode').change(function () {
            if ($('#hdnSearch').val() == "") {
                $.post("@Url.Action("ValidatePartner", "Partner")", {
                    internalID: $("#txtInternalIdFind").val(),
                    acccessCode: $('#accesscode').val()
                }).done(function (response) {
                    if (response.message != "") {
                        alertify.set({
                            labels: {
                                ok: "Yes", cancel: "No"
                            }
                        });
                        alertify.confirm(response.message, function (result) {
                            if (result) {
                                $.post("@Url.Action("ActivatePartner", "Partner")", {
                                    internalID: $("#txtInternalIdFind").val(),
                                    acccessCode: $('#accesscode').val()
                                }).done(function (resp) {
                                });
                            }
                        });
                    }
                });
            }
        });
        });

</script>

<form id="FindpartnerForm" method="post" enctype="multipart/form-data">
    <input type="hidden" id="hdnSearch" value="@ViewBag.searchType" />
    <div id="panelFind" class="row">

        <input id="searchType" type="hidden" value="@ViewBag.searchType" name="searchType">
        <div class="col-lg-8">
            <table width="70%;" id="inputTable" style="float:left" border="0">
                <tbody>
                    <tr>
                        <td class="tLeftColumn form-label">Touchpoint </td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("touchpoint", null, String.Empty, new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Type</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("partnertype", null, String.Empty, new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Status</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("partnerStatus", null, String.Empty, new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">
                            <span id="lblGroupFind">Group</span>
                        </td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("group", null, String.Empty, new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Name</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtNameFind" class="form-control" type="text" name="txtNameFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Internal ID (EID)</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtInternalIdFind" class="form-control" type="text" name="txtInternalIdFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Access Code</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="accesscode" class="form-control" type="text" name="accesscode">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Contact Email</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtContactEmailFind" class="form-control" type="text" name="txtContactEmailFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">HRO Email</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtHROEmailFind" class="form-control" type="text" name="txtHROEmailFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">DUNS Number</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtDunsNumberFind" class="form-control" type="text" name="txtDunsNumberFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Federal ID</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            <input id="txtFederalIdFind" class="form-control" type="text" name="txtFederalIdFind">
                        </td>
                    </tr>

                    <tr>
                        <td class="tLeftColumn form-label">Zip Code</td>
                        <td width="5%"></td>
                        <td class="tRightColumn">
                            <input id="txtZipCodeFind" class="form-control" type="text" name="txtZipCodeFind">
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn">Country</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("country", null, string.Empty, htmlAttributes: new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tLeftColumn form-label">Owner</td>
                        <td class="tCenterColumn"></td>
                        <td class="tRightColumn">
                            @Html.DropDownList("owner", null, string.Empty, htmlAttributes: new { @class = "form-control" })
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>
        <div class="col-lg-4">
            <table style="float:left">
                <tr>
                    <td></td>
                    <td>

                        <input id="btnFind" class="btn btn-default" value="Find" type="submit" name="btnFind">
                        &nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="btnCancel" class="btn btn-default" value="Cancel" type="button" name="btnCancel">
                    </td>
                </tr>
                <tr>
                    <td></td>
                    <td>
                        <input type="button" value="Clear" onclick="clearInputs()" class="btn btn-default">
                    </td>
                </tr>
                <tr>
                    <td></td>
                    <td>
                        <input type="button" value="Upload" class="btn btn-default">
                        &nbsp;&nbsp;&nbsp;&nbsp;  <a href="#">Download Template</a>
                    </td>
                </tr>

            </table>
        </div>
    </div>

</form>
