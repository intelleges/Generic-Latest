@inherits System.Web.Mvc.WebViewPage
@using System.Web.Mvc;
@using System.Web.Mvc.Html;
@using Generic.Helpers;
@using Telerik.Web.Mvc.UI;
@using System.Web.Optimization;
@{
    Layout = LayoutHelper.GetPopupLayout();
    ViewBag.Title = "Find Partner";
}
<style>
    .dropDown {
        width: 210px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 20px;
        font-size: 13px;
        font-family: Arial;
    }

    .txtBox {
        width: 205px;
        border-style: inset;
        border-left-width: 2px;
        border-top-width: 2px;
        height: 15px;
        border-bottom: none;
        border-right: none;
    }
</style>
<h2>Find Partner</h2>

<script type="text/javascript">
        function getDatePicker(){
            var datepicker = $("#DatePicker").data("tDatePicker");
            return datepicker;
        }


        jQuery(document).ready(function () {
            //$(function () {
            $('#touchpoint').change(function () {

              

                var objtouchpointID = $('#touchpoint').val();
             

                if (objtouchpointID == "") {
                    objtouchpointID = 0;
                }

                var formData = { touchpointId: objtouchpointID };

                $.ajax({
                    url: "@Url.Content("~/Group/GetGroupByTouchpoint")",
                    type: "post",
                    data: formData,
                    success: function (data) {
                        var len = data.Data.length;
                        var i = 0;
                        var groupSelectList = "<option value=''></option>";
                        for (i = 0; i < len; i++) {
                            groupSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].description + "</option>";
                        }

                        $('#group').html(groupSelectList);


                    },
                    error: function (data) {
                        var touchpointSelectList = "<option value=''></option>";
                        $('#group').html(touchpointSelectList);
                    }
                });



                $.ajax({
                    url: "@Url.Content("~/PartnerType/GetPartnerTypeByTouchpoint")",
                     type: "post",
                     data: formData,
                     success: function (data) {
                         var len = data.Data.length;
                         var i = 0;
                         var partnerTypeSelectList = "<option value=''></option>";
                         for (i = 0; i < len; i++) {
                             partnerTypeSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].description + "</option>";
                         }

                         $('#partnertype').html(partnerTypeSelectList);


                     },
                     error: function (data) {
                         var partnerTypeSelectList = "<option value=''></option>";
                         $('#partnertype').html(partnerTypeSelectList);
                     }
                 });

            });
        });

</script>

<form id="FindpartnerForm" method="post" enctype="multipart/form-data">
 
    <div id="panelFind">
        <table width="100%" border="0">
            <tbody>
                <tr>
                    <td class="tLeftColumn">Campaign </td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                         @Html.DropDownList("touchpoint", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">
                        <span id="lblGroupFind">Group</span>
                    </td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        @Html.DropDownList("group", String.Empty)


                   

                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Internal ID (EID)</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtInternalIdFind" class="txtBox" type="text" name="txtInternalIdFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">DUNS Number</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtDunsNumberFind" class="txtBox" type="text" name="txtDunsNumberFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Name</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtNameFind" class="txtBox" type="text" name="txtNameFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Federal ID</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtFederalIdFind" class="txtBox" type="text" name="txtFederalIdFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Contact Email</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtContactEmailFind" class="txtBox" type="text" name="txtContactEmailFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">HRO Email</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtHROEmailFind" class="txtBox" type="text" name="txtHROEmailFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Zip Code</td>
                    <td width="5%"></td>
                    <td class="tRightColumn">
                        <input id="txtZipCodeFind" class="txtBox" type="text" name="txtZipCodeFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Country</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                            @Html.DropDownList("country", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Type</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                          @Html.DropDownList("partnertype", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Status</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        @Html.DropDownList("partnerStatus", String.Empty)
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Score Between </td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtScoreFromFind" class="txtBox" type="text" style="width: 60px;" name="txtScoreFromFind">
                        &
                        <input id="txtScoreToFind" class="txtBox" type="text" style="width: 60px;" name="txtScoreToFind">
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">Added Between</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                             @Html.Telerik().DatePicker().Name("txtAddedFromFind")
                      
                        &

                         @Html.Telerik().DatePicker().Name("txtAddedToFind")

                        
                    </td>
                </tr>
                <tr>
                    <td class="tLeftColumn">FULL TEXT SEARCH</td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        <input id="txtFullTextSearch" class="txtBox" type="text" style="width: 250px;" name="txtFullTextSearch">
                    </td>
                </tr>
                 <tr>
                    <td class="tLeftColumn"></td>
                    <td class="tCenterColumn"></td>
                    <td class="tRightColumn">
                        
                        <input id="btnFind" class="txtBox" value="Find" type="submit" style="width: 100px; height:22px" name="btnFind">
                        &nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="btnCancel" class="txtBox" value="Cancel"  type="button" style="width: 100px; height:22px" name="btnCancel">

                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</form>
