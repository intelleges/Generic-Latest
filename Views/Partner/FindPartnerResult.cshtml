    function summarize(accessCode, internalID, touchpoint, partnerName) {
        $("#genericPopup").html("<p>Loading Data...</p>");
         $.get('@Url.Content("~/Partner/SummarizeAsync")' + '?accesscode=' + accessCode + '&internalID=' + internalID + '&touchpoint=' + touchpoint + '&partner=' + partnerName, function (data) {
             if (data) {
                $("#genericPopup").html(data.data);
			} else {
				alertify.alert("Something went wrong, please try again later");
			}
		});
		$("#genericPopup").dialog({ height: 600, title: "Summarize" });
		$("#genericPopup").dialog('open');

    }

    var itemsForPrint = [];
    function printNextPdf(item) {
        if (item.status == 6 || item.status == 7 || item.status == 13) {
            alertify.confirm('The current status for ' + item.touchpoint + ' is ' + item.statusDesc + ' for ' + item.partnerName+'. Would youlike to send a reminder?', function (e) {
					if (e) {
						// click yes
                        remind(item.accesscode);
                        var index = itemsForPrint.indexOf(item);
                        if (index >= 0 && index < itemsForPrint.length - 1)
                            printNextPdf(itemsForPrint[index + 1]);

					} else {
						// click no
                        var index = itemsForPrint.indexOf(item);
                        if (index >= 0 && index < itemsForPrint.length - 1)
                            printNextPdf(itemsForPrint[index + 1]);
					}
				});
        }
        else {
            setTimeout(function () {
                 $('#yourLinkID').attr('href', "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + item.accesscode);
                 document.getElementById('yourLinkID').click();
            }, 1000);

             var index = itemsForPrint.indexOf(item);
             if (index >= 0 && index < itemsForPrint.length - 1) {

                 alertify.confirm('You have printed PDF for ' + item.touchpoint + ', would you like to print PDF for ' + itemsForPrint[index + 1].touchpoint +'?', function (e) {
                     if (e) {
                         // click yes
                         printNextPdf(itemsForPrint[index + 1]);

                     } else {
                         // click no
                     }
                 });
             }
        }
    }

    var htmlInfo = "";
    function checkToPrintPDF(pptqId, status, touchpoint) {
        var self = this;
        $.getJSON('@Url.Content("~/Partner/PartnertypeTouchpointQuestionnaireCampaignStatus3")', { pptqId: pptqId, status: status, touchpoint: touchpoint }, function (data) {
            if (status === 14) {
                alertify.alert(data.message, function () {
                      checkToPrintPDF(data.pptqId, data.status, data.touchpoint);
    		    });
            }
            else if (data.items.length > 1) {
                itemsForPrint = data.items;
                printNextPdf(data.items[0]);
            }
            else if (data.msg != null) {
                alertify.alert(data.msg, function () {
    			window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + data.accessCode;
    		    });

            }
			else if (data.iscanprintPdf == true) {
				window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + data.accessCode;
			}
			else if (data.message.next == 6) {
				alertify.alert(data[0].nextStep);
			}
			else if (data.message.next == 5) {
				alertify.alert(data.message.nextStep);
			}
			else if (data.message.next == 4) {
				alertify.alert(data.message.nextStep);
			}
			else if (data.message.next == 3) {
				alertify.confirm(data.message.nextStep, function (e) {
					if (e) {
						// click yes
						window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + data.accessCode;

					} else {
						// click no
					}
				});
			}
		else if (data.message.next == 2) {
			alertify.confirm(data.message.nextStep, function (e) {
				if (e) {
					// click yes
					remind(data.accessCode);

				} else {
					// click no
				}
			});
		}
            else if (data.message.next == 1) {
                var html = '<div style="text-align:left;">';
                html += ' <input type="radio" style="width:30px;" id="choiseSelect" checked name="choiseSelect" value="1" >' + data.message.nextStep + '<br/>';
                if (data.message.newStatus == 10) {
                    html += ' <input type="radio" style="width:30px;" id="choiseSelect" name="choiseSelect" value="2" >Print the pending approval PDF<br/>';
                    html += ' <input type="radio" style="width:30px;" id="choiseSelect" name="choiseSelect" value="3" >Approve this supplier<br/>';
                    html += ' <input type="radio" style="width:30px;" id="choiseSelect" name="choiseSelect" value="4" >Reject this supplier<br/>';
                }

                html += '</div>';
                alertify.confirm(html, function (e) {
				if (e) {
                    var val = $("input[name='choiseSelect']:checked").val();
                    if (val === '1')
                        remind(data.accessCode);
                    else if (val === '2') {
                        window.location.href = "@Url.Content("~/Partner/PrintPDF/?accesscode=")" + data.accessCode;
                    }
                    else if (val === '3') {
                        $.post("Approve", { accessCode: data.accessCode }).done(function (result) { });
                    }
                    else if (val === '4') {
                        $.post("Reject", { accessCode: data.accessCode }).done(function (result) { });
                    }

				} else {
					// click no
				}
			});
		}
            else {
				alertify.alert(data.message.nextStep);
			if (data.message.next > 6) {
                checkToPrintPDF(data.message.next, status, touchpoint);
			}
		}
		}).fail(function (jqXHR, textStatus, errorThrown) {
			debugger;
			alertify.alert('Error getting Touch Point!');
		});
    }

    function copyHtmlContent() {
        this.htmlInfo = $('#print-content').text();
        navigator.clipboard.writeText(htmlInfo);
    }

	function checkToPrintHTML(status, accesscode) {
		if (status.toLowerCase() == 'responded/complete') {
			window.location.href = "@Url.Content("~/Partner/PrintHTML/?accesscode=")" + accesscode;
		} else {
			alert("it's not responded yet");
		}
	}

	function ExecuteResponses(acceessCode, pptqId) {
		$.getJSON("CheckResponses", { pptqId: pptqId }, function (data) {
			if (data) {
				if (data === true) {
					window.location.href = '@Url.Action("GetResponses")' + '?pptqId=' + pptqId;
				} else {
					alertify.confirm(data, function (result) {

						if (result) {
							remind(acceessCode);
						} else {
							if (data.startsWith("Currently, there are only partitial (incomplete) data available for"))
								alertify.confirm("Would you like to print partitial response?", function (endgeResult) {
									if (endgeResult) {
										window.location.href = '@Url.Action("GetResponses")' + '?pptqId=' + pptqId;
									}
								});

						}
					});
				}
			} else {
				alertify.alert('There is no response data available for shadows. Please access the REFERENCE and try again');
			}
		});
    }

        function sendEmailByPptq(nextIndex, progressbar, progressLabel, pptqs) {
			$.post('@Url.Action("SendRemind", "Partner")', {
                pptqId: pptqs[nextIndex],
				touchpointId: "@ViewBag.TouchpointId",
				partnerTypeId: "@ViewBag.PartnerTypeId",
				statusId: "@ViewBag.StatusId"
			}).done(function (result) {
				var val = progressbar.progressbar("value") || 0;
                var v = (nextIndex + 1) / pptqs.length * 100;
				progressbar.progressbar("value", v);

				$('.fancybox-inner #progress-note').html(result.message)

                if (pptqs.length > nextIndex + 1) {
                    sendEmailByPptq(nextIndex + 1, progressbar, progressLabel, pptqs);
				}
				else {
					$.fancybox.close();
					alertify.alert("You have sent out " + (nextIndex + 1) + " Messages");
				}
			});
		}


	$(function () {
        $(".t-widget.t-dropdown.t-header").css("width", "100%");

         $('#btnRemind').click(function (e) {
              	alertify.set({
				labels: {
					ok: "No",
					cancel: "Yes"
				},
				buttonFocus: "cancel"
			});
                alertify.confirm("You are about to send out @ViewBag.CountPPtq, are you sure?", function (e) {
				if (e) {
					// Click no
                } else {
                    alertify.set({
                        labels: {
                            ok: "Ok",
                            cancel: "Cancel"
                        },
                        buttonFocus: "ok"
                    });
                    var pptqs = JSON.parse('@Html.Raw(pptqStr)');
                    $.fancybox({
                        'content': $('#send-email-progress').html(),
                        closeBtn: false,
                        closeClick: false,
                        modal: true,
                        type: 'html',
                        minWidth: 400,
                        minHeight: 150
                    });

                    var progressbar = $(".fancybox-inner #progressbar"),
                        progressLabel = $(".fancybox-inner .progress-label");

                    progressbar.progressbar({
                        value: false,
                        change: function () {
                            progressLabel.text(Number(progressbar.progressbar("value")).toFixed(2) + "%");
                        },
                        complete: function () {
                            progressLabel.text("Complete!");
                        }
                    });

                    sendEmailByPptq(0, progressbar, progressLabel, pptqs);
					// click yes

				}
			});

            });
	});
	$("#changePtqBtn").click(function () {

	})
</script>
