            columns.Bound(o => o.internalID).Title("Internal ID").Width(150).Encoded(false);
            columns.Bound(o => o.PartnerName).Title("Partner Name").Width(250).Template(@<text>
                @{

                    var columnData = item.PartnerName;
                    var width = 30;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
                    }
                    <a href='#' id='@item.PartnerName' class="menu_block" title="@columnData">@visibleText</a>
                }
                <div class="display_menu" style="display: none;">
                    <ul>

                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu?"none":"inherit")'><a href="javascript:openEditPopup(@item.id)">Edit/Correct</a></li>
                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu||Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="javascript:openRemovePopup(@item.id,'@item.internalID','@item.PartnerName')">Remove</a></li>
                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu||Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="javascript:openArchivePopup(@item.id,'@item.internalID','@item.PartnerName')">Archive</a></li>
                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu||Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="javascript:openViewDetailPopup(@item.id)">View Detail</a></li>
                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu||Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="@item.Expr1" target="_blank">Complete</a></li>

                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="javascript:checkToPrintPDF('@item.status','@item.AccessCode')">Print PDF</a></li>

                        <li style='display:@(Generic.SessionClass.SessionSingleton.ShouldDisplayMenu||Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAA?"none":"inherit")'><a href="javascript:checkToPrintHTML('@item.status','@item.AccessCode')">Print HTML</a></li>
                        @if (Generic.SessionClass.SessionSingleton.ShouldDisplayMenuBAAFull)
                        {
                            <li><a href="javascript:remind('@item.AccessCode')">Remind</a></li>
                        }
                        <li><a href="javascript:changePTQ('@item.AccessCode')">Change PTQ</a></li>
                        <li>@Html.ActionLink("Docs", "PartnerDocuments", "Partner", new { accessCode = item.AccessCode }, new { target = "_blank" })</li>
