            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.city).Title("City").Width(100).Template(@<text>

        @{
            var columnData = item.city;
            var width = 10;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.state).Title("State").Width(50).Template(@<text>

        @{
            var columnData = item.state;
            var width = 5;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>); ;

            columns.Bound(o => o.address).Title("Address").Width(150).Template(@<text>

        @{
            var columnData = item.address;
            var width = 20;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.zipcode).Title("Zipcode").Width(80).Template(@<text>

        @{
            var columnData = item.zipcode;
            var width = 10;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);

            columns.Bound(o => o.Touchpoint).Title("Touchpoint").Width(150).Template(@<text>

        @{
            var columnData = item.Touchpoint;
            var width = 25;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.Partnertype).Title("Partnertype").Width(120).Template(@<text>

        @{
            var columnData = item.Partnertype;
            var width = 20;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.Group).Title("Group").Width(70).Template(@<text>

        @{
            var columnData = item.Group;
            var width = 7;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.phone).Title("Phone").Width(100);
            columns.Bound(o => o.status).Title("Status").Width(150).Template(@<text>

                @{
                    var columnData = item.status;
                    var width = 20;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
                    }
                    <p title="@columnData">@visibleText</p>
                }


            </text>); ;


        })
                        .DataKeys(keys => keys.Add(o => o.internalID))
                        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
                        .Sortable(sorting => sorting.Enabled(true))

                        .Scrollable(scrolling => scrolling
                        .Enabled(true)
                        .Height(380))
                        .HtmlAttributes(new { @class = "ra" })



)

<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>
<div id="genericPopup" title=""></div>
