                </div>
            </text>);
            columns.Bound(o => o.Contact).Title("Contact").Width(150).Template(@<text>

        @{
            var columnData = item.Contact;
            var width = 30;
            var visibleText = string.Empty;
            if (columnData != null)
            {
                visibleText = columnData.Length > width ? @columnData.Substring(0, width) + "..." : columnData;
            }
            <p title="@columnData">@visibleText</p>
        }


            </text>);
            columns.Bound(o => o.AccessCode).Title("AccessCode").Width(90).Template(@<text>

