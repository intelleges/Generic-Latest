            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span aria-hidden="true">&times;</span><span class="sr-only"></span>
                        </button>
                        <h4 class="modal-title" id="gpsLabel">Add a document</h4>
                    </div>
                    <div class="modal-body">
                        <form id="model-upload-manual">
                            <div class="form-group">
                                <label class="control-label col-sm-4" for="manualuploadfile">Choose a file</label>
                                <div class="clear-fix"></div>
                                <input type="file" class="form-control" id="manualuploadfile" name="manualuploadfile" accept="application/pdf" data-val-required="*" data-val="true" />
                                <label>Upload PDF only(less than 2MB)</label>
                            </div>
                            <div class="form-group">
