    function ManualUpload(accessCode, pptq) {
        $.get('@Url.Content("~/Partner/getPartnerPartnertypeTouchpointQuestionnaireStatusByPPTQ")' + '?pptq=' + pptq, function (data) {
            if (data.response.StatusId === 6 || data.response.StatusId === 7){
                ProcessManualUpload(accessCode, pptq);
			} else {
                alertify.alert("You’re not permitted to add files manually for " + accessCode + " with " + data.response.StatusText + " status. Please contact your system administrator.");
			}
		});
    }

    function ProcessManualUpload(accessCode, pptq) {
        alertify.confirm("Are you sure? After you upload valid document this will set " + accessCode + " to status RESPONDED COMPLETE.", function (e) {
            if (e) {
                // click yes
                ShowManualUploadDailog(accessCode, pptq);

            } else {
                // click no
            }
        });
    }

    function ShowManualUploadDailog(accessCode, pptq) {
        $('div#manual_upload_dialog #manual-upload-accesscode').val(accessCode);
        $('div#manual_upload_dialog #manual-upload-pptq').val(pptq);
        $('div#manual_upload_dialog #txt-manual-upload-comment').val('');
        $('div#manual_upload_dialog #manualuploadfile').val(null);
        $('#manual_upload_dialog').modal('show');
    }

    $(document.body).on('click', 'div#manual_upload_dialog #btnUploadManual', function (e) {
        if ($('div#manual_upload_dialog #manualuploadfile').val()) {
            var formData = new FormData();
            var pdfFile = $('div#manual_upload_dialog #manualuploadfile')[0].files[0];
            formData.append('pdfFile', pdfFile);
            formData.append('comment', $('div#manual_upload_dialog #txt-manual-upload-comment').val());
            formData.append('accessCode', $('div#manual_upload_dialog #manual-upload-accesscode').val());
            formData.append('pptq', $('div#manual_upload_dialog #manual-upload-pptq').val());
            $.ajax({
            type: "POST",
            url: '@Url.Action("UploadManaul", "Partner")',
            data: formData,
            dataType: 'json',
            contentType: false,
            processData: false,
                success: function (response) {
                    if (response.data) {
                        $('#manual_upload_dialog').modal('hide');
                        alertify.alert("Manual PDF Uploaded.");
                    }
            },
            error: function (error) {
            }
        });
        }
    });

	function remind(accessCodeValue) {
		$.post("Remind", { accessCode: accessCodeValue }).done(function (result) {

			if (result) {
				alertify.alert(result);
			}
		});
	}

	function sms(accessCode) {
		$.post("SendRemindSms", { accessCode: accessCode }).done(function (result) {
			if (result) {
