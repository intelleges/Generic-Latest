        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }

    #madalEmailForm .table td[colspan='5'] {
        text-align: center;
    }
</style>
