@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.Models.PartnerExternalDocModel>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Partner documents";
}

<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
   #partnersExternalDocsGrid, #partnersInternalDocGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }

    .btnprocess {
        height: 21px !important;
        line-height: 4px !important;
        font-size: 100% !important;
    }

    .input_size {
        font-size: 11px !important;
        padding: 1px !important;
        position: relative;
        top: 2px;
    }
</style>
@(Html.Telerik().Grid(Model).Name("partnersExternalDocsGrid").Columns(conf =>
                    {
                        conf.Bound(o => o.title).Title("Title").Template(
                            @<text>
@Html.ActionLink(item.title, "DownloadPdf", new { id = item.id, accessCode = Request["accessCode"] }, new {title="Click to download", target="_blank" })
                             </text>
                        );
                        conf.Bound(o => o.uploadedFileType).Title("Doc type");
                        conf.Bound(o => o.updatedBy).Title("Partner");
                    }).Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
                        .Sortable(sorting => sorting.Enabled(true))

                        .Scrollable(scrolling => scrolling
                        .Enabled(true)
                        .Height(170)).ToolBar(commands =>
    {
        commands.Template("<form method='post' enctype='multipart/form-data' action='" + @Url.Action("ExportExternalDocs", "Partner", new { accessCode = Request["accessCode"] }) + "'><a class='t-button' href='" + @Url.Action("ExportExternalDocs", "Partner", new { accessCode = Request["accessCode"] }) + "' id='export'>Export to Excel</a></form>");
    })
)

@(Html.Telerik().Grid<Generic.Models.ShowDocsModel>().DataBinding(conf => conf.Ajax().Select("ShowDocs", "Partner", new { accessCode = Request["accessCode"] })).Name("partnersInternalDocGrid").Columns(conf =>
                    {
                        conf.Bound(o => o.title).Title("Title").ClientTemplate("<a href='#' id='InternalMenu<#=Id#>' class=\"menu_block\" title=\"<#=title#>\"><#=title#></a><div class=\"display_menu\" style=\"display: none;\"><ul><li ><a href=\"#\">Review</a></li><li ><a href=\"#\">Remove</a></li><li ><a href=\"#\">Replace</a></li><li><a href=\"#\">Redline</a></li></ul></div>"

);
                        conf.Bound(o => o.doctype).Title("Doc type");
                        conf.Bound(o => o.uploadDateTime).Title("Upload date");
                        conf.Bound(o => o.uploadedBy).Title("Uploaded by");
                    }).Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
                        .Sortable(sorting => sorting.Enabled(true))

                        .Scrollable(scrolling => scrolling
                        .Enabled(true)
                            .Height(170)).ToolBar(commands =>
    {
        commands.Template("<form method='post' enctype='multipart/form-data' action='" + @Url.Action("PartnerDocuments", "Partner", new { accessCode = this.Request["accessCode"] }) + "'><a class='t-button' href='" + @Url.Action("ExportInternalDocs", "Partner", new { accessCode = this.Request["accessCode"] }) + "' id='export'>Export to Excel</a><input type='file' id='file'  name='file' class='input_size'  id='newDocFile'/><input type='submit' class='btnprocess t-button' value='Upload'></input></form>");
    })
)
