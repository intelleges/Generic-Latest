<script>
    jQuery(document).ready(function () {
        $("#touchpoint").change(function () {
            var touchpoint = $("#touchpoint").val();
            var defaultOption = "<option value>Select Partner Type</option>";
            if (touchpoint) {
                $.getJSON("GetPartnerTypes/" + touchpoint).done(function (result) {
                    if (result) {
                        var len = result.length;
                        var i = 0;
                        for (i = 0; i < len; i++) {
                            defaultOption += "<option value='" + result[i].id + "'>" + result[i].name + "</option>";
                        }

                        $('#partnertype').html(defaultOption);
                    }
                });
            }
            else $("#partnertype").html(defaultOption);
        });
        $('#protocol').change(function () {
            var objProtocolID = $('#protocol').val();
            var formData = { protocolId: objProtocolID };
            if (objProtocolID == "") {
                var touchpointSelectList = "<option value=''>-Select-</option>";
                $('#touchpoint').html(touchpointSelectList);
                return;
            }
            $.ajax({
                url: "@Url.Content("~/touchpoint/GetTouchPointWithTitleByprotocolId")",
                    type: "post",
                    data: formData,
                    success: function (data) {
                        var len = data.Data.length;
                        var i = 0;
                        var touchpointSelectList = "<option value=''></option>";
                        for (i = 0; i < len; i++) {
                            touchpointSelectList += "<option value='" + data.Data[i].id + "'>" + data.Data[i].title + "</option>";
                        }

                        $('#touchpoint').html(touchpointSelectList);
                        $('#touchpointDiv').show();

                    },
                    error: function (data) {
                        var touchpointSelectList = "<option value=''> -Select-</option>";
                        $('#touchpoint').html(touchpointSelectList);
                    }
                });
            });
            if ("@ViewBag.Message" == "1") {
                debugger;
                alertify.set({
                    labels: {
                        ok: "Invite Later", cancel: "Invite Now"
                    }
                });
                alertify.confirm("", function (e) {
                    if (e) {
                        // Click no
                    } else {
                        // click yes  
                        $.ajax({
                            url: "@Url.Content("~/partner/InvitePartners")",
                            type: "post",
                            success: function (data) {

                                alertify.set({
                                    labels: {
                                        ok: "ok", cancel: "cancel"
                                    }
                                });

                                //dataClear();
                                alertify.alert(data.Data.message);
                                $('#alertify-ok').text('OK');
                                var len = data.EventNotification.length;
                                $('#btnInviteList').show();
                                if (len == 0) {
                                    alertify.alert("Please wait, data processing");
                                    $('#alertify-ok').text('OK');
                                } else {

                                    var events = "<table><tr><td>Email</td><td>Loadgroup</td><td>Accesscode</td><td>Event</td><td>Reason</td><td>Protocol Touchpoint</td><td>Date</td></tr>";
                                    for (i = 0; i < len; i++)
                                        events += "<tr><td>" + data.EventNotification[i].email + "</td><td>" + data.EventNotification[i].loadgroup + "</td><td>" + data.EventNotification[i].accesscode + "</td><td>" + data.EventNotification[i].event + "</td><td>" + data.EventNotification[i].reason + "</td><td>" + data.EventNotification[i].protocolTouchpoint + "</td><td>" + data.EventNotification[i].timestamp + "</td></tr>";


                                    $('#DivEventNotification').html(events);
                                }

                            },
                            error: function (data) {

                            }
                        });
                    }
                });
            }
            if ("@ViewBag.Message" == "2") {

                alertify.alert('@ViewBag.MessageDetail');
                dataClear();
            }
            if ("@ViewBag.Message" == "error") {

                alertify.alert('@ViewBag.MessageDetail');
                dataClear();
            }


            $('#btnInvite').click(function (e) {
                e.preventDefault();
            });

            $('#btnInviteList').click(function (e) {
                e.preventDefault();
                $.ajax({
                    url: "@Url.Content("~/partner/InvitePartnersList")",
                    type: "post",
                    success: function (data) {
                        var len = data.EventNotification.length;

                        if (len == 0) {
                            alertify.alert("Please wait, data processing");
                        } else {

                            var events = "<table><tr><td>Email</td><td>Loadgroup</td><td>Accesscode</td><td>Event</td><td>Reason</td><td>Protocol Touchpoint</td><td>Date</td></tr>";
                            for (i = 0; i < len; i++)
                                events += "<tr><td>" + data.EventNotification[i].email + "</td><td>" + data.EventNotification[i].loadgroup + "</td><td>" + data.EventNotification[i].accesscode + "</td><td>" + data.EventNotification[i].event + "</td><td>" + data.EventNotification[i].reason + "</td><td>" + data.EventNotification[i].protocolTouchpoint + "</td><td>" + data.EventNotification[i].timestamp + "</td></tr>";


                            $('#DivEventNotification').html(events);
                        }
                    },
                    error: function (data) {
                        alertify.alert(data.Data.message);
                    }
                });
            });

            $('#btnInvitelater').click(function (e) {
                e.preventDefault();
                $.ajax({
                    url: "@Url.Content("~/partner/InvitePartnersLater")",
                    type: "post",
                    success: function (data) {
                        alertify.alert(data.Data.message);

                    },
                    error: function (data) {
                        alertify.alert(data.Data.message);
                    }
                });
            });

            $("#btnClear").click(function (e) {
                dataClear();
            });

            function dataClear() {
                $("#name").val("");
                $("#internalID").val("");
                $("#address1").val("");
                $("#address2").val("");
                $("#city").val("");
                $("#state").val("0");
                $("#province").val("");
                $("#zipcode").val("");
                $("#country").val("0");
                $("#phone").val("");
                $("#fax").val("");
                $("#firstName").val("");
                $("#lastName").val("");
                $("#title").val("");
                $("#email").val("");
                $("#dunsNumber").val("");
                $("#federalID").val("");
                $("#owner").val("");
                $("#author").val("");
                $("#protocol").val("");
                $("#touchpoint").val("");
                $("#partnertype").val("");
                $("#group").val("");
                $("#DueDate").val("");
            }
        });
        function doSomething() {

        }

        $("#btnConfirm").click(function () {
            debugger;
            alertify.alert('you choose Confirm');
        });

        $("#btnConfirmlater").click(function () {
            debugger;
            alertify.alert('you choose Confirm Later');
        });
</script>
