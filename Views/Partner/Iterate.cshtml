            }
            if ($("#zipcode").val() === "") {
                alertify.alert("Zip Code is required");
                return false;
            }
            if ($("#country").val() === "") {
                alertify.alert("Country is required");
                return false;
            }
            if ($("#phone").val() === "") {
                alertify.alert("Phone is required");
                return false;
            }
            if ($("#title").val() === "") {
                alertify.alert("Title is required");
                return false;
            }
            if ($("#dunsNumber").val() === "") {
                alertify.alert("DUNS Number is required");
                return false;
            }
            if ($("#dunsNumber").val() === "") {
                alertify.alert("DUNS Number is required");
                return false;
            }
        }
        $("#searctText").keypress(function (event) {
            if (event.which == 13) {
                seacrhPartner();
            }
        });
        $("#btnSearch").click(function () {
            seacrhPartner();
        });
        function ShowPartnerFindLoader() {
            $(".loader").show();
        }
        function HidePartnerFindLoader() {
            $(".loader").hide();
        }
        function rowSelected(row) {
            $('#tblPartners tbody tr').removeClass("info");
            $(row).addClass("info");
            for (var i = 0; i < iterate.data.length; i++) {
                if (iterate.data[i].id == $(row).data().partnerid) {
                    $("#name").val(iterate.data[i].PartnerName);
                    $("#internalID").val(iterate.data[i].internalID);
                    $("#address1").val(iterate.data[i].address);
                    $("#phone").val(iterate.data[i].phone);
                    $("#city").val(iterate.data[i].city);
                    $("#state").val(iterate.data[i].state);
                    $("#zipcode").val(iterate.data[i].zipcode);
                    var names = iterate.data[i].Contact.split(' ');
                    if (names.length > 0)
                        $("#firstName").val(names[0]);
                    if (names.length > 2)
                        $("#lastName").val(names[2]);
                    else if (names.length > 1)
                        $("#lastName").val(names[1]);
                    $("#title").val(iterate.data[i].ContactTitle);
                    $("#email").val(iterate.data[i].ContactEmail);
                    $("#dunsNumber").val(iterate.data[i].dunsNumber);
                    $("#group").val(iterate.data[i].groupID);
                    $("#touchpoint").val(iterate.data[i].touchpointID);
                    $("#partnertype").val(iterate.data[i].partnertypeID);
                    break;
                }
            }
        }
        function seacrhPartner(load) {
            if (!load) {
                var searchText = $("#searctText").val();
                if (searchText) {
                    ShowPartnerFindLoader();
                    $("#tblPartners tbody").empty();
                    $.ajax({
                        type: "POST",
                        url: "IterateContacts",
                        data: {
                            searchText: searchText
                        },
                        success: function (result) {
                            if (result) {
                                if (result.length > 0) {
                                    iterate.data = result;
                                    for (var i = 0; i < result.length; i++) {
                                        addRow(result[i]);
                                    }
                                    $('#tblPartners tbody tr').click(function () {
                                        rowSelected(this);
                                        // row was clicked
                                    });
                                } else {
                                    addNotFoundRow();
                                }
                            }
                            HidePartnerFindLoader();
                        }
                    });
                }
            }
            else {
                $.ajax({
                    type: "POST",
                    url: "IterateAllContacts",
                    success: function (result) {
                        $("#tblPartners tbody").empty();
                        if (result) {
                            if (result.length > 0) {

                                for (var i = 0; i < result.length; i++) {
                                    addRow(result[i], true);
                                }
                                $('#tblPartners tbody tr').click(function () {
                                    rowSelected();
                                });
                            } else {
                                addNotFoundRow();
                            }
                        }
                        HidePartnerFindLoader();
                    }
                });
            }
        }
        function addNotFoundRow() {
            $("#tblPartners tbody").append("<tr><td><div>Partners not found</div></td></tr>");
        }
        function addRow(data, all) {
            if (!all) {
                var imageClass = "";
                switch (data.statusID) {
                    case 6: imageClass = "gradient-red"; break;
                    case 7: imageClass = "gradient-yellow"; break;
                    case 8: imageClass = "gradient-green"; break;
                }
                $("#tblPartners tbody").append("<tr data-partnerid='" + data.id + "'><td><div class='line-wrapper'><div class='img img-circle " + imageClass + "' title='" + data.status + "' ></div></div></td><td><div>" + data.Contact + "</div></td><td><div>" + data.PartnerName + "</div></td></tr>");
            }
            else {
                var imageClass = "";
                switch (data.status) {
                    case 6: imageClass = "gradient-red"; break;
                    case 7: imageClass = "gradient-yellow"; break;
                    case 8: imageClass = "gradient-green"; break;
                }
                $("#tblPartners tbody").append("<tr><td><div class='line-wrapper'><div class='img img-circle " + imageClass + "' title='" + data.status + "' ></div></div></td><td><div>" + data.FirstName + " " + data.LastName + "</div></td><td><div>" + data.name + "</div></td></tr>");
            }
        }
        function nextRow() {
            if ($(".table tr.info").length > 0) {
                $(".table tr.info").next().click();
            } else $(".table tbody tr:first-child").click();
        }
        function prevRow() {
            if ($(".table tr.info").length > 0) {
                $(".table tr.info").prev().click();
            } else $(".table tbody tr:last-child").click();
        }

        $(".clickable").click(function () {
            //if ($(".table tr").length === 0)
            // return;
            if ($(this).text() === "<<")
                $("#IteratePartners tr.t-state-selected").prev().click();//prevRow();
            else $("#IteratePartners tr.t-state-selected").next().click();// nextRow();
        });        
        //#endregion
    });
</script>

