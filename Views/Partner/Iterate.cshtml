<script type="text/javascript">
	function dropDownSubjectsChanged() {
		var control = $("#DropDownSubjects");
		if (control.val() && control.val() != 'Please select automail') {
			$.get("@Url.Action("GetAutomailIterate","Partner")" + "?id=" + control.val() + "&pptq="
				+ $('#DropDownSubjects').data().pptq).done(function (result) {
				if (result) {
					$("#emailSubject").val(result.subject);
					CKEDITOR.instances["emailText"].setData(result.text + '<br/>'+result.footer1);
					CKEDITOR.instances["text1"].setData(result.text);
					CKEDITOR.instances["footer1"].setData(result.footer1);
					
					if (result.attachmentOneName!=null&& result.attachmentOneName.length > 0) {
						$('#EmailAttachmentUpload').parent().addClass('hidden');
						$('#EmailAttachmentUpload_attach label').html(result.attachmentOneName);
						$('#EmailAttachmentUpload_attach').removeClass('hidden');
					}
					else {
						$('#EmailAttachmentUpload').parent().removeClass('hidden');
