    	$('#EmailAttachmentUpload').parent().removeClass('hidden');
    	$('#EmailAttachmentUpload2').parent().removeClass('hidden');

    	$('#emailText').parent().removeClass('hidden');
    	$('#saveButton').addClass('hidden');
    	$('#cancelButton').addClass('hidden');
    	$('#sendButton').removeClass('hidden');
    	$('#testButton').removeClass('hidden');
    	$('#addButton').removeClass('hidden');

    	dropDownSubjectsChanged();
	}

	
	function removeAttachment(type, element) {
		if (type == 'one') {
			isoneattachremoved = true;
			$('#EmailAttachmentUpload3').parent().removeClass('hidden');
		}
		else {
			istwoattachremoved = true;
			$('#EmailAttachmentUpload4').parent().removeClass('hidden');
		}

		$(element).parent().addClass('hidden');
	}

    function saveIterateEmailText() {
    	var formdata = new FormData(); 
    	var fileInput = document.getElementById('EmailAttachmentUpload3');
    	for (i = 0; i < fileInput.files.length; i++) {
    		formdata.append('one', fileInput.files[i]);
    	}
    	fileInput = document.getElementById('EmailAttachmentUpload4');
    	for (i = 0; i < fileInput.files.length; i++) {
    		formdata.append('two', fileInput.files[i]);
    	}
    	formdata.append("id", iterateEmailTextId);
    	formdata.append("person", iterate.person);
    	formdata.append("subject", $("#emailSubject").val());
    	formdata.append("text", CKEDITOR.instances["text1"].getData());
    	formdata.append("footer1", CKEDITOR.instances["footer1"].getData());
    	formdata.append("isoneattachremoved", isoneattachremoved);
    	formdata.append("istwoattachremoved", istwoattachremoved);
    	$("#emailDialog input[type='submit'], #emailDialog input[type='button']").prop("disabled", true);
    	$.ajax({
    		url: 'SaveIterateEmailText',
    		type: 'POST',
    		data: formdata,
    		processData: false,
    		contentType: false,
    		cache: false
    	}).done(function (result) {
    		$("#emailDialog button[type='submit'], #emailDialog button[type='button']").prop("disabled", false);
    		if (result.error) {
    			$("#emailDialog").modal("toggle");
    			alertify.alert(result.error);
    		} else {
    			refreshPopup();
    		}

    	});
    }

    function emailDialogSendTest() {
    	var formdata = new FormData(); //FormData object
    	var fileInput = document.getElementById('EmailAttachmentUpload');
    	////Iterating through each files selected in fileInput
    	for (i = 0; i < fileInput.files.length; i++) {
    		//Appending each file to FormData object
    		formdata.append(fileInput.files[i].name, fileInput.files[i]);
    	}
    	fileInput = document.getElementById('EmailAttachmentUpload2');
    	////Iterating through each files selected in fileInput
    	for (i = 0; i < fileInput.files.length; i++) {
    		//Appending each file to FormData object
    		formdata.append(fileInput.files[i].name, fileInput.files[i]);
    	}
    	formdata.append("iterateTextId", $("#DropDownSubjects").val());
    	formdata.append("partnerId", iterate.selectedPartnerId);
    	formdata.append("subject", $("#emailSubject").val());
    	formdata.append("text", CKEDITOR.instances["emailText"].getData());
    	formdata.append("userDate", new Date().toISOString());
    	formdata.append("ccSender", $("#ccSender").prop("checked"));
    	$("#emailDialog input[type='submit'], #emailDialog input[type='button']").prop("disabled", true);
    	$.ajax({
    		url: 'SendIteratePartnerEmailTest',
    		type: 'POST',
    		data: formdata,
    		processData: false,
    		contentType: false,
    		cache: false
    	}).done(function (result) {
    		$("#emailDialog button[type='submit'], #emailDialog button[type='button']").prop("disabled", false);
    		if (result.error) {
    			$("#emailDialog").modal("toggle");
    			alertify.alert(result.error);
    		} else {
    			alertify.alert('Done');
    		}

    	});
    }
</script>

