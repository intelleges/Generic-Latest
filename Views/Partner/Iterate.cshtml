            columns.Bound(o => o.partnumber).Title("Part number").Width(100);
            @*.Template(@<text>
                    <a href="#" id="@item.partnumber" class="menu_block">
                        @item.partnumber
                    </a>
                    <div class="display_menu" style="display: none;top: -10px;left: 110px;height: 60px;width: 120px;">
                        <ul style="margin-top: 5px;">
                            <li><a href="javascript:DetailsDialog.removePartNumber(@item.id)">Remove</a></li>
                            <li><a href="javascript:DetailsDialog.resetPartNumber(@item.partner,@item.id)">Reset</a></li>
                        </ul>
                    </div>
                </text>);*@

            columns.Bound(o => o.site).Title("Site").Width(220);
            columns.Bound(o => o.zcode).Title("ZCode").Width(220);
            columns.Bound(o => o.status).Title("Status").Width(100);
            columns.Bound(o => o.lastDateModified).Title("Last Date Modified").Width(120);
            columns.Bound(o => o.LSMW).Title("LSMW").Width(80);
            columns.Bound(o => o.COUNTRY).Title("Country of Orign").Width(120);
            columns.Bound(o => o.ProductContent).Title("Product Content").Width(100);
        })
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           )
           .HtmlAttributes(new { @class = "ra" }).Footer(false).HtmlAttributes(new { style = "width:100%;" })
        )
    </div>

}

@section scripts{
    @System.Web.Optimization.Scripts.Render("~/bundles/jqueryval")
    <script src="/Scripts/bootstrap.js"></script>
    <script src="/Scripts/validator.js"></script>
    <script src="http://lab.jakiestfu.com/contextjs/context.js"></script>
    <script>
        $(function () {
            $("#evernotesDiv").jstree({
                "core": {
                    "check_callback": function (operation, node, node_parent, node_position, more) {
                        if (operation == 'move_node') {
                            // console.log(node_parent);
                            if (node_parent.type == 'notebook') {
                                return true;
                            } else
                                return false;
                        }
                        return true;
                    },
                    "data": {
                        "url": "EvernoteNotebooksList",
                        "data": "json"
                    }
                },
                "dnd": {
                    "is_draggable": function (node) {
                        console.log('is_draggable called: ', node[0]);
                        if (node[0].type != 'note') {
                            return false;
                            console.log('node isnt note ');
                        }
                        if (iterate.globalVars.allNotesIds.indexOf(node[0].id) < 0) {
                            console.log('notesId doesnt contain current node ', iterate.globalVars.allNotesIds, node[0].id);
                            return false;
                        }
                        return true;
                    }
                },
                "types": {
                    "root": {

                    },
                    "notebook": {

                    },
                    "note": {

                    }
                },
                "plugins": ["dnd", "types"]
            }).bind("redraw.jstree", function (event, data) {
                //after redraw bind dblclick
                $("#evernotesDiv").off("dblclick", "a");
                $("#evernotesDiv").delegate("a", "dblclick", function (e) {
                    //if nodes type=== "note" then show note
                    e.preventDefault();
                    if ($("#evernotesDiv").data("jstree").get_type($(this).parent()) === "note") {
                        $.post("GetIteratePartnerByNote", { noteId: $(this).parent().attr("id") }).done(function (result) {
                            if (result.finded) {
                                iterate.selectedPartnerId = result.partnerId;
                                iterate.selectedPartner = result.partnerName;
                                showNoteEditor(result.partnerId, result.partnerName);
                            }
                            else alertify.alert("There is no iterate partner for selected note");
                        });
                    }
                });
            });
            $(document).on("dnd_stop.vakata", function (event, data, element) {
                if (data) {
                    $.post("UpdateNote", {
                        title: iterate.globalVars.nodeText,
                        id: iterate.globalVars.nodeId,
                        newNoteBookId: iterate.globalVars.parentNode
                    },
                        function (result) {
                            if (result.iteratestatusid) {
                                var grid = $("#IteratePartners").data("tGrid");
                                grid.ajaxRequest();
                                //var nItem = grid.dataSource.find(result.partnerid);
                                //if (nItem) {
                                //    grid.dataSource.find(result.partnerid).iteratePartnerStatus = result.iteratestatusid;
                                //    grid.dataSource.find(result.partnerid).iteratePartnerStatusDescription = result.iteratestatusdescription;

                                //}
                                if (iterate.selectedPartnerId === result.partnerid)
                                    $("#partnerstatus").val(result.iteratestatusid);
                            }
                        });
                }
            });
            $('#evernotesDiv').on("move_node.jstree", function (e, data) {
                //data.node, data.parent, data.old_parent is what you need
                iterate.globalVars.parentNode = data.parent;
                iterate.globalVars.nodeText = data.node.text;
                iterate.globalVars.nodeId = data.node.id;

            });
            $("#evernotesDiv").on("select_node.jstree", function (event, data) {
                if (data) {
                    if (data.node.text === "Authorize to get notebooks") {
                        $.get("AuthorizeEverNote", function (result) {
                            if (result) {
                                window.location.href = result;
                            }
                        });
                    }
                }
            });



        });


        //Rewritten update.
        function TwilioCall(Id, row) {
            var url = '@Url.Action("CallPartnerNow", "Partner")';
            var partnerGrid = $("#IteratePartners").data("tGrid");
            var rowData = partnerGrid.dataItem($(row).parents("tr")[0]);
            jQuery.ajax({
                type: "post",
                url: url,
                data: { id: rowData.id, phone: rowData.phone }, //pass according to needs.
                cache: false,
                async: true,
                success: function (result) {

                },
                error: function (header, status, e) {
                    //location.reload();

                }
            });
        }

    </script>

<script type="text/javascript">

	var selectedItemNote = null;
	function setSelectedRowData(e) {
		var partnerGrid = $("#iterateNotesGrid").data("tGrid");
		var row = e.row;
		selectedItemNote = partnerGrid.dataItem(row);
		$('#buttons-panel .btn-primary').removeClass('disabled');
	}

	function viewNote() {
		$.fancybox({
			closeBtn: true,
			closeClick: true,
			modal: false,
			content: selectedItemNote.note,
			type: 'html',
			minWidth: 400,
			minHeight: 150,
			afterClose: function () {

				var url = '@Url.Action("GetIterateNotes", "Partner")' + '?partnerId=' + iterate.selectedPartnerId;
				$.fancybox({
					closeBtn: false,
					closeClick: false,
					modal: true,
					href: url,
					type: 'ajax',
					minWidth: 400,
					minHeight: 150
				});
			}
		});
	}

	function archiveNote() {
		$.get("@Url.Action("ArchiveIterateNote", "Partner")" + "?id=" + selectedItemNote.iteratePartnerNote).done(function (result) {
			$("#iterateNotesGrid").data("tGrid").ajaxRequest();
		});
	}

	function editNote()
	{
		$.get("@Url.Action("EditIterateNote", "Partner")" + "?id=" + selectedItemNote.iteratePartnerNote).done(function (result) {
			CKEDITOR.instances["noteUpdateText"].setData(result.text);
			$.fancybox.close();
			$("#noteUpdateDialog").modal("toggle");
		});
	}
</script>
}

