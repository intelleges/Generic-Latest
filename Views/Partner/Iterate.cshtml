            }).bind("redraw.jstree", function (event, data) {
                //after redraw bind dblclick
                $("#evernotesDiv").off("dblclick", "a");
                    $("#evernotesDiv").delegate("a", "dblclick", function (e) {
                        //if nodes type=== "note" then show note
                        e.preventDefault();
                        if ($("#evernotesDiv").data("jstree").get_type($(this).parent()) === "note") {
                            $.post("GetIteratePartnerByNote", { noteId: $(this).parent().attr("id") }).done(function (result) {
