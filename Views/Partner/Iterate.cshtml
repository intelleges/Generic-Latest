        var checkResult = false;
        $.ajax({
            url: "IteratePartnerCheckoAuth",
            async: false,
            type: "POST"
        }).done(function (result) {
            if (result !== true) {
                alertify.alert("Please wait for authentification");
                window.location.href = result;
                checkResult = false;
            } else checkResult = true;
        });
