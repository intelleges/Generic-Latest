    function Grid1_onDataBound(e) {
    	$('#buttons-panel .btn-primary').addClass('disabled');
    	$('#closeNoteHistoryPopup').removeClass('disabled');
    }

    function Grid_onDataBound(e) {
    	$("#IteratePartners td").mouseover(function () {
    		if ($(this).find('.display_menu').length > 0) {
    			var offset = $(this).find('.menu_block').offset();
    			$(this).find('.display_menu').css({ position: 'fixed', left: offset.left + 40, top: offset.top - $(document).scrollTop() });
    			$(this).find('.display_menu').show();
    		}

    		if ($(this).find('.display_menu_right').length > 0) {
    			var offset = $(this).find('.menu_block').offset();
    			$(this).find('.display_menu_right').css({ position: 'fixed', left: offset.left - 178, top: offset.top - $(document).scrollTop() });
    			$(this).find('.display_menu_right').show();
    		}
    		
    	}).mouseout(function () {
    		$(this).find('.display_menu').hide();
    		$(this).find('.display_menu_right').hide();
    	});

    	$(".display_menu > ul > li").mouseover(function () {
    		$(this).find('.sub-items').show();

    	}).mouseout(function () {
    		$(this).find('.sub-items').hide();
    	});

        $("td a.menu_block.title").each(function () {
            if ($(this).text().length > 13) {
                $(this).text($(this).text().substr(0, 13) + "...");
            }
        });
        //append time zone information
        $(".address2").each(function () {
            var text = $(this).text();
            var result="";
            if (text && text.length>2) {
                text = text.substr(0, 3);
                var offset = 0;
                var cMoment = moment();
                switch (text) {
                    case "EST": offset = -5 * 60;
                        break;
                    case "CST": offset = -6 * 60; break;
                    case "MST": offset = -7 * 60; break;
                    case "PST": offset = -8 * 60; break;
                default:break;
                }
                if (offset != 0) {
                    cMoment.utcOffset(offset);
                    var startMoment = moment(cMoment).startOf("day");
                    //=12.00 PM
                    if (cMoment.isSame(moment(startMoment).hours(12))) {
                        result = "NOON - ";
                    }
                    else
                        if (cMoment.isBetween(startMoment, moment(startMoment).hours(5).minutes(59).seconds(59))) {
                            result = "EARLY MORNING - ";
                        } else
                        //00:01 am - 11:59 am
                            if (cMoment.isBetween(moment(startMoment).hours(6), moment(startMoment).hours(11).minutes(59).seconds(59))) {
                        result = "MORNING - ";
                    } else {
                        //00.01 PM -5.59 PM 
                        if (cMoment.isBetween(moment(startMoment).hours(12), moment(startMoment).hours(17).minutes(59).seconds(59))) {
                            result = "AFTERNOON - ";
                        } else
                            //06.00 PM -11.59 PM 
                            if (cMoment.isBetween(moment(startMoment).hours(18), moment(startMoment).hours(23).minutes(59).seconds(59))) {
                            result = "EVENING - ";
                        }
                    }
                }
                if (result) {
                    $(this).text(result + " " + $(this).text());
                }
            }
        });
        $(".display_menu ul li a").click(function (e) {
            //note menu item click
            if ($(this).text() === "Note") {
                e.preventDefault();
                var partnerGrid = $("#IteratePartners").data("tGrid");
                var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
                //data can be used for whatever it needed
                iterate.selectedPartnerId = rowData.id;
                iterate.selectedPartner = rowData.name;
                showNoteEditor(iterate.selectedPartnerId, iterate.selectedPartner);
            }
            if ($(this).text() === "Email") {
            	e.preventDefault();
            	var partnerGrid = $("#IteratePartners").data("tGrid");
            	var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
            	var pptq = rowData.pptq;
            	if (pptq === undefined)
            		pptq = null;

            	person = rowData.person;
            	
            	if (pptq)
            		$('#DropDownSubjects').data("pptq", pptq);
            	else
            		$('#DropDownSubjects').removeData("pptq");
            	$.get("@Url.Action("GetSubjectsIterateByPerson", "Partner")" + "?personId=" + rowData.person + "&pptq=" + pptq).done(function (result) {
            		if (result) {

            			$('#DropDownSubjects')
							.empty()
							.append('<option selected="selected">Please select automail</option>');


            			$.each(result.list, function (index, val) {
            				$('#DropDownSubjects')
		.append($("<option></option>")
				   .attr("value", val.id)
				   .text(val.subject));
            			});
            		}
            	});
             
                //data can be used for whatever it needed
            	iterate.selectedPartnerId = rowData.id;
            	iterate.selectedPartnerId1 = rowData.id;
            	iterate.person = rowData.person;
            	iterate.email = rowData.email;

                iterate.selectedPartner = rowData.name;
                $("#emailSubject").val("");
                CKEDITOR.instances.emailText.setData("");
                //if (!checkoAuth()) return;
                $("#emailDialog").modal("toggle");
            }
        	if ($(this).text() === "Meet") {
        		e.preventDefault();
        		alertify.alert('Functionality not available yet.');
        	}

            if ($(this).text() === "Update") {
            	e.preventDefault();
            	var partnerGrid = $("#IteratePartners").data("tGrid");
