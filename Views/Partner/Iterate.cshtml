    function AddNote(title, text, partner, partnerId) {
        $("#addNoteDialog button[type='submit'], #addNoteDialog button[type='button']").prop("disabled", true);
        $.post("AddNote", {
            partnerName: partner,
            noteTitle: title,
            noteText: text,
            partnerId: partnerId
        }).done(function (result) {
            $("#addNoteDialog button[type='submit'], #addNoteDialog button[type='button']").prop("disabled", false);
            if (result !== "done") {
                window.location.href = result;
            }
            else {
                $("#addNoteDialog").modal("hide");
                $("#evernotesDiv").jstree(true).refresh();
                //var evernotestree = $('#evernotesTree').data('tTreeView');
                //refresh data
                $("#IteratePartners").data("tGrid").ajaxRequest();
                showNotesPanel();
                loadNotesIds();
            }
        });
        //$.ajax({
        //    type: "POST",
        //    dataType: 'json',
        //    url: "AddNote",
        //    async:true,
        //    data: {
        //        partnerName: partner,
        //        noteTitle: title,
        //        noteText: text,
        //        partnerId:partnerId
        //    },
        //    success: function (result) {

        //        //                        HidePartnerFindLoader();
        //    }
        //});
    }
    function showNotesPanel() {
        var splitter = $("#Splitter2").data("tSplitter");
        var pane = $("#Splitter2 > .t-pane")[2]; // the 3d pane
        splitter.expand(pane);
    }
    function checkoAuth() {
        var checkResult = false;
        $.ajax({
            url: "IteratePartnerCheckoAuth",
            async: false,
            type: "POST"
        }).done(function (result) {
            if (result !== true) {
                alertify.alert("Please wait for authentification");
                window.location.href = result;
                checkResult= false;
            } else checkResult = true;
        });
        return checkResult;
    }


    function Grid_onDataBound(e) {
        $("td a.menu_block.title").each(function () {
            if ($(this).text().length > 13) {
                $(this).text($(this).text().substr(0, 13) + "...");
            }
        });
        $(".display_menu ul li a").click(function (e) {
            //note menu item click
            if ($(this).text() === "Note") {
                e.preventDefault();
                var partnerGrid = $("#IteratePartners").data("tGrid");
                var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
                //data can be used for whatever it needed
                iterate.selectedPartnerId = rowData.id;
                iterate.selectedPartner = rowData.name;
                showNoteEditor(iterate.selectedPartnerId, iterate.selectedPartner);
            }
            if ($(this).text() === "Email") {
                e.preventDefault();
                var partnerGrid = $("#IteratePartners").data("tGrid");
                var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
                //data can be used for whatever it needed
                iterate.selectedPartnerId = rowData.id;
                iterate.selectedPartner = rowData.name;
                $("#emailSubject").val("");
                CKEDITOR.instances.emailText.setData("");
                if (!checkoAuth()) return;
                $("#emailDialog").modal("toggle");
            }
            if ($(this).text() === "Nurture/Remind") {
                e.preventDefault();
                var partnerGrid = $("#IteratePartners").data("tGrid");
                var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
                iterate.selectedPersonId = rowData.personID;
                iterate.selectedPartnerId = rowData.id;
                $.post("NurtureRemindIteratePartner", {
                    internalId: rowData.internalID,
                    email: rowData.email,
                    partnerId: rowData.id,
                    personId: rowData.personID
                }).done(function (result) {
                    if (result !== "NOT_RELATED") {
                        alertify.alert(result);
                    }
                    else {
                        $("#nurturePartner").modal("toggle");
                    }
                });
            }
            if ($(this).text() === "Add") {
                var partnerGrid = $("#IteratePartners").data("tGrid");
                var rowData = partnerGrid.dataItem($(this).parents("tr")[0]);
                //data can be used for whatever it needed
                iterate.selectedPartnerId = rowData.id;
                $("#newIteratePartner").modal("toggle");
            }
        });
        if (iterate.saved) {
            $($("#Company" + iterate.selectedPartnerId).parents("tr")[0]).click();
            iterate.saved = false;

        }
        else {
            iterate.selectedPartnerId = 0;
            clearFields();
        }
    }

    function showNoteEditor(partnerId, partnerName) {
        if (!checkoAuth()) return;
        $.post("GetEvernoteText", { partnerId: partnerId }).done(function (e) {
            if (e.text) {
                var date = new Date();
                if (e.text !== "none") {

                    CKEDITOR.instances.noteText.setData("<hr/><div>" + date.today() + "@@" + date.timeNow() + "-note added - by " + e.email + "</div>" + e.text, {
                        callback: function () {
                            $("#noteTitle").val(partnerName);
                            $("#noteTitle").attr("disabled", true);
                            $("#addNoteDialog").modal("toggle");
                        }
                    });
                } else {
                    CKEDITOR.instances.noteText.setData("<hr/><div>" + date.today() + "@@" + date.timeNow() + "-note added - by " + e.email + "</div>", {
                        callback: function () {
                            $("#noteTitle").val(partnerName);
                            $("#noteTitle").attr("disabled", true);
                            $("#addNoteDialog").modal("toggle");
                        }
                    });
                }
            } else {
                window.location.href = e;
            }

        });
    }

    @section onSplitter2Load{
    if ('@ViewBag.showNotes' === "True") {
        showNotesPanel();
    }
    if ('@ViewBag.gmailAuth' === "True") {
        checkoAuth();
    }
    }
        function loadNotesIds() {
            $.post("getIteratePartnerNoteIds").done(function (result) {
                if (result) {
                    iterate.globalVars.allNotesIds = result;
                }
            });
        }


    //#region First declaration
    $(document).ready(function () {
        loadNotesIds();
        
        $("#btnLoad").click(function () {
            //$(".t-button.t-upload-button").click();
            $("#excelFile").click();
        });
        $("#addEverNote").click(function () {
            //AddNote($("#noteTitle").val(), $("#noteText").val(), iterate.selectedPartner, iterate.selectedPartnerId);
        });
        $("#addNoteDialog").submit(function (e) {
            e.preventDefault();
            AddNote($("#noteTitle").val(), $("#noteText").val(), iterate.selectedPartner, iterate.selectedPartnerId);
        });
        $("#newIteratePartner").submit(function (e) {
            e.preventDefault();
            $("#newIteratePartner :input").prop("disable", true);
            $.ajax({url:"AddNewIteratePartner", data:{
                partnerId: iterate.selectedPartnerId,
                firstName: $("#newIteratePartner #firstName").val(),
                lastName: $("#newIteratePartner #lastName").val(),
                phoneNumber: $("#newIteratePartner #phoneNumber").val(),
                email: $("#newIteratePartner #email").val(),
                title: $("#newIteratePartner #title").val()
            }, method:"POST",async:true}).done(function (result) {
                $("#newIteratePartner").modal("toggle");
                $("#newIteratePartner :input").prop("disable", false);
                $("#IteratePartners").data("tGrid").ajaxRequest();
            }).fail(function () {
                alertify.alert("There was an error during adding operation. Please try again later.");
                $("#newIteratePartner :input").prop("disable", false);
            });
            
        });
        
        //send email to partner
        $("#emailDialog").submit(function (e) {
            e.preventDefault();
            $("#emailDialog input[type='submit'], #emailDialog input[type='button']").prop("disabled", true);
            $.post("SendIteratePartnerEmail", {
                partnerId: iterate.selectedPartnerId,
                subject: $("#emailSubject").val(),
                text: $("#emailText").val(),
                userDate: new Date().toISOString(),
                ccSender: $("#ccSender").prop("checked")
            }).done(function (result) {
                $("#emailDialog button[type='submit'], #emailDialog button[type='button']").prop("disabled", false);
                if (result.error) {
                    $("#emailDialog").modal("toggle");
                    alertify.alert(result);
                } else {
                    if (result === "done") {
                        $("#IteratePartners").data("tGrid").ajaxRequest();
                        $("#evernotesDiv").jstree(true).refresh();
                        $("#emailDialog").modal("toggle");
                    }
                    else {
                        window.location.href = result;
                    }
                }

            });
        });
        $("#nurturePartner").submit(function (e) {
            e.preventDefault();
            $.post("CreateAndInviteIteratePartner", {
                partnerId: iterate.selectedPartnerId,
                personId: iterate.selectedPersonId,
                partnertype: $("#partnerType").val(),
                group: $("#partnerGroup").val()
            }).done(function (result) {
                if (result) {
                    $("#nurturePartner").modal("toggle");
                    $("#IteratePartners").data("tGrid").ajaxRequest();
                    $("#evernotesDiv").jstree(true).refresh();
                    alertify.alert(result);
                }
            });
        });

