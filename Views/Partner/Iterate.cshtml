<script type="text/javascript">
    function evernotesTree_onSelect(e) {
        if (e.item) {
            if ("Authorize to get notebooks" === $(this).data("tTreeView").getItemText(e.item)) {
                $.get("AuthorizeEverNote", function (result) {
                    if (result) {
                        window.location.href = result;
                    }
                });
            }
        }
    }
    function onSuccess(e) {       
        alertify.alert(e.response.message);
        $("#IteratePartners").data("tGrid").ajaxRequest();
        //$("#topCallapsePanel").html("")
    }
    function onError(e) {
        var err = e.XMLHttpRequest.responseText;
        alertify.alert("There was server error:" + err);
    }

    function onNodeDropped(e) {
        console.log(1);
    }

    $(document).ready(function () {
        $("#IteratePartners").show();

        $("#excelFile").closest(".k-upload-button")
                        .find("span")
                        .text("Select file to upload");

        //Initialize the scheduler
        $(document).on('click', '.t-link[href="#tabstrip-2"]', function () {
            $('.dhx_cal_tab_last').click();
        });
        $(document).on('click', '#getiCal', function () {
            $.ajax({
                url: "@Url.Content("~/Partner/GetPersonIcal")",
                type: "POST",
                success: function (data) {
                    alertify.alert(data.Data);
                    document.getElementById('hdnICal').value = text;
                },
                error: function (data) {
                }
            });
        });
        $(document).on('click', '#setiCal', function () {
            var text = prompt("Enter Calendar Url", "");
            //var iCal = document.getElementById('hdnICal').value;
            if (text) {
                $.ajax({
                    url: "@Url.Content("~/Partner/ModifyPersonIcal")",
                    type: "POST",
                    data: { iCal: text },
                    success: function (data) {
                        alertify.alert(data.Data);
                    },
                    error: function (data) {
                    }
                });
            } else alertify.alert("Please enter valid calendar URI.");
        });

    });
    function changeStatus(id, status) {
        $.post("ChangeiteratePartnerStatus", {
            partnerId: id,
            partnerStatusId: status
        }).done(function (result) {
            if (result===true) {
                $("#IteratePartners").data("tGrid").ajaxRequest();
                $("#evernotesDiv").jstree(true).refresh();
                clearFields();
            }
            else {
                window.location.href = result;
            }
        });
    }
    function changeNextAction(id, nextAction) {
        var d = new Date();
        //var offset = d.getTimezoneOffset();
        //var dt = new Date(d.getTime() - (offset * 60000));
        $.post("ChangeIteratePartnerNextAction", {
            partnerId: id,
            nextActionId: nextAction,
            localDate: d.toISOString()
        }).done(function (result) {
            if (result) {
                $("#IteratePartners").data("tGrid").ajaxRequest();
                clearFields();
            }
        });
    }
    function changeLastContact(id, lastContact) {
        $.post("ChangeIteratePartnerLastContact", {
            partnerId: id,
            lastContactId: lastContact
        }).done(function (result) {
            if (result===true) {
                $("#IteratePartners").data("tGrid").ajaxRequest();
                $("#evernotesDiv").jstree(true).refresh();
                clearFields();
            }
            else {
                window.location.href = result;
            }
        });
    }
    function callIfNeed(partnerId, nextActionId, row) {
        if (nextActionId === 1 || nextActionId === 15) {
            TwilioCall(partnerId, row);
        }
    }
    function shownote(sender,partnerId) {
        var partnerGrid = $("#IteratePartners").data("tGrid");
        var rowData = partnerGrid.dataItem($(sender).parents("tr")[0]);
        //data can be used for whatever it needed
        iterate.selectedPartnerId = rowData.id;
        iterate.selectedPartner = rowData.name;
        showNoteEditor(iterate.selectedPartnerId, iterate.selectedPartner);
    }
</script>

