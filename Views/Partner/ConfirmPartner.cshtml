@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.ViewModel.ConfirmPartnerViewModel>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Partner";
}

<style>
    div#ConfirmPartnerGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }

     .alertify-message {
        word-wrap: break-word;
    }
</style>
<form action="@Url.Content("~/Partner/ConfirmPartner")" method="post">
  @*<input id="SelectedRecord" type="hidden" value="@ViewBag.SelectedRecord" name="SelectedRecord">*@
    @( Html.Telerik().Grid(Model).Name("ConfirmPartnerGrid")
    .ToolBar(commands =>
         {
             commands.Template("<a class='t-button' href='#' id='btnconfirm'>Confirm</a><a class='t-button' href='#' id='btninvite'>Invite</a><a class='t-button' id='btnclear' href='#'>Clear</a>");
         })

        .Columns(columns =>
        {
            columns.Bound(o => o.IsSelected1)
                   .Title("&nbsp;A")
                   .Template(@<text><input type='radio' id='@item.Partner_A' name='rbtnSelect_@item.id' style="width:15px;" onclick="SelectedPartnerA(this)" /></text>)
                   .Width(25)
                   .HtmlAttributes(new { style = "" });

            columns.Bound(o => o.Partner_A_Name).Title("Name").Width(100).HtmlAttributes(new { style = "overflow: hidden !important;"});
            columns.Bound(o => o.Group1).Title("Group").Width(50).HtmlAttributes(new { style = "overflow: hidden !important;text-overflow: ellipsis !important;"});
            columns.Bound(o => o.Status1).Title("Status").Width(80).HtmlAttributes(new { style = "text-overflow: ellipsis !important;overflow: hidden !important;white-space: nowrap;" });
            columns.Bound(o => o.IsReference1).Title("Ref").Width(30).HtmlAttributes(new { style = "text-align:left;" });;

            columns.Bound(o => o.IsSelected2)
                  .Title("&nbsp;B")
                  .Template(@<text><input type='radio' id="@item.Partner_B" style="width:15px;" name='rbtnSelect_@item.id' onclick="SelectedPartnerB(this)" /></text>)
                  .Width(25)
                  .HtmlAttributes(new { style = "" });

            columns.Bound(o => o.Partner_B_Name).Title("Name").Width(100).HtmlAttributes(new { style = "overflow: hidden !important;"});
            columns.Bound(o => o.Group2).Title("Group").Width(50).HtmlAttributes(new { style = "overflow: hidden !important;text-overflow: ellipsis !important;"});
            columns.Bound(o => o.Status2).Title("Status").Width(80).HtmlAttributes(new { style = "text-overflow: ellipsis !important;overflow: hidden !important;white-space: nowrap;" });
            columns.Bound(o => o.IsReference2).Title("Ref").Width(30).HtmlAttributes(new { style = "text-align:center;" });;
            columns.Bound(o => o.EmailMatch).Title("EM").Width(30).HtmlAttributes(new { style = "text-align:center;" });;
            columns.Bound(o => o.InternalIDMatch).Title("IM").Width(30).HtmlAttributes(new { style = "text-align:center;" });;
            columns.Bound(o => o.FederalIDMatch).Title("FM").Width(30).HtmlAttributes(new { style = "text-align:center;" });;
            columns.Bound(o => o.DUNSMatch).Title("DM").Width(30).HtmlAttributes(new { style = "text-align:center;" });;
            columns.Bound(o => o.NameMatch).Title("NM").Width(30).HtmlAttributes(new { style = "text-align:center;" });;

            columns.Bound(o => o.IsCheckboxSelected)
            .Title("ActionType")
             .Template(@<text><select id="ddlactionType_@item.id"><option value="0">Select</option>
                  <option value="1">Ignore</option>
                  <option value="2">Remove</option>
                  <option value="3">Shadow</option>
                  <option value="4">Skip</option>
              </select></text>)
            .Width(80)
             .HtmlAttributes(new { style = "text-align:center" });

            columns.Bound(o => o.IsCheckboxSelected)
            .Title("")@*"<input type='checkbox'  id='chkSelectAll' style='margin-left: 11px;' name='checkedRecords' value='<#= IsCheckboxSelected #>' />")*@
            .Template(@<text><input type='checkbox' id='chkpartnerconfirm_@item.id' onclick='GetRowDetails(this)' name='chkSelect' value='@item.id' /></text>)
                                                   .Width(30)
                                                   .HtmlAttributes(new { style = "text-align:center" });
        })

            //.DataKeys(keys => keys.Add(o => o.internalID))
        .Pageable(pager => pager.PageSize(13).Total(200).Enabled(true))
        .Sortable(sorting => sorting.Enabled(true))

        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height(380))
           .HtmlAttributes(new { @class = "ra" })
)
</form>


<style>
    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
</style>
