    //Tocheck and uncheck all the check boxes
    $("#chkSelectAll").click(function () {
        debugger;
        $("input[name='chkSelect']").attr("checked", this.checked);

        $("input[name='chkSelect']").click(function () {
            if ($("input[name='chkSelect']").length == $("input[name='chkSelect']:checked").length) {
                $("#chkSelectAll").attr("checked", "checked");
