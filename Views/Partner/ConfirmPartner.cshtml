    function GetRowDetails(e) {
        debugger;
        var recordID = e.value;
        if ($("#chkpartnerconfirm_" + recordID).is(':checked')) {
            //var closer = $(e).closest("tr").find('td input:radio');
            var name = $(e).closest("tr").find('td input:radio')[0].name;
            if ($("input[type='radio'][name='" + name + "']:checked")[0] || $("input[type='radio'][name='" + name + "']:checked")[1]) {
                if ($("#ddlactionType_" + recordID).val() != "0") {
                    var Checked = $("input[type='radio'][name='" + name + "']:checked")[0].id;
                    var UnChecked = $("input[type='radio'][name='" + name + "']:not(:checked)")[0].id;
                    var ActionType = $("#ddlactionType_" + recordID).val();
                    TotalRecord += Checked + "," + UnChecked + "," + ActionType + ";";
                    //alert(TotalRecord);
                }
                else {
                    $("#chkpartnerconfirm_" + recordID).removeAttr("checked");
                    alert("Please select action type");
                }
            }
            else {
                $("#chkpartnerconfirm_" + recordID).removeAttr("checked");
                alert("Please select a group");
            }
        }
    else{
            var name = $(e).closest("tr").find('td input:radio')[0].name;
             var Checked = $("input[type='radio'][name='" + name + "']:checked")[0].id;
             var UnChecked = $("input[type='radio'][name='" + name + "']:not(:checked)")[0].id;
             var ActionType = $("#ddlactionType_" + recordID).val();
             var value = Checked + "," + UnChecked + "," + ActionType + ";";
             TotalRecord = TotalRecord.replace(value,'');
             //alert(TotalRecord);
}
  
    }


