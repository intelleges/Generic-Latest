@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.ViewModel.PersonViewModel>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI;
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Person";
}

@section header{
    <script src="//cdn.ckeditor.com/4.7.2/standard/ckeditor.js"></script>
    <link href="~/Content/Site.css" rel="stylesheet" />
    @System.Web.Optimization.Scripts.Render("~/bundles/jqueryval")
}
<style>
    div#PersonGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }
</style>
<form action="@Url.Content("~/Person/RemovePerson")" method="post">
    <input id="searchType" type="hidden" value="@ViewBag.searchType" name="searchType">

    @( Html.Telerik().Grid(Model).Name("PersonGrid")
                            .Columns(columns =>
                        {
                            columns.Bound(o => o.internalId).Title("Internal ID").Width(100).Encoded(false).Template(@<text>
                                @{
                                    <a href='#' id='@item.id' class="menu_block" title="@item.internalId">@item.internalId</a>
                                }
                                <div class="display_menu" style="display: none;">
                                    <ul>

                                        <li style='display:inherit'><a href="javascript:retorePerson(@item.id);">Restore</a></li>
                                    </ul>
                                </div>
                            </text>); ;
                                    columns.Bound(o => o.firstName).Title("Firstname").Width(200);
                                    columns.Bound(o => o.lastName).Title("Lastname").Width(1 - 0);
                                    columns.Bound(o => o.email).Title("Email").Width(200);
                        // .FooterTemplate(@<text><input style="width: 80px;" type="submit" value="Go" /></text>);



                        columns.Bound(o => o.State).Title("State").Width(100);

                                    columns.Bound(o => o.Country).Title("Country").Width(200);

                        //columns.Bound(o => o.Role).Title("Role").Width(100);

                    })
                                            .DataKeys(keys => keys.Add(o => o.internalId))

                                            .Sortable(sorting => sorting.Enabled(true))

                                            .Scrollable(scrolling => scrolling
                                               .Enabled(true)
                                               .Height(380))
                                               .HtmlAttributes(new { @class = "ra" })



    )
</form>
<div id="EmailDialog" title="Questionnaire Routing Form">
    <p>Email dialog</p>
</div>

<style>
    .t-grid-content {
        overflow-x: scroll !important;
    }

        .t-grid-content tr > td:hover .menu_block + .display_menu {
            display: block !important;
        }

    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        top: -5px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

    .t-grid-content tr > td {
        overflow: visible !important;
        position: relative;
    }

    .display_menu > ul {
        padding: 0 16px;
    }

    .display_menu li {
        list-style: none outside none;
        width: 143px;
    }
</style>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    $(function () {
        jQuery.noConflict();
        $("#EmailDialog").dialog({
            autoOpen: false
        });
        $('#menu_block').hover(function () {
            // alert("call");
            $('#display_menu').show();
        }, function () {
            $('#display_menu').hide();
        })

        $('#menu_block').mouseenter(function () {
            $('#display_menu').show();
        }).mouseleave(function () {

            $('#display_menu').hide();

        });
    });
    function OpenEmailDialog(ac) {
        jQuery.noConflict();

        $.get("/WrongContact/Index", { accessCode: ac }, function (data) {

            $("#EmailDialog").html(data);
            $("#EmailDialog").dialog({
                width: 1200,
                height: 1000,
            });
            $("#EmailDialog").dialog('open');
        });
    }


    function retorePerson(id) {
        $.getJSON('@Url.Content("~/Person/RetorePersonFunc")', { id: id }, function (data) {
            alertify.alert(data.message, function () {
                window.location.reload();
            });
        });
    }

    function Selectall() {
        // if check all is checked, all checkboxes are checked
        // if check all is unchecked, all checkboxes are cleared

        if ($('#chkSelectAll').is(':checked')) {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).attr('checked', 'checked');
                });
        }
        else {
            $('input:checkbox[name$=chkSelect]').each(
                function () {
                    $(this).removeAttr('checked');
                });
        }
    }

    $('input:checkbox[name$=chkSelect]').click(
    function () {
        // if any of the checkbox is unchecked
        // check all checkbox should be cleared
        if (!$(this).is(':checked')) {
            $('#chkSelectAll').removeAttr('checked');
        }
        else {
            // if all of the checkbox is checked
            // check all checkbox should be checked
            if ($('input:checkbox[name$=chkSelect]').length ==
            $('input:checkbox[name$=chkSelect]:checked').length) {
                $('#chkSelectAll').attr('checked', 'checked');
            }
        }
    });


</script>

