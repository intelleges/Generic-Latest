@inherits System.Web.Mvc.WebViewPage<IEnumerable<Generic.ViewModel.InvalidZCodeViewModel>>
@using System.Web.Mvc.Html
@using Generic.Helpers
@using Telerik.Web.Mvc.UI
@{
    Layout = LayoutHelper.GetLayout();
    ViewBag.Title = "Invalid Zcodes";
}

<script type="text/javascript">
    function formatter(value) {
        return value.substring(0, 10);
    }
</script>

<style>
    div#ZcodeGrid {
        font-size: 11px;
    }

    #modal {
        height: 489px;
    }

    .ui-dialog {
        width: 99% !important;
        left: 0;
    }

    .t-grid-content tr > td:hover .menu_block + .display_menu {
        display: block !important;
    }
    .t-grid-header .t-header {
        padding-top: 3px !important;
        padding-bottom: 13px !important;
    }
    .display_menu {
        left: 65px;
        overflow: visible;
        position: absolute;
        margin-top: -26px;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 100;
    }

        .display_menu > ul {
            padding: 0 16px;
        }

        .display_menu li {
            list-style: none outside none;
            width: 143px;
        }
</style>
<div style="margin-top:10px;">
    @( Html.Telerik().Grid(Model).Name("ZcodeGrid").ToolBar(commands => commands
                .Custom()
                    .HtmlAttributes(new { id = "export" })
                    .Text("Export to Excel")
                    .Action("ExportExcel", "zCodeCheck"))

        .Columns(columns =>
        {
            columns.Bound(o => o.Id).Width(20).Title("Id");
            columns.Bound(o => o.Touchpoint).Width(100).Title("Touchpoint").Encoded(false).Template(@<text>
                @{
                    var columnData = item.Touchpoint;
                    var width = 30;
                    var visibleText = string.Empty;
                    if (columnData != null)
                    {
                        visibleText = columnData.ToString().Length > width ? @columnData.ToString().Substring(0, width) + "..." : columnData.ToString();
                    }

                    <a href='#' id='@item.Id' class="menu_block" title="@columnData">@visibleText</a>
                }
                <div class="display_menu" style="display: none;">
                    <ul>
                        <li><a href="#">Edit/Correct</a></li>
                        <li><a href="#">Remove</a></li>
                        <li><a href="#>Archive</a></li>
                        <li><a href="#">View Detail</a></li>
                        @* <li><a href="@item.Expr1" target="_blank">Complete</a></li>*@
                    </ul>
                </div>
            </text>);
            columns.Bound(o => o.PartnerType).Width(100).Title("Partner Type");
            columns.Bound(o => o.ZCode).Width(100).Title("ZCode");
            columns.Bound(o => o.ZCodeActionType).Width(100).Title("ZCode Action Type");
        })
        .Pageable()
        .Sortable()
        .Scrollable(scrolling => scrolling
           .Enabled(true)
           .Height("auto"))
)
</div>
<script src="~/Scripts/jquery-1.8.2.js"></script>
<script src="~/Scripts/jquery-ui-1.9.2.js"></script>
<script type="text/javascript">
    
    $(function () {
        jQuery.noConflict();
    });
    function OpenManualAddModal() {
        debugger;
        jQuery.noConflict();
        $("#popup").dialog({
            autoOpen: true,
            modal: true,
            height: 650,
            width: 500,
            open: function () {

                $("#modal").attr("src", url);
            }
        });
    }
</script>

