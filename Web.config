  <elmah>
    <security allowRemoteAccess="false" />
    <errorLog type="Elmah.SqlErrorLog, Elmah" connectionStringName="hs3MVCMTQa2Entities" />
  </elmah>
  <chargify>
    <defaultAccount apiKey="YOUR_API_KEY" password="x" subdomain="YOUR_SUBDOMAIN" />
