    <membership defaultProvider="CustomMembershipProvider">
      <providers>
        <clear />
        <add name="CustomMembershipProvider" type="Generic.Helpers.CustomMembershipProvider, Generic" connectionStringName="hs3MVCMTQa2Entities" />
      </providers>
    </membership>
    <profile>
      <providers>
        <clear />
      </providers>
